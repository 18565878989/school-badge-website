<div class="life">
	<script type="text/javascript">
		$(document).ready(function() {
			$('.life-wrapper').Slider({
				slides: '.life-inner > a',
				autoMargin: false,
				fixedSlide: 1,
				fixWidth: false,
				offset: 54
			});
			$('a', '.life nav').click(function(e) {
				$('a.selected', '.life nav').removeClass('selected');
				$('.life-wrapper', '.life').removeClass('show');
				$(this).addClass('selected');
				$($(this).attr('href'), '.life').addClass('show');
				e.preventDefault();
			});
			$('select[name="life"]', '.life').change(function() {
				$('a[href="#life' + $(this).val() + '"]', '.life nav').trigger('click');
			});
			$('.select').selectbox();
		});
	</script>
