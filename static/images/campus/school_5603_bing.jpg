		<script>
    function textHandler(slides, current_page){
        let current_id = $(slides).eq(current_page-1).data('id');
		
        $('#'+current_id).removeClass('go-right');
        $('#'+current_id).removeClass('go-left');

        $(slides).eq(current_page-1).parent().nextAll().each(function(i,v){
            let id = $(v).find('.cell').data('id');
            $('#'+id).addClass('go-right');
        })
        $(slides).eq(current_page-1).parent().prevAll().each(function(i,v){
            let id = $(v).find('.cell').data('id');
            $('#'+id).addClass('go-left');
        })
    }
	</script>
