<div class="banner">
	<script type="text/javascript">
		$(document).ready(function() {
			$('.banner').Slider({
				slides: '.banner-wrapper > a',
				fixedSlide: 1,
				autoMargin: false,
				autoPlay: 5000,
				fadeOut: true,
				autoStop: false,
				autoHide: false,
				afterInit: function(slider, slides, current_page, total_page) {					
					$('.pause', slider).click(function(e) {
						if($(this).data('stop'))
						{
							slider.Slider('start');
							$(this).data('stop', false);
						}
						else
						{
							slider.Slider('stop');
							$(this).data('stop', true);
						}
						$(this).toggleClass('stop');
						e.preventDefault();
					});
				}
			});
		});
	</script>
