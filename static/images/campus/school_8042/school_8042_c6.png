    font-size: 2.25rem;
    padding: 0;
    line-height: 1.25;
    color: #9FDDF9;
    font-family: 'MalloryBold';
    text-shadow: -1px -1px 0 black, 1px -1px 0 black, -1px 1px 0 black, 1px 1px 0 black, 2px 4px 6px rgba(0, 0, 0, 0.5);
}
        
        /* .breadcrumbs */
        nav.breadcrumbs { display: none; }
        
        
        
        /* .overlay-slider */
        
