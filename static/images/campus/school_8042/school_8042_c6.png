<style type="text/css">
  .res2-news-container-gray {
    margin: 0 auto;
    max-width: 100%;
    padding: 0;
    background-color: #f0f1f3;
  }

  .res2-container {
    margin: 0 auto;
    max-width: 1300px;
    padding: 100px 20px;
    padding-top: 100px;
  }

  .res2-title {
    margin-bottom: 50px;
  }

  .res2-title h2 {
    position: relative;
    font-size: 2.35rem;
    color: #13133e;
    font-family: "MalloryBlack", sans-serif;
  }

  .res2-title h2 .res2-bg {
    font-family: "MalloryBold", sans-serif;
    position: absolute;
    left: -6px;
    top: 5px;
    color: transparent;
    font-size: 5rem;
    font-weight: 900;
    opacity: 0.1;
    line-height: 0;
    -webkit-text-stroke: 1px #000;
    -webkit-user-select: none;
  }

  .res2-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-gap: 30px;
  }

  .res2-card {
    box-shadow: 1px 1px 5px rgba(0, 0, 0, 0.2);
    background-color: #fff;
  }

  .res2-card img {
    height: 250px;
    width: 100%;
    object-fit: cover;
  }

  .res2-card-body {
    background-color: #fff;
    padding: 20px;
  }

  .res2-card-body .res2-text-date {
    font-size: 14px;
    color: #888;
    margin-bottom: 0;
    line-height: 1.7;
  }

  .res2-card-body .res2-text-date h3{
    font-size: 14px;
    color: #fff;
    margin-bottom: 0;
    line-height: 1.7;
  }

  .res2-line {
    height: 1px;
    width: 100%;
    background-color: #999;
    margin-bottom: 20px;
  }

  .res2-card-body .res2-text {
    color: #000;
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.35rem;
  }

  .res2-card-body .res2-text a {
    color: #3455db;
    line-height: normal !important;
    text-decoration-style: dotted;
    text-decoration-color: #00205b;
    text-decoration-thickness: 0.1em;
    text-decoration-skip-ink: auto;
    text-underline-offset: 1.5px;
    display: inline;
    font-size: 1.125rem;
    font-weight: 600;
  }

  .res2-card-body .res2-text a:hover {
    color: #697e2f;
    text-decoration-style: solid;
    text-decoration-color: #697e2f;
    text-decoration-thickness: 0.1em;
    text-decoration-skip-ink: auto;
    text-underline-offset: 1.5px;
    font-size: 1.125rem;
    font-weight: 600;
  }

  @media screen and (max-width: 900px) {
    .res2-cards {
      grid-template-columns: repeat(2, 1fr);
    }

    .res2-container {
      padding: 50px 20px;
      padding-top: 80px;
    }
  }

  @media screen and (max-width: 600px) {
    .res2-cards {
      grid-template-columns: 1fr;
    }

    .res2-container {
      padding: 30px 20px;
    }

    .res2-title {
      margin-bottom: 30px;
    }

    .res2-title h3 .res2-bg {
      display: none;
    }
  }

  .tag {
    font-family: "MalloryBold";
    display: inline-flex;
    padding: 0.25rem 1rem;
    border-radius: 5px 5px 0 0;
    background-color: #ef2f2f;
    color: white;
    align-items: center;
    margin: 0 3px 0 0;
    text-transform: uppercase;
    font-size: 0.8rem;
    &.blue {
      background-color: #0a509e;
    }
    &.purple {
      background-color: #9b0fff;
    }
    &.pink {
      background-color: #db2768;
    }
    &.green {
      background-color: #005b50;
    }
    &:last-child:not(:first-child) {
      margin: 0 0 0 3px;
    }
    &:first-child:not(:last-child) {
      margin: 0 3px 0 0;
    }
    .tag-exit {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-left: 6px;
      border: 0;
      border-radius: 50%;
      width: 25px;
      height: 25px;
      background-color: rgba(0, 0, 0, 0);
      transition: background-color 0.2s ease;
      outline: 0;
      padding: 0;
      cursor: pointer;
      i {
        color: white;
        font-size: 14px;
        display: inline-flex;
        justify-content: center;
        align-items: center;
      }
      &:hover {
        background-color: rgba(0, 0, 0, 0.35);
      }
      &:active {
        transition: 0;
        background-color: rgba(0, 0, 0, 0.55);
      }
    }
  }
</style>
