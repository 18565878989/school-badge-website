    font-size: 2.35rem;
    color: #13133E;
}
    .rr3-mag-left-column {
      flex: 0 0 80%;

      padding: 20px;
    }

    .rr3-mag-right-column {
      flex: 0 0 20%;

      padding: 20px;
    }

.rr3-mag-right-column img {border: 1px solid #7C7E7F;}

    @media (max-width: 768px) {
      .rr3-mag-left-column, .rr3-mag-right-column {
        flex: 0 0 100%;
      }
    }
</style>
