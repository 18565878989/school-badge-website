<script type="text/javascript">
//first-year
(function($){
    $( ".elementor-button-text" ).append( "<span></span>" );
    $( ".elementor-button-text span" ).append( "<div class='circle'></div>" );
	//first-year
    //$("#yrflip").click(function(){	
		//var x = document.getElementsByClassName("yearname");
		//var year = x[0].innerText;
      
      var lcount = document.getElementsByClassName("yearname");
        for (var i = 0; i < lcount.length; i++) {
          lcount[i].addEventListener('click', (function(i) {
              return function() {
                  var yearname = lcount[i].innerText;
                  $("."+yearname).slideToggle((1000),function(){
                    if(!$(this).hasClass("hided")) { 
                      $(this).addClass("hided");
                      $("#yrfaicon-"+yearname+" .elementor-icon").css('transform', 'rotate(180deg)');
                    } else {
                      $("#yrfaicon-"+yearname+" .elementor-icon").css('transform', 'rotate(0deg)');
                      $(this).removeClass("hided");
                    }
                  });
              };
        })(i), false);

      } // end. for loop
      
    //});
	
	$(".flip").click(function(){
		var suffix = this.id.match(/\d+/);
    	$("#mpanel-"+suffix).slideToggle((1000),function(){
		  if(!$(this).hasClass("hided")) { 
			$(this).addClass("hided");
			$(".faicon-"+suffix+" .elementor-icon").css('transform', 'rotate(180deg)');
		  } else {
			$(".faicon-"+suffix+" .elementor-icon").css('transform', 'rotate(0deg)');
			$(this).removeClass("hided");
		  }

		});		
    });

})(jQuery);</script>
<!-- end Simple Custom CSS and JS -->

</body>
</html>
