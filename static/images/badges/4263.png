	<section id="content">		
		<script type="text/javascript">
    var timeout = [];

    $(window).load(function() {
		let animate = function() {
			let height = $(window).scrollTop() + Math.round($(window).height() * 0.6);
			$('#content > section').each(function() {
				if(!$(this).hasClass('animate') && height > $(this).offset().top)
				{
					$(this).addClass('animate');
                    if($(this).attr('id') == 'section2') {
						$('li > div', '#section2').each(function(index) {
							let item = $(this);
							setTimeout(function() {
								item.addClass('animate');
							}, index * 200);
						});
					}
				}
			});
		};
		$(window).on('scroll', animate);
		animate();
	});
</script>
<div id="banner">
    <div class="banner-container">
                                                <div class="banner-item">
                    <div class="wrapper">
                        <img src="/cache/img/3a09b7163e25f6992490185fbab79c3c.png" alt="" loading="lazy" width="1904" height="1200" class="trans" />                        <video id="video" width="1904" height="1200" preload="none" playsinline webkit-playsinline muted loop>
                            <source src="/upload/banner/1/banner/672516b20bf29.mp4" type="video/mp4">
                        </video>
                        <div class="mask"></div>
                        <div class="container">
                            <button class="play"></button>
                        </div>
                    </div>
                                    </div>
                        </div>
    <div class="container">
                <div class="scroll-icon"></div>
    </div>
    <script type="text/javascript">
        $(document).ready(function() {
            let pager_click = false;

            $('#banner').Slider({
                slides: '.banner-item',
                maxSlide: 1,
                swipeControl: true,
                skipBoundary: true,
                infiniteLoop: true,
                pager: '.banner-pager',
                afterSlide: function(slider, slides, current_page, total_page) {
                    $.each(timeout, function(index, value) {
                        clearTimeout(value);
                    });
                    let videos = $('video', slider);
                    videos.each(function(i, video) {
                        video.pause();
                        video.currentTime = 0;
                    });
                    $('button', slider).removeClass('play').addClass('pause');
                    if($('.slider.current video', slider).length) {
                                                        video = document.querySelector('#banner .slider.current video');
                                video.play();
                                            }
                    else if(!pager_click) {
                        timeout = setTimeout(function() {
                            slider.Slider('next');
                        }, 5000);
                    }
                },
                afterResize: function(slider, slides, current_page, total_page) {
                    if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                },
                afterInit: function(slider, slides, current_page, total_page) {
                                            let videos = $('video', slider);
                        videos.each(function(i, video) {
                            video.addEventListener('ended', videoEnd, false);
                        });
                        if($('.slider.current video', slider).length) {
                                                                video = document.querySelector('#banner .slider.current video');
                                    video.play();
                                    $('.slider.current button', slider).removeClass('play').addClass('pause');
                                                    }
                        else {
                            timeout = setTimeout(function() {
                                slider.Slider('next');
                            }, 5000);
                        }
                                        if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                }
            });
            
            $('.banner-item video', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                let button = $(this).parent().find('button');
                if(button.hasClass('pause')) {
                    video.pause();
                    button.removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    button.removeClass('play').addClass('pause');
                }
            });
            $('.banner-item button', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                if($(this).hasClass('pause')) {
                    video.pause();
                    $(this).removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    $(this).removeClass('play').addClass('pause');
                }
            });

            $('body').on('click', '#banner .banner-pager a', function() {
                pager_click = true;
            });

            function videoEnd(e) {
                if(!pager_click) {
                    $('#banner').Slider('next');
                }
                else {
                    $('#banner .slider.current button').removeClass('pause').addClass('play');
                }
            }
        });
    </script>
</div>
<section id="section1">
    <div class="container">
                    <div class="left">
                <article class="editor"><h3 class="title"><span class="colour2" style="font-size: 30px;">FIND YOUR PURPOSE,&nbsp;</span></h3>
<h2 class="title"><span class="colour2" style="font-size: 30px;"><strong>REALISE YOUR POTENTIAL</strong></span></h2>
<p>&nbsp;</p>
<p>Our educational philosophy is that success is not a narrow path, but one forged by curiosity, exploration, and self-discovery. Our role is to provide the environment and the opportunities for our students to not only find that passion and purpose but also to realise their unique potential in school and in life.</p>
<p>&nbsp;</p>
<p class="rounded_title bg-colour2"><a href="https://wis.esf.edu.hk/en/about_us/vision_and_values/"><span style="font-size: 18px;"><span style="color: #ffffff;">Discover our vision and value</span>s</span></a></p>
<p>&nbsp;</p></article>
            </div>
                            <div class="right">
                <article class="editor"><p><iframe title="YouTube video player" src="https://www.youtube.com/embed/XwNj3-DsI8w?si=Tev_0cZv67CAq35m" width="560" height="315" frameborder="0" allowfullscreen="allowfullscreen"></iframe></p></article>
            </div>
                            <div class="responsive">
                <article class="editor"><h3 class="title"><span class="colour2" style="font-size: 30px;">FIND YOUR PURPOSE,&nbsp;</span></h3>
<h2 class="title"><span class="colour2" style="font-size: 30px;"><strong>REALISE YOUR POTENTIAL</strong></span></h2>
<p>&nbsp;</p>
<p>Our educational philosophy is that success is not a narrow path, but one forged by curiosity, exploration, and self-discovery. Our role is to provide the environment and the opportunities for our students to not only find that passion and purpose but also to realise their unique potential in school and in life.</p>
<p>&nbsp;</p>
<p class="rounded_title bg-colour2"><a href="https://wis.esf.edu.hk/en/about_us/vision_and_values/"><span style="font-size: 18px;"><span style="color: #ffffff;">Discover our vision and value</span>s</span></a></p>
<p>&nbsp;</p>
<p><iframe title="YouTube video player" src="https://www.youtube.com/embed/XwNj3-DsI8w?si=Tev_0cZv67CAq35m" width="560" height="315" frameborder="0" allowfullscreen="allowfullscreen"></iframe></p></article>
            </div>
            </div>
</section>
<section id="section2">
    <div class="container">
        <div class="section-title">
            <h2 class="colour2">What can WIS offer your family?</h2>
            <span class="bg-colour1"></span>
        </div>
    </div>
    <div class="wrapper bg-colour2">
        <div class="container">
            <ul>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/63ade9a1c91a9e79371b10d4542b05a6.png" alt="World-class Education" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">World Class Education</h3>
                            <div class="overlay bg-colour1">
                                <p>As an IB World School, we prepare our students to achieve their personal best through a world-class education tailored to each of their potential and needs.</p>
                                                                    <a  href="https://wis.esf.edu.hk/en/outstanding_education/curriculum/curriculum_overview">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/66b065864f9bc6dc635c4399cf4b9b20.png" alt="Well-rounded Education" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Well-rounded Education</h3>
                            <div class="overlay bg-colour1">
                                <p>From science to the arts to sports, we offer a full range of courses and experiences for students to choose from in and outside of the classrooms.</p>
                                                                    <a  href="https://wis.esf.edu.hk/en/outstanding_experiences/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/59dea5fb01b06b849f3e328c66cb57f4.png" alt="Comprehensive Student Support" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Comprehensive Student Support</h3>
                            <div class="overlay bg-colour1">
                                <p>The pastoral programme makes sure that each student’s well being is valued and taken care of.</p>
                                                                    <a  href="https://wis.esf.edu.hk/en/outstanding_education/student_support_wellbeing/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/11a690265b4241a0cd1516c2048d1322.png" alt="Incredible Results (1)" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Incredible Results</h3>
                            <div class="overlay bg-colour1">
                                <p>We celebrate the success of all students for their achievements during an exceptional year. These results reflect the hard work of students and their teachers and everybody giving their best.</p>
                                                                    <a  href="https://wis.esf.edu.hk/en/outstanding_education/exam_results_university_destinations/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/271caff51590d5a07ae9801088ca64d7.png" alt="Well-equipped Facilities" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Well-equipped Facilities</h3>
                            <div class="overlay bg-colour1">
                                <p>Among our well-rounded facilities, our Design Technology classrooms and Food Technology rooms have some of the most updated equipment.</p>
                                                                    <a  href="https://wis.esf.edu.hk/en/about_us/campus_find_us/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/8dd733d011ddd249a4a13f9d7960795d.png" alt="SIS offers icon-6" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">ESF Network</h3>
                            <div class="overlay bg-colour1">
                                <p>As part of the English Schools Foundation(ESF), our students are supported by the largest English-medium international school organisation in Hong Kong, providing them the resources and opportunities not found outside of ESF Schools.</p>
                                                                    <a  href="https://wis.esf.edu.hk/en/about_us/ESF_family/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                            </ul>
        </div>
    </div>
    <script type="text/javascript">
        $(window).load(function() {
            $('h3', '#section2').each(function() {
                let img = $(this).parent().children('img');
                if(img.length) {
                    $(this).css('top', img.offset().top + img.height() + 25 - $(this).parent().offset().top);
                }
            });
        });
    </script>
</section>
<section id="section3">
    <img src="/cache/img/63f17e7066a6b29d8c7e93fe956f8e34.jpg" alt="_MG_4670" loading="lazy" width="1722" height="1294" />    <div class="wrapper">
        <div class="section-title-container">
            <div class="section-title">
                <h2 class="colour2">International Curriculum</h2>
                <span class="bg-colour1"></span>
            </div>
        </div>
        <div class="tabs">
                            <button class="tab current" data-id="1">Years 7-9</button>
                            <button class="tab" data-id="2">Years 10-11</button>
                            <button class="tab" data-id="3">Years 12-13</button>
                    </div>
        <select class="tab-select" name="tab"><option value="1">Years 7-9</option><option value="2">Years 10-11</option><option value="3">Years 12-13</option></select>                    <div class="tab-content current" data-id="1">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Years 7-9 Curriculum</h3>
                    </div>
                                <article class="editor"><p><span style="font-weight: 400;">West Island School's Years 7 to 9 follow the</span><strong> IB Middle Years Programme (MYP)</strong><span style="font-weight: 400;">, offering a challenging and practical learning framework that supports students' transition and integration into the secondary school community, building a solid foundation of critical thinking and global mindedness for the middle and senior years.</span></p></article>
                                    <a href="https://wis.esf.edu.hk/en/outstanding_education/curriculum/curriculum_overview/years-7-9/">
                        <span>Learn More</span>
                    </a>
                            </div>
                    <div class="tab-content" data-id="2">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Years 10-11 Curriculum</h3>
                    </div>
                                <article class="editor"><p><span style="font-weight: 400;">In Years 10 and 11, West Island School offers a common curriculum and elective subjects, preparing students for </span><strong>I/GCSE</strong><span style="font-weight: 400;"> exams while providing guidance for future pathways both local and abroad.</span></p></article>
                                    <a href="https://wis.esf.edu.hk/en/outstanding_education/curriculum/curriculum_overview/years-10-11/">
                        <span>Learn More</span>
                    </a>
                            </div>
                    <div class="tab-content" data-id="3">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Years 12-13 Curriculum</h3>
                    </div>
                                <article class="editor"><p><span style="font-weight: 400;">In Years 12 and 13, West Island School offers three pathways, </span><strong>the IB Diploma Programme (IBDP), the IB Career-related Programme (IBCP),</strong><strong> BTEC, </strong><strong>and</strong><strong> the International Diploma</strong><span style="font-weight: 400;"> to give students agency in their studies based on their learning style and aspirations while fostering a well-rounded and global-minded outlook through leadership and community involvement.</span></p></article>
                                    <a href="https://wis.esf.edu.hk/en/outstanding_education/curriculum/curriculum_overview/years-12-13/">
                        <span>Learn More</span>
                    </a>
                            </div>
                <script type="text/javascript">
            $(document).ready(function() {
                $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();

                $('.tab', '#section3').click(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $(this).addClass('current');
                    $('.tab-content[data-id=' + $(this).data('id') + ']', '#section3').addClass('current');
                    $('select', '#section3').val($(this).data('id')).selectbox('refresh');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });

                $('.tab-select', '#section3').change(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $('.tab[data-id=' + $(this).val() + ']').addClass('current');
                    $('.tab-content[data-id=' + $(this).val() + ']', '#section3').addClass('current');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });
            });
        </script>
    </div>
</section>
<section id="section4" data-total="4">
    <div class="container">
        <div class="bg bg-colour4"></div>
        <div class="section-title-container">
            <div class="section-title">
                <h2 class="colour2">Personalised Learning Journey</h2>
                <span class="bg-colour1"></span>
            </div>
        </div>
        <div class="record-slider">
            <div class="slider-container">
                                    <div class="record-item">
                        <img src="/cache/img/8b91175d406cba93e67f6f83d88e85c1.jpg" alt="Dynasty_Day--85" loading="lazy" width="1070" height="802" />                        <div class="overlay">
                            <div class="bg-colour2"></div>
                            <h3>
                                <span>Dynasty-themed House System</span>
                            </h3>
                            <p>Our House System is built around six Chinese Dynasties: Han, Ming, Qing, Song, Tang and Yuan. These dynasties serve as the foundation for fostering identity, collaboration, and school spirit across all year groups. Every student, teacher, and staff member is allocated to one of these dynasties, creating a shared sense of belonging and community.</p>
                                                            <a href="https://wis.esf.edu.hk/en/outstanding_experiences/dynasties/">
                                    <span>Find out more</span>
                                </a>
                                                    </div>
                    </div>
                                    <div class="record-item">
                        <img src="/cache/img/3545d18ec4774e47943e97a08e0eceb1.jpg" alt="IMG_4675" loading="lazy" width="1070" height="802" />                        <div class="overlay">
                            <div class="bg-colour2"></div>
                            <h3>
                                <span>Horizons Week</span>
                            </h3>
                            <p>Horizons Week is an exciting opportunity for students to learn in non-traditional settings beyond the classroom. Every trip during Horizons Week is designed to broaden students' perspectives and enrich their experiential learning.</p>
                                                            <a href="https://wis.esf.edu.hk/en/outstanding_experiences/school_activities/">
                                    <span>Find out more</span>
                                </a>
                                                    </div>
                    </div>
                                    <div class="record-item">
                        <img src="/cache/img/82bb381776dd8880c172e3f46c3fe51b.jpg" alt="IDL_Week_d1--64" loading="lazy" width="1070" height="802" />                        <div class="overlay">
                            <div class="bg-colour2"></div>
                            <h3>
                                <span>Interdisciplinary Learning (IDL)</span>
                            </h3>
                            <p>Interdisciplinary Learning (IDL) Units are designed to foster authentic, student-centred inquiry that connects learning to both local and global contexts. These units empower students to explore meaningful questions, build resilience and take ownership of their learning journey.</p>
                                                            <a href="https://wis.esf.edu.hk/en/outstanding_experiences/interdisciplinary_learning/">
                                    <span>Find out more</span>
                                </a>
                                                    </div>
                    </div>
                                    <div class="record-item">
                        <img src="/cache/img/c49815a3fece7136121dd56822527b83.jpg" alt="Project_Kart-2" loading="lazy" width="1070" height="802" />                        <div class="overlay">
                            <div class="bg-colour2"></div>
                            <h3>
                                <span>Creativity, Activity, Service (CAS)</span>
                            </h3>
                            <p>With over 100 CAS activities, CAS is the heart of the school and provides our students with abundant opportunities to develop themselves and their passions through a broad spectrum of inter, extra and co-curricular activities. With its holistic approach, CAS is designed to strengthen and extend students’ personal and interpersonal learning.</p>
                                                            <a href="https://wis.esf.edu.hk/en/outstanding_experiences/cas_programme/">
                                    <span>Find out more</span>
                                </a>
