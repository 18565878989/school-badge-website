	<section id="content">		
		<script type="text/javascript">
    var timeout = [];

    $(window).load(function() {
		let animate = function() {
			let height = $(window).scrollTop() + Math.round($(window).height() * 0.6);
			$('#content > section').each(function() {
				if(!$(this).hasClass('animate') && height > $(this).offset().top)
				{
					$(this).addClass('animate');
                    if($(this).attr('id') == 'section2') {
						$('li > div', '#section2').each(function(index) {
							let item = $(this);
							setTimeout(function() {
								item.addClass('animate');
							}, index * 200);
						});
					}
				}
			});
		};
		$(window).on('scroll', animate);
		animate();
	});
</script>
<div id="banner">
    <div class="banner-container">
                                                <div class="banner-item">
                    <div class="wrapper">
                        <img src="/cache/img/a11c7ef11927d7062d19b53de5c5806e.png" alt="" loading="lazy" width="1904" height="1200" class="trans" />                        <video id="video" width="1904" height="1200" preload="none" playsinline webkit-playsinline muted loop>
                            <source src="/upload/banner/2/banner/677dcb84ed558.mp4" type="video/mp4">
                        </video>
                        <div class="mask"></div>
                        <div class="container">
                            <button class="play"></button>
                        </div>
                    </div>
                                    </div>
                        </div>
    <div class="container">
                <div class="scroll-icon"></div>
    </div>
    <script type="text/javascript">
        $(document).ready(function() {
            let pager_click = false;

            $('#banner').Slider({
                slides: '.banner-item',
                maxSlide: 1,
                swipeControl: true,
                skipBoundary: true,
                infiniteLoop: true,
                pager: '.banner-pager',
                afterSlide: function(slider, slides, current_page, total_page) {
                    $.each(timeout, function(index, value) {
                        clearTimeout(value);
                    });
                    let videos = $('video', slider);
                    videos.each(function(i, video) {
                        video.pause();
                        video.currentTime = 0;
                    });
                    $('button', slider).removeClass('play').addClass('pause');
                    if($('.slider.current video', slider).length) {
                                                        video = document.querySelector('#banner .slider.current video');
                                video.play();
                                            }
                    else if(!pager_click) {
                        timeout = setTimeout(function() {
                            slider.Slider('next');
                        }, 5000);
                    }
                },
                afterResize: function(slider, slides, current_page, total_page) {
                    if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                },
                afterInit: function(slider, slides, current_page, total_page) {
                                            let videos = $('video', slider);
                        videos.each(function(i, video) {
                            video.addEventListener('ended', videoEnd, false);
                        });
                        if($('.slider.current video', slider).length) {
                                                                video = document.querySelector('#banner .slider.current video');
                                    video.play();
                                    $('.slider.current button', slider).removeClass('play').addClass('pause');
                                                    }
                        else {
                            timeout = setTimeout(function() {
                                slider.Slider('next');
                            }, 5000);
                        }
                                        if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                }
            });
            
            $('.banner-item video', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                let button = $(this).parent().find('button');
                if(button.hasClass('pause')) {
                    video.pause();
                    button.removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    button.removeClass('play').addClass('pause');
                }
            });
            $('.banner-item button', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                if($(this).hasClass('pause')) {
                    video.pause();
                    $(this).removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    $(this).removeClass('play').addClass('pause');
                }
            });

            $('body').on('click', '#banner .banner-pager a', function() {
                pager_click = true;
            });

            function videoEnd(e) {
                if(!pager_click) {
                    $('#banner').Slider('next');
                }
                else {
                    $('#banner .slider.current button').removeClass('pause').addClass('play');
                }
            }
        });
    </script>
</div>
<section id="section1">
    <div class="container">
                    <div class="left">
                <article class="editor"><h3 class="homepage-title"><span style="font-size: 56px;"><em><span style="color: #34495e;"><strong>"Success For Every Child"</strong></span></em></span></h3>
<p>&nbsp;</p>
<p style="text-align: justify;"><span style="font-weight: 400;">Our mission is to provide a joyful, supportive and stimulating learning environment where successful learners achieve through a wide range of learning opportunities and have positive wellbeing.</span></p>
<p>&nbsp;</p>
<p class="rounded_title bg-colour1"><span style="color: #ffffff;"><a style="color: #ffffff;" href="https://kjs.esf.edu.hk/en/about_us/what_we_stand_for/">Discover Our Vision</a></span></p>
<p>&nbsp;</p></article>
            </div>
                            <div class="right">
                <article class="editor"><p>&nbsp;</p>
<p><span style="font-weight: 400;"><img class="round-border" src="https://kjs.esf.edu.hk/upload/page/35/self/672c66690a675.jpg" alt="" width="694" height="462" /></span></p></article>
            </div>
                            <div class="responsive">
                <article class="editor"><h3 class="homepage-title"><span style="font-size: 56px;"><em><span style="color: #34495e;"><strong>"Success For Every Child"</strong></span></em></span></h3>
<p>&nbsp;</p>
<p><span style="font-weight: 400;">Our mission is to provide a joyful, supportive and stimulating learning environment where successful learners achieve through a wide range of learning opportunities and have positive wellbeing.</span></p>
<p>&nbsp;</p>
<p><span style="font-weight: 400;"><img class="round-border" src="https://kjs.esf.edu.hk/upload/page/35/self/672c66690a675.jpg" alt="" width="693" height="461" /></span></p>
<p>&nbsp;</p>
<p class="rounded_title bg-colour2"><span style="color: #ffffff;"><a style="color: #ffffff;" href="https://kjs.esf.edu.hk/en/about_us/what_we_stand_for/">Discover Our Vision</a></span></p>
<p>&nbsp;</p></article>
            </div>
            </div>
</section>
<section id="section2">
    <div class="container">
        <div class="section-title">
            <h2 class="colour2">What can Kowloon Junior School offer your family?</h2>
            <span class="bg-colour1"></span>
        </div>
    </div>
    <div class="wrapper bg-colour2">
        <div class="container">
            <ul>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/ae731b9a6a7568d0ad9cacf4b9f21310.png" alt="ESF_Logomark_BW_RGB" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">ESF Network</h3>
                            <div class="overlay bg-colour1">
                                <p>As part of the English Schools Foundation(ESF), our students are supported by the largest English-medium international school organisation in Hong Kong, providing them the resources and opportunities not found outside of ESF Schools.</p>
                                                                    <a  href="https://kjs.esf.edu.hk/en/about_us/marketing_family/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/65d27cdd0c97f2956decb2338b2d61c3.png" alt="Strong School-Family Connection" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Strong School-Family Connection</h3>
                            <div class="overlay bg-colour1">
                                <p>We believe in fostering a strong partnership between schools and families.</p>
                                                                    <a  href="https://kjs.esf.edu.hk/en/outstanding_education/parent_partnership/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/45e336d06c4c9c81a2cc7f1465ef972a.png" alt="Comprehensive Student Support" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Comprehensive Student Support</h3>
                            <div class="overlay bg-colour1">
                                <p>Our schools offer comprehensive support systems, including personalised guidance, pastoral care, and counselling services, to help students thrive academically, emotionally, and socially.</p>
                                                                    <a  href="https://kjs.esf.edu.hk/en/outstanding_education/student_support/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/611db28e3c7f0971780cba7a772abb86.png" alt="Well-rounded Education" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Well-rounded Education</h3>
                            <div class="overlay bg-colour1">
                                <p>Alongside academic excellence, our well-rounded education cultivates talents, interests, and character through diverse co-curricular activities in sports, arts, music, and community service.</p>
                                                                    <a  href="https://kjs.esf.edu.hk/en/outstanding_education/our_approach/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/caa99d79f7b5abe6e3f8d68f565892d5.png" alt="Real-world Experience" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Student Agency and Action</h3>
                            <div class="overlay bg-colour1">
                                <p>Nurturing student agency and action empowers learners to take ownership, apply knowledge, and become agents of positive change in their communities.</p>
                                                                    <a  href="https://kjs.esf.edu.hk/en/outstanding_experiences/action_student_leadership/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/6f534ca374045b8d4a16dce7d3e9a49a.png" alt="World-class Education" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Student Well-Being</h3>
                            <div class="overlay bg-colour1">
                                <p>We foster students' social-emotional learning through assemblies, classroom integration, and cultivating respectful school relationships - empowering well-being and academic achievement.</p>
                                                                    <a  href="https://kjs.esf.edu.hk/en/outstanding_education/student_wellbeing/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                            </ul>
        </div>
    </div>
    <script type="text/javascript">
        $(window).load(function() {
            $('h3', '#section2').each(function() {
                let img = $(this).parent().children('img');
                if(img.length) {
                    $(this).css('top', img.offset().top + img.height() + 25 - $(this).parent().offset().top);
                }
            });
        });
    </script>
</section>
<section id="section3">
    <img src="/cache/img/d77e934da77bf6c60e8374fb0d8d736b.png" alt="PYP (1) copy" loading="lazy" width="1722" height="1294" />    <div class="wrapper">
        <div class="section-title-container">
            <div class="section-title">
                <h2 class="colour2">Primary Years Programme (PYP)</h2>
                <span class="bg-colour1"></span>
            </div>
        </div>
        <div class="tabs">
                            <button class="tab current" data-id="1"></button>
                    </div>
                            <div class="tab-content current" data-id="1">
                                <article class="editor"><p><span style="font-weight: 400;">Kowloon Junior School is an IB World School committed to educating open-minded seekers, supporting individual student needs, and developing the whole child's skills, attitudes, and global perspectives. The IB curriculum emphasises transdisciplinary learning, research, communication, and critical thinking to foster respect, responsibility, and meaningful action.</span></p></article>
                                    <a href="https://kjs.esf.edu.hk/en/outstanding_education/curriculum/">
                        <span>Find out more</span>
                    </a>
                            </div>
                <script type="text/javascript">
            $(document).ready(function() {
                $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();

                $('.tab', '#section3').click(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $(this).addClass('current');
                    $('.tab-content[data-id=' + $(this).data('id') + ']', '#section3').addClass('current');
                    $('select', '#section3').val($(this).data('id')).selectbox('refresh');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });

                $('.tab-select', '#section3').change(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $('.tab[data-id=' + $(this).val() + ']').addClass('current');
                    $('.tab-content[data-id=' + $(this).val() + ']', '#section3').addClass('current');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });
            });
        </script>
    </div>
</section>
