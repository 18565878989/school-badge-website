    <script type="text/javascript">
        $(document).ready(function() {
            const ori_total = parseInt($('#section4').data('total'));
            let slider_loop = ori_total >= 3 ? true : false;
            $('#section4').Slider({
                slides: '.record-item',
                maxSlide: 1,
                swipeControl: true,
                skipBoundary: true,
                infiniteLoop: slider_loop,
                dummySlide: slider_loop,
				afterSlide: function(slider, slides, current_page, total_page) {
					if(slider_loop) {
						if(current_page == ori_total) {
							slider.Slider('jump', ori_total * 2).Slider('start');
						}
						if(current_page == ori_total * 2 + 1) {
							slider.Slider('jump', ori_total + 1).Slider('start');
						}
					}
				},
                afterInit: function(slider, slides, current_page, total_page) {
                    if(slider_loop) {
                        slider.Slider('jump', ori_total * 2);
                    }
                    else {
                        slider.Slider('jump', total_page);
                    }
                }
            });
        });
    </script>
</section>
<section id="section6">
    <div class="container">
        <div class="section-title">
            <h2 class="colour2">Testimonials</h2>
            <span class="bg-colour1"></span>
        </div>
        <div class="wrapper">
            <div class="tabs">
                                    <button class="tab current" data-id="1">Students</button>
                                    <button class="tab" data-id="2">Parents</button>
                                    <button class="tab" data-id="3">Alumni</button>
                            </div>
            <select class="tab-select" name="tab"><option value="1">Students</option><option value="2">Parents</option><option value="3">Alumni</option></select>                            <div class="tab-content current" data-id="1">
                                            <div class="record-slider">
                            <div class="slider-container">
                                                                    <div class="record-item">
                                        <div class="left">
                                            <div class="thumbnail bg-colour1">
                                                <span></span>
                                                <img src="/cache/img/2424c7a2839edc77c01dc71adbcc057b.png" alt="CHAN_Yau Ning_Y6" loading="lazy" width="548" height="548" />                                            </div>
                                                                                            <div class="slider-pager">
                                                    <button class="prev"></button>
                                                    <span>1 / 3</span>
                                                    <button class="next"></button>
                                                </div>
                                                                                    </div>
                                        <div class="right">
                                            <article>
                                                                                                    <div class="content">
                                                        <p class="description">I love KJS because it is a wonderful school that fosters a positive learning environment. Our teachers are incredibly supportive and always available to help us when we need it. I've noticed significant improvements in my learning, thanks to the engaging curriculum and collaborative atmosphere. Overall, KJS inspires me to reach my full potential every day!</p>
                                                        <button class="view-more">
                                                            <span>View More</span>
                                                        </button>
                                                        <p class="content">I love KJS because it is a wonderful school that fosters a positive learning environment. Our teachers are incredibly supportive and always available to help us when we need it. I've noticed significant improvements in my learning, thanks to the engaging curriculum and collaborative atmosphere. Overall, KJS inspires me to reach my full potential every day!</p>
                                                        <button class="view-less">
                                                            <span>View Less</span>
                                                        </button>
                                                    </div>
                                                                                            </article>
                                                                                            <div class="title">
                                                    <span></span>
                                                    <h3>Yau Yau - Year 6</h3>
                                                </div>
                                                                                    </div>
                                    </div>
                                                                    <div class="record-item">
                                        <div class="left">
                                            <div class="thumbnail bg-colour1">
                                                <span></span>
                                                <img src="/cache/img/b77086b3fb13ba5402552320ae26bb63.png" alt="JAIN_Fida_6AC" loading="lazy" width="548" height="548" />                                            </div>
                                                                                            <div class="slider-pager">
                                                    <button class="prev"></button>
                                                    <span>2 / 3</span>
                                                    <button class="next"></button>
                                                </div>
                                                                                    </div>
                                        <div class="right">
                                            <article>
                                                                                                    <div class="content">
                                                        <p class="description">I love KJS because it is a positive learning environment. Our teachers and staff are incredibly supportive and always there when you need help. KJS is a really fun place to learn. KJS inspires me everyday to be the best person I can be!</p>
                                                        <button class="view-more">
                                                            <span>View More</span>
                                                        </button>
                                                        <p class="content">I love KJS because it is a positive learning environment. Our teachers and staff are incredibly supportive and always there when you need help. KJS is a really fun place to learn. KJS inspires me everyday to be the best person I can be!</p>
                                                        <button class="view-less">
                                                            <span>View Less</span>
                                                        </button>
                                                    </div>
                                                                                            </article>
                                                                                            <div class="title">
                                                    <span></span>
                                                    <h3>Fida - Year 6</h3>
                                                </div>
                                                                                    </div>
                                    </div>
                                                                    <div class="record-item">
                                        <div class="left">
                                            <div class="thumbnail bg-colour1">
                                                <span></span>
                                                <img src="/cache/img/7e33aa1fcffb6ff5a72369a6b00fee5a.png" alt="Mishka - Year 6" loading="lazy" width="548" height="548" />                                            </div>
                                                                                            <div class="slider-pager">
                                                    <button class="prev"></button>
                                                    <span>3 / 3</span>
                                                    <button class="next"></button>
                                                </div>
                                                                                    </div>
                                        <div class="right">
                                            <article>
                                                                                                    <div class="content">
                                                        <p class="description">KJS gives its students lots of opportunities to sign up for different after school activities and clubs to foster our interests. The teachers are amazing because they encourage us to experience and learn new things. KJS also respects my unique culture and makes me feel valued for who I am. I love being a student at KJS!</p>
                                                        <button class="view-more">
                                                            <span>View More</span>
                                                        </button>
                                                        <p class="content">KJS gives its students lots of opportunities to sign up for different after school activities and clubs to foster our interests. The teachers are amazing because they encourage us to experience and learn new things. KJS also respects my unique culture and makes me feel valued for who I am. I love being a student at KJS!</p>
                                                        <button class="view-less">
                                                            <span>View Less</span>
                                                        </button>
                                                    </div>
                                                                                            </article>
                                                                                            <div class="title">
                                                    <span></span>
                                                    <h3>Mishka - Year 6</h3>
                                                </div>
                                                                                    </div>
                                    </div>
                                                            </div>
                        </div>
                                    </div>
                            <div class="tab-content" data-id="2">
                                            <div class="record-slider">
                            <div class="slider-container">
                                                                    <div class="record-item">
                                        <div class="left">
                                            <div class="thumbnail bg-colour1">
                                                <span></span>
                                                <img src="/cache/img/35360e56ff467308a9690961dac6cb40.jpg" alt="Anna" loading="lazy" width="548" height="548" />                                            </div>
                                                                                    </div>
                                        <div class="right">
                                            <article>
                                                                                                    <div class="content">
                                                        <p class="description">We couldn’t be happier with KJS! The school’s support for each child goes beyond academics—they truly care about the well-being and growth of every student. My kids have thrived here, building confidence and learning based on their own strengths. The teachers are incredible, using modern tools and methods, and the facilities are amazing; seeing what even Year 1 students have access to is impressive! With no homework, our kids still come out well-prepared, independent, and confident. We love the KJS community—it’s a safe, positive place where kids are nurtured to be their best. Highly recommended!</p>
                                                        <button class="view-more">
                                                            <span>View More</span>
                                                        </button>
                                                        <p class="content">We couldn’t be happier with KJS! The school’s support for each child goes beyond academics—they truly care about the well-being and growth of every student. My kids have thrived here, building confidence and learning based on their own strengths. The teachers are incredible, using modern tools and methods, and the facilities are amazing; seeing what even Year 1 students have access to is impressive! With no homework, our kids still come out well-prepared, independent, and confident. We love the KJS community—it’s a safe, positive place where kids are nurtured to be their best. Highly recommended!</p>
                                                        <button class="view-less">
                                                            <span>View Less</span>
                                                        </button>
                                                    </div>
                                                                                            </article>
                                                                                            <div class="title">
                                                    <span></span>
                                                    <h3>Anna - Mother of Sasha, 2022 Graduate, and Slava, Y6 Student</h3>
                                                </div>
                                                                                    </div>
                                    </div>
                                                            </div>
                        </div>
                                    </div>
                            <div class="tab-content" data-id="3">
                                            <div class="record-slider">
                            <div class="slider-container">
                                                                    <div class="record-item">
                                        <div class="left">
                                            <div class="thumbnail bg-colour1">
                                                <span></span>
                                                <img src="/cache/img/d1765565a26a5d2ec74089b73d41f541.png" alt="Bernita, Arabelle" loading="lazy" width="548" height="548" />                                            </div>
                                                                                            <div class="slider-pager">
                                                    <button class="prev"></button>
                                                    <span>1 / 3</span>
                                                    <button class="next"></button>
                                                </div>
                                                                                    </div>
                                        <div class="right">
                                            <article>
                                                                                                    <div class="content">
                                                        <p class="description">ESF serves as a foundational pillar of our family's educational journey. My cousins and I take great pride in being graduates of ESF. Among us, Gladwin and Billy share a special bond with Arabelle, having attended KJS themselves, where they created countless cherished memories.<br><br> KJS and ESF have not only nurtured our growth but also inspired us to become well-rounded individuals. We were encouraged to explore our potentials and given opportunities to pursue our passions, eventually allowing us to grow up and make meaningful contributions to our society.<br><br> I hope Arabelle will carry forward this esteemed tradition, becoming both a contributor to and a beneficiary of the world class ESF educational experience.</p>
                                                        <button class="view-more">
                                                            <span>View More</span>
                                                        </button>
                                                        <p class="content">ESF serves as a foundational pillar of our family's educational journey. My cousins and I take great pride in being graduates of ESF. Among us, Gladwin and Billy share a special bond with Arabelle, having attended KJS themselves, where they created countless cherished memories.<br><br> KJS and ESF have not only nurtured our growth but also inspired us to become well-rounded individuals. We were encouraged to explore our potentials and given opportunities to pursue our passions, eventually allowing us to grow up and make meaningful contributions to our society.<br><br> I hope Arabelle will carry forward this esteemed tradition, becoming both a contributor to and a beneficiary of the world class ESF educational experience.</p>
                                                        <button class="view-less">
                                                            <span>View Less</span>
                                                        </button>
                                                    </div>
                                                                                            </article>
                                                                                            <div class="title">
                                                    <span></span>
                                                    <h3>Billy– Medical Graduate, 2011 Graduate, Arabelle- Year 5 KJS student, Bernita- Hong Kong Qualified Lawyer, Gladwin- Registered Medical Practitioner, 2010 Graduate</h3>
                                                </div>
                                                                                    </div>
                                    </div>
                                                                    <div class="record-item">
                                        <div class="left">
                                            <div class="thumbnail bg-colour1">
                                                <span></span>
                                                <img src="/cache/img/8232a210652bcd9fbe338ca0e043c0c0.jpg" alt="Simon Garner, Nov 2024, Hong Kong Peak" loading="lazy" width="548" height="548" />                                            </div>
                                                                                            <div class="slider-pager">
                                                    <button class="prev"></button>
                                                    <span>2 / 3</span>
                                                    <button class="next"></button>
                                                </div>
                                                                                    </div>
                                        <div class="right">
                                            <article>
                                                                                                    <div class="content">
                                                        <p class="description">I would simply say that Kowloon Junior School definitely prepared me well for my secondary boarding school education in England, after leaving KJS at the age of 11 in 1965. Even after 60+ years, I still remember my KJS class teacher in 1963 – Ms. Fung – who had a very positive impact on me. It was wonderful to re-visit KJS again for the first time in 2024, almost 60 years since I “graduated” in 1965. Thank you, KJS.</p>
                                                        <button class="view-more">
                                                            <span>View More</span>
                                                        </button>
                                                        <p class="content">I would simply say that Kowloon Junior School definitely prepared me well for my secondary boarding school education in England, after leaving KJS at the age of 11 in 1965. Even after 60+ years, I still remember my KJS class teacher in 1963 – Ms. Fung – who had a very positive impact on me. It was wonderful to re-visit KJS again for the first time in 2024, almost 60 years since I “graduated” in 1965. Thank you, KJS.</p>
                                                        <button class="view-less">
                                                            <span>View Less</span>
                                                        </button>
                                                    </div>
                                                                                            </article>
                                                                                            <div class="title">
                                                    <span></span>
                                                    <h3>Simon- 1965 Graduate</h3>
                                                </div>
                                                                                    </div>
                                    </div>
                                                                    <div class="record-item">
                                        <div class="left">
                                            <div class="thumbnail bg-colour1">
                                                <span></span>
                                                <img src="/cache/img/c3d64fdccf680d412fae324ea1c280a9.png" alt="圖片 1" loading="lazy" width="548" height="548" />                                            </div>
                                                                                            <div class="slider-pager">
                                                    <button class="prev"></button>
                                                    <span>3 / 3</span>
                                                    <button class="next"></button>
                                                </div>
                                                                                    </div>
                                        <div class="right">
                                            <article>
                                                                                                    <div class="content">
                                                        <p class="description">Three KJS Alumni—Sunil, Anil, and Vishal—have maintained a lifelong friendship since graduating in 1995, supporting each other through various life paths. Their bond has transcended generations, as their sons, Jai, Sahil, and Aveer, now share the same enriching experiences at ESF Kowloon Junior School. These boys are not only building their own camaraderie but also embodying the values of friendship and loyalty instilled by their fathers. Their story is a testament to the lasting connections formed at KJS which continued through KGV showing how the relationships nurtured in school can shape future generations.<br><br>Thanks for the great times, then and now!</p>
                                                        <button class="view-more">
                                                            <span>View More</span>
                                                        </button>
                                                        <p class="content">Three KJS Alumni—Sunil, Anil, and Vishal—have maintained a lifelong friendship since graduating in 1995, supporting each other through various life paths. Their bond has transcended generations, as their sons, Jai, Sahil, and Aveer, now share the same enriching experiences at ESF Kowloon Junior School. These boys are not only building their own camaraderie but also embodying the values of friendship and loyalty instilled by their fathers. Their story is a testament to the lasting connections formed at KJS which continued through KGV showing how the relationships nurtured in school can shape future generations.<br><br>Thanks for the great times, then and now!</p>
                                                        <button class="view-less">
                                                            <span>View Less</span>
                                                        </button>
                                                    </div>
                                                                                            </article>
                                                                                            <div class="title">
                                                    <span></span>
                                                    <h3>Anil and Sahil Chandiramani, Sunil and Jai Detaramani and Vishal and Aveer Daswani.</h3>
                                                </div>
                                                                                    </div>
                                    </div>
                                                            </div>
                        </div>
                                    </div>
