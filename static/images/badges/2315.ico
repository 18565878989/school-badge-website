	<section id="content">		
		<script type="text/javascript">
    var timeout = [];

    $(window).load(function() {
		let animate = function() {
			let height = $(window).scrollTop() + Math.round($(window).height() * 0.6);
			$('#content > section').each(function() {
				if(!$(this).hasClass('animate') && height > $(this).offset().top)
				{
					$(this).addClass('animate');
                    if($(this).attr('id') == 'section2') {
						$('li > div', '#section2').each(function(index) {
							let item = $(this);
							setTimeout(function() {
								item.addClass('animate');
							}, index * 200);
						});
					}
				}
			});
		};
		$(window).on('scroll', animate);
		animate();
	});
</script>
<div id="banner">
    <div class="banner-container">
                                                <div class="banner-item">
                    <div class="wrapper">
                        <img src="/cache/img/2803d8b731838149ef2f60e6656d983f.png" alt="" loading="lazy" width="1904" height="1200" class="trans" />                        <video id="video" width="1904" height="1200" preload="none" playsinline webkit-playsinline muted loop>
                            <source src="/upload/banner/1/banner/671e27a071e95.mp4" type="video/mp4">
                        </video>
                        <div class="mask"></div>
                        <div class="container">
                            <button class="play"></button>
                        </div>
                    </div>
                                    </div>
                        </div>
    <div class="container">
                <div class="scroll-icon"></div>
    </div>
    <script type="text/javascript">
        $(document).ready(function() {
            let pager_click = false;

            $('#banner').Slider({
                slides: '.banner-item',
                maxSlide: 1,
                swipeControl: true,
                skipBoundary: true,
                infiniteLoop: true,
                pager: '.banner-pager',
                afterSlide: function(slider, slides, current_page, total_page) {
                    $.each(timeout, function(index, value) {
                        clearTimeout(value);
                    });
                    let videos = $('video', slider);
                    videos.each(function(i, video) {
                        video.pause();
                        video.currentTime = 0;
                    });
                    $('button', slider).removeClass('play').addClass('pause');
                    if($('.slider.current video', slider).length) {
                                                        video = document.querySelector('#banner .slider.current video');
                                video.play();
                                            }
                    else if(!pager_click) {
                        timeout = setTimeout(function() {
                            slider.Slider('next');
                        }, 5000);
                    }
                },
                afterResize: function(slider, slides, current_page, total_page) {
                    if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                },
                afterInit: function(slider, slides, current_page, total_page) {
                                            let videos = $('video', slider);
                        videos.each(function(i, video) {
                            video.addEventListener('ended', videoEnd, false);
                        });
                        if($('.slider.current video', slider).length) {
                                                                video = document.querySelector('#banner .slider.current video');
                                    video.play();
                                    $('.slider.current button', slider).removeClass('play').addClass('pause');
                                                    }
                        else {
                            timeout = setTimeout(function() {
                                slider.Slider('next');
                            }, 5000);
                        }
                                        if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                }
            });
            
            $('.banner-item video', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                let button = $(this).parent().find('button');
                if(button.hasClass('pause')) {
                    video.pause();
                    button.removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    button.removeClass('play').addClass('pause');
                }
            });
            $('.banner-item button', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                if($(this).hasClass('pause')) {
                    video.pause();
                    $(this).removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    $(this).removeClass('play').addClass('pause');
                }
            });

            $('body').on('click', '#banner .banner-pager a', function() {
                pager_click = true;
            });

            function videoEnd(e) {
                if(!pager_click) {
                    $('#banner').Slider('next');
                }
                else {
                    $('#banner .slider.current button').removeClass('pause').addClass('play');
                }
            }
        });
    </script>
</div>
<section id="section1">
    <div class="container">
                    <div class="left">
                <article class="editor"><h3 class="homepage-title title" style="text-align: left;">Above</h3>
<h3 class="homepage-title title" style="text-align: left;">And</h3>
<h3 class="homepage-title title" style="text-align: left;">Beyond</h3>
<p>&nbsp;</p>
<p style="text-align: justify;"><span style="font-weight: 400;">At Peak School, we aim to become effective communicators, confident critical thinkers and enthusiastic life-long learners. In partnership with our community, we strive to have integrity and be socially responsible global citizens.</span></p>
<p>&nbsp;</p>
<p class="rounded_title bg-colour1"><a href="https://ps.esf.edu.hk/en/about_us/what_we_stand_for/" target="_blank" rel="noopener"><span style="color: #ffffff;">Discover Our Vision</span></a></p></article>
            </div>
                            <div class="right">
                <article class="editor"><p><img class="round-border" src="https://ps.esf.edu.hk/upload/files/1/file/673add029d382.jpg" alt="" width="392" height="523" /></p></article>
            </div>
                            <div class="responsive">
                <article class="editor"><h3 class="homepage-title title" style="text-align: left;">Above</h3>
<h3 class="homepage-title title" style="text-align: left;">And</h3>
<h3 class="homepage-title title" style="text-align: left;">Beyond</h3>
<p>&nbsp;</p>
<p style="text-align: justify;"><span style="font-weight: 400;">At Peak School, we aim to become effective communicators, confident critical thinkers and enthusiastic life-long learners. In partnership with our community, we strive to have integrity and be socially responsible global citizens.</span></p>
<p style="text-align: justify;">&nbsp;</p>
<p><img class="round-border" src="https://ps.esf.edu.hk/upload/files/1/file/673add029d382.jpg" alt="" width="392" height="523" /></p>
<p>&nbsp;</p>
<p class="rounded_title bg-colour1"><a href="https://ps.esf.edu.hk/en/about_us/what_we_stand_for/" target="_blank" rel="noopener"><span style="color: #ffffff;">Discover Our Vision</span></a></p>
<p>&nbsp;</p></article>
            </div>
            </div>
</section>
<section id="section2">
    <div class="container">
        <div class="section-title">
            <h2 class="colour2">What can Peak School offer your family?</h2>
            <span class="bg-colour1"></span>
        </div>
    </div>
    <div class="wrapper bg-colour2">
        <div class="container">
            <ul>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/b8b416ddb18600e5b18cdf907b4d6270.png" alt="ESF_Logomark_BW_RGB" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">ESF Network</h3>
                            <div class="overlay bg-colour1">
                                <p>As part of the English Schools Foundation(ESF), our students are supported by the largest English-medium international school organisation in Hong Kong, providing them the resources and opportunities not found outside of ESF Schools.</p>
                                                                    <a  href="https://ps.esf.edu.hk/en/about_us/marketing_family/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/c366ec9fe1d9b9a7f85669c9927bc65c.png" alt="World-class Education" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">World Class Education</h3>
                            <div class="overlay bg-colour1">
                                <p>At ESF schools, we provide a world-class education that is renowned for its academic excellence and rigorous curriculum. Our dedicated teachers and staff ensure that every student receives the best possible learning experience.</p>
                                                                    <a  href="https://ps.esf.edu.hk/en/outstanding_education/curriculum/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/807907e3257df813406eaaa9f6a345f2.png" alt="Comprehensive Student Support" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Comprehensive Student Support</h3>
                            <div class="overlay bg-colour1">
                                <p>We believe in nurturing the holistic development of our students. Our schools offer comprehensive support systems, including personalised guidance, pastoral care, and counselling services, to help students thrive academically, emotionally, and socially.</p>
                                                                    <a  href="https://ps.esf.edu.hk/en/outstanding_education/student_support_wellbeing/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/289adeb6e02105ac46187690bb93d8a6.png" alt="Strong School-Family Connection" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Strong School-Family Connection</h3>
                            <div class="overlay bg-colour1">
                                <p>We believe in fostering a strong partnership between schools and families. We actively encourage parental involvement and maintain open lines of communication to ensure that parents are fully engaged in their child's educational journey.</p>
                                                                    <a  href="https://ps.esf.edu.hk/en/outstanding_education/parent_partnership/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/5f69cda425e658669bdf92336065c64a.png" alt="Real-world Experience" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Real World Experience</h3>
                            <div class="overlay bg-colour1">
                                <p>Through interdisciplinary projects, your child applies their knowledge to solve authentic, engaging challenges.</p>
                                                                    <a  href="https://ps.esf.edu.hk/en/outstanding_experiences/outdoor_learning/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/52816046484c713269f7cb1b1aaf556f.png" alt="Well-rounded Education" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Well-rounded Education</h3>
                            <div class="overlay bg-colour1">
                                <p>Our well-rounded education cultivates talents, interests, and character through the school’s curriculum, trips, camps, leadership opportunities and diverse co-curricular activities in sports, and expressive arts.</p>
                                                                    <a  href="https://ps.esf.edu.hk/en/outstanding_experiences/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                            </ul>
        </div>
    </div>
    <script type="text/javascript">
        $(window).load(function() {
            $('h3', '#section2').each(function() {
                let img = $(this).parent().children('img');
                if(img.length) {
                    $(this).css('top', img.offset().top + img.height() + 25 - $(this).parent().offset().top);
                }
            });
        });
    </script>
</section>
<section id="section3">
    <img src="/cache/img/71f588897357c7c5714c00a66515d484.jpg" alt="peakschool_3937" loading="lazy" width="1722" height="1294" />    <div class="wrapper">
        <div class="section-title-container">
            <div class="section-title">
                <h2 class="colour2">Primary Years Programme (PYP)</h2>
                <span class="bg-colour1"></span>
            </div>
        </div>
        <div class="tabs">
                            <button class="tab current" data-id="1"></button>
                    </div>
                            <div class="tab-content current" data-id="1">
                                <article class="editor"><p><span style="font-weight: 400;">Peak School is an IB World School committed to educating open-minded seekers, supporting individual student needs, and developing the whole child's skills, attitudes, and global perspectives. The IB curriculum emphasises transdisciplinary learning, research, communication, and critical thinking to foster respect, responsibility, and meaningful action.</span></p></article>
                                    <a href="https://ps.esf.edu.hk/en/outstanding_education/curriculum/">
                        <span>Find out more</span>
                    </a>
                            </div>
                <script type="text/javascript">
            $(document).ready(function() {
                $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();

                $('.tab', '#section3').click(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $(this).addClass('current');
                    $('.tab-content[data-id=' + $(this).data('id') + ']', '#section3').addClass('current');
                    $('select', '#section3').val($(this).data('id')).selectbox('refresh');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });

                $('.tab-select', '#section3').change(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $('.tab[data-id=' + $(this).val() + ']').addClass('current');
                    $('.tab-content[data-id=' + $(this).val() + ']', '#section3').addClass('current');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });
            });
        </script>
    </div>
</section>
<section id="section4" data-total="5">
    <div class="container">
        <div class="bg bg-colour4"></div>
        <div class="section-title-container">
            <div class="section-title">
                <h2 class="colour2">Life at Peak School</h2>
                <span class="bg-colour1"></span>
            </div>
        </div>
        <div class="record-slider">
            <div class="slider-container">
                                    <div class="record-item">
                        <img src="/cache/img/ebcf696dc6e880dd7a8470a23a847185.jpg" alt="Untitled design" loading="lazy" width="1070" height="802" />                        <div class="overlay">
                            <div class="bg-colour2"></div>
                            <h3>
                                <span>DIVERSITY, EQUITY, AND INCLUSION</span>
                            </h3>
                            <p>Peak School is committed to creating an environment that values, respects, and embraces the diversity of all individuals within our community.  We are dedicated to meeting the needs of our community, where every student feels a sense of belonging and has the opportunity to thrive.</p>
                                                            <a href="https://ps.esf.edu.hk/en/about_us/what_we_stand_for/">
                                    <span>Find out more</span>
                                </a>
                                                    </div>
                    </div>
                                    <div class="record-item">
                        <img src="/cache/img/4b246f3940a33fc5e37c9982cedc8b06.jpg" alt="IMG_9192" loading="lazy" width="1070" height="802" />                        <div class="overlay">
                            <div class="bg-colour2"></div>
                            <h3>
                                <span>STUDENT LEADERSHIP</span>
                            </h3>
                            <p>Student leadership opportunities cultivate a sense of responsibility and agency among our students. We believe in the continuous development of leadership skills. Our Student Leadership Group is specifically designed to nurture this growth. Through collaboration and proactive initiatives, students enhance their teamwork abilities and contribute meaningfully to our school community.</p>
                                                            <a href="https://ps.esf.edu.hk/en/outstanding_people/student_voice/">
                                    <span>Find out more</span>
                                </a>
                                                    </div>
                    </div>
                                    <div class="record-item">
                        <img src="/cache/img/73a2673d2075ff2ed4a7b9ff33c9fccd.jpg" alt="IMG_1199" loading="lazy" width="1070" height="802" />                        <div class="overlay">
                            <div class="bg-colour2"></div>
                            <h3>
                                <span>OUTDOOR LEARNING</span>
                            </h3>
                            <p>Peak School students engage in adventure camps, field trips, and cultural excursions. These learning experiences outside the classroom expand their horizons, sharpen their collaborative skills, and deepen their understanding of the world around them. These memorable moments are a significant part of their Peak School journey.</p>
                                                            <a href="https://ps.esf.edu.hk/en/outstanding_experiences/outdoor_learning">
                                    <span>Find out more</span>
                                </a>
                                                    </div>
                    </div>
                                    <div class="record-item">
                        <img src="/cache/img/997090815364ed5a9a0da4c565648c0a.jpg" alt="DSC02563" loading="lazy" width="1070" height="802" />                        <div class="overlay">
                            <div class="bg-colour2"></div>
                            <h3>
                                <span>COMMUNITY EVENTS</span>
                            </h3>
                            <p>We take pride in our strong bond as a community. Our community events are the heartbeats of our shared experiences, creating unforgettable memories and nurturing a sense of unity.  Our students, staff, and PTA take turns organising various events for the community.</p>
                                                            <a href="https://ps.esf.edu.hk/en/outstanding_experiences/action_student_leadership/">
                                    <span>Find out more</span>
                                </a>
                                                    </div>
                    </div>
                                    <div class="record-item">
                        <img src="/cache/img/8e910c709e4b1a7eeec779955375b850.jpg" alt="IMG_8676 (1)" loading="lazy" width="1070" height="802" />                        <div class="overlay">
