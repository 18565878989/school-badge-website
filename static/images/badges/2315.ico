                                    </div>
                            <div class="tab-content" data-id="2">
                                            <div class="record-slider">
                            <div class="slider-container">
                                                                    <div class="record-item">
                                        <div class="left">
                                            <div class="thumbnail bg-colour1">
                                                <span></span>
                                                <img src="/cache/img/57ce0244a6ee0ac001382c7cfc41df6f.jpg" alt="unnamed-2" loading="lazy" width="548" height="548" />                                            </div>
