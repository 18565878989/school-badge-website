    <script type="text/javascript">
if (document.fullscreenEnabled) {
    const fullscreen_button = document.createElement("button");
    fullscreen_button.setAttribute('id','fullscreen-button');
    fullscreen_button.addEventListener("click", toggle_fullscreen);
    fullscreen_button.addEventListener("click", topFunction);
    fullscreen_button.addEventListener("keydown", escapeFunction);  
    fullscreen_button.innerHTML  = `
        <svg viewBox="0 0 24 24">
            <path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 
            7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/>
        </svg>
        <svg viewBox="0 0 24 24">
            <path d="M5 16h3v3h2v-5H5v2zm3-8H5v2h5V5H8v3zm6 
            11h2v-3h3v-2h-5v5zm2-11V5h-2v5h5V8h-3z"/>
        </svg>
    `;
    document.body.appendChild(fullscreen_button);
}

   function toggle_fullscreen() {

	    	if (!document.fullscreenElement) {

		        document.documentElement.requestFullscreen();
		        document.documentElement.setAttribute("fullscreen",""); 

		    } else {

		        document.exitFullscreen();
		        document.documentElement.removeAttribute("fullscreen"); 
    
		}

   }
function topFunction() {
  if (!document.fullscreenElement) {
      document.body.scrollTop = 189; // For Safari
  document.documentElement.scrollTop = 189; // For Chrome, Firefox, IE and Opera
  
    
    $('html, body').css({
    overflow: 'hidden',
});
    
   
  } else if (document.exitFullscreen) {
      document.body.scrollTop = 0; // For Safari
      document.documentElement.scrollTop = 0; // For Chrome, Firefox, IE and Opera
    
        $('html, body').css({
    overflow: 'initial',
         });
    } 
  } 


function escapeFunction() {

	    	 document.onkeydown = function(keyPressEvent) {
  if (keyPressEvent && keyPressEvent.key && (keyPressEvent.key === "Escape" || keyPressEvent.key === "Esc") && keyPressEvent.keyCode === 27) {
		         document.exitFullscreen();
                 document.webkitExitFullscreen();
		         document.documentElement.removeAttribute("fullscreen"); 
                 document.body.scrollTop = 0; // For Safari
                 document.documentElement.scrollTop = 0; // For Chrome, Firefox, IE and Opera
   
        $('html, body').css({
    overflow: 'initial',
         });
		       
    
		}

   }

}


</script>
