<script type="text/javascript">
    $(document).ready(function() {
        disableScroll();

        $('.close', '#home-popup').click(function() {
            var video = document.querySelector('#banner .slider.current video');
            if(video) {
                video.play();
                $('#banner .slider.current button').removeClass('play').addClass('pause');
            }
            else {
                timeout = setTimeout(function() {
                    $('#banner').Slider('next');
                }, 5000);
            }
        });
    });
</script>
