	<section id="content">		
		<script type="text/javascript">
    var timeout = [];

    $(window).load(function() {
		let animate = function() {
			let height = $(window).scrollTop() + Math.round($(window).height() * 0.6);
			$('#content > section').each(function() {
				if(!$(this).hasClass('animate') && height > $(this).offset().top)
				{
					$(this).addClass('animate');
                    if($(this).attr('id') == 'section2') {
						$('li > div', '#section2').each(function(index) {
							let item = $(this);
							setTimeout(function() {
								item.addClass('animate');
							}, index * 200);
						});
					}
				}
			});
		};
		$(window).on('scroll', animate);
		animate();
	});
</script>
<div id="banner">
    <div class="banner-container">
                                                <div class="banner-item">
                    <div class="wrapper">
                        <img src="/cache/img/b89e634786953e37222bc3a7de66d7bf.png" alt="" loading="lazy" width="1904" height="1200" class="trans" />                        <video id="video" width="1904" height="1200" preload="none" playsinline webkit-playsinline muted loop>
                            <source src="/upload/banner/1/banner/675927f1722ab.mp4" type="video/mp4">
                        </video>
                        <div class="mask"></div>
                        <div class="container">
                            <button class="play"></button>
                        </div>
                    </div>
                                    </div>
                        </div>
    <div class="container">
                <div class="scroll-icon"></div>
    </div>
    <script type="text/javascript">
        $(document).ready(function() {
            let pager_click = false;

            $('#banner').Slider({
                slides: '.banner-item',
                maxSlide: 1,
                swipeControl: true,
                skipBoundary: true,
                infiniteLoop: true,
                pager: '.banner-pager',
                afterSlide: function(slider, slides, current_page, total_page) {
                    $.each(timeout, function(index, value) {
                        clearTimeout(value);
                    });
                    let videos = $('video', slider);
                    videos.each(function(i, video) {
                        video.pause();
                        video.currentTime = 0;
                    });
                    $('button', slider).removeClass('play').addClass('pause');
                    if($('.slider.current video', slider).length) {
                                                        video = document.querySelector('#banner .slider.current video');
                                video.play();
                                            }
                    else if(!pager_click) {
                        timeout = setTimeout(function() {
                            slider.Slider('next');
                        }, 5000);
                    }
                },
                afterResize: function(slider, slides, current_page, total_page) {
                    if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                },
                afterInit: function(slider, slides, current_page, total_page) {
                                        if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                }
            });
            
            $('.banner-item video', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                let button = $(this).parent().find('button');
                if(button.hasClass('pause')) {
                    video.pause();
                    button.removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    button.removeClass('play').addClass('pause');
                }
            });
            $('.banner-item button', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                if($(this).hasClass('pause')) {
                    video.pause();
                    $(this).removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    $(this).removeClass('play').addClass('pause');
                }
            });

            $('body').on('click', '#banner .banner-pager a', function() {
                pager_click = true;
            });

            function videoEnd(e) {
                if(!pager_click) {
                    $('#banner').Slider('next');
                }
                else {
                    $('#banner .slider.current button').removeClass('pause').addClass('play');
                }
            }
        });
    </script>
</div>
<section id="section1">
    <div class="container">
                    <div class="left">
                <article class="editor"><h3 class="homepage-title title"><strong>&lsquo;Be your own remarkable&hellip;&rsquo;</strong></h3></article>
            </div>
                            <div class="right">
                <article class="editor"><p><span style="font-weight: 400;">We create a school for one, a place where each and every person engages in remarkable learning to achieve at high levels and be the best they can be.</span></p>
<p>&nbsp;</p>
<p class="rounded_title bg-colour1"><a href="https://kgv.esf.edu.hk/en/about_us/vision_and_mission/"><span style="color: #ffffff;">Discover Our Vision</span></a></p></article>
            </div>
                            <div class="responsive">
                <article class="editor"><h3 class="homepage-title title"><span style="font-size: 40px;"><strong>&lsquo;Be your own remarkable&hellip;&rsquo;</strong></span></h3>
<p>&nbsp;</p>
<p><span style="font-weight: 400;">We create a school for one, a place where each and every person engages in remarkable learning to achieve at high levels and be the best they can be.</span></p>
<p>&nbsp;</p>
<p class="rounded_title bg-colour1"><a href="https://kgv.esf.edu.hk/en/about_us/vision_and_mission/"><span style="color: #ffffff;">Discover Our Vision</span></a></p></article>
            </div>
            </div>
</section>
<section id="section2">
    <div class="container">
        <div class="section-title">
            <h2 class="colour2">What can KGV offer your Family?</h2>
            <span class="bg-colour1"></span>
        </div>
    </div>
    <div class="wrapper bg-colour2">
        <div class="container">
            <ul>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/ced202062561df0eff54f602413acf6e.png" alt="Comprehensive Student Support" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Personalised Learning Experience</h3>
                            <div class="overlay bg-colour1">
                                <p>Our "school for one" cultivates each student's sense of belonging, identity and purpose. Our personalised approach empowers holistic development and high achievement, as our graduates excel at top universities.</p>
                                                                    <a  href="https://kgv.esf.edu.hk/en/outstanding_education/curriculum/curriculum_overview">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/0646eb23056df08fb0548e0ea93d01d7.png" alt="Multicultural Environment" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Inclusive and Diverse Community</h3>
                            <div class="overlay bg-colour1">
                                <p>We foster a culture that celebrates diversity, where unique ideas, beliefs, and values are cherished, respected, and heard. Our inclusive environment empowers collaboration, innovation, and growth in a vibrant learning community.</p>
                                                                    <a  href="https://kgv.esf.edu.hk/en/outstanding_education/student_support_wellbeing/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/872d4b84066515b085ab069b865703cf.png" alt="Strong School-Family Connection" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Strong Family-School Partnership</h3>
                            <div class="overlay bg-colour1">
                                <p>We prioritise strong school-family relationships, actively engaging parents through feedback sessions and community events that celebrate student achievements. This supportive partnership enhances the educational experience for all.</p>
                                                                    <a  href="https://kgv.esf.edu.hk/en/outstanding_experiences/experiential_learning/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/59e1ba443fb4bfa5b34b81373c9ba456.png" alt="Strong Community Network" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Rich Historical Legacy</h3>
                            <div class="overlay bg-colour1">
                                <p>Our century-old legacy connects generations, empowering students with the wisdom, experiences and connections of our thriving alumni network. This rich heritage instils a profound sense of community and pride.</p>
                                                                    <a  href="https://kgv.esf.edu.hk/en/outstanding_people/parent-teacher-student_association/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/7fbaf20d4fe5a5c01c950dd4ad1c78bc.png" alt="Well-equipped Facilities" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Extensive Sports Facilities</h3>
                            <div class="overlay bg-colour1">
                                <p>Our extensive sports facilities cater to diverse athletic interests, empowering students to excel. This commitment to health and wellness enriches our educational experience.</p>
                                                                    <a  href="https://kgv.esf.edu.hk/en/outstanding_education/student_success/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/8ef2fecb211e0a421058bc069c91753f.png" alt="SIS offers icon-6" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">ESF Network</h3>
                            <div class="overlay bg-colour1">
                                <p>As part of the English Schools Foundation(ESF), our students are supported by the largest English-medium international school organisation in Hong Kong, providing them the resources and opportunities not found outside of ESF Schools.</p>
                                                                    <a  href="https://kgv.esf.edu.hk/en/about_us/ESF_family/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                            </ul>
        </div>
    </div>
    <script type="text/javascript">
        $(window).load(function() {
            $('h3', '#section2').each(function() {
                let img = $(this).parent().children('img');
                if(img.length) {
                    $(this).css('top', img.offset().top + img.height() + 25 - $(this).parent().offset().top);
                }
            });
        });
    </script>
</section>
<section id="section3">
    <img src="/cache/img/915c90c83b7b14d707f94ef351eea635.jpg" alt="kgv_1772 (1)" loading="lazy" width="1722" height="1294" />    <div class="wrapper">
        <div class="section-title-container">
            <div class="section-title">
                <h2 class="colour2">International Curriculum</h2>
                <span class="bg-colour1"></span>
            </div>
        </div>
        <div class="tabs">
                            <button class="tab current" data-id="1">Years 7-9</button>
                            <button class="tab" data-id="2">Years 10-11</button>
                            <button class="tab" data-id="3">Years 12-13</button>
                    </div>
        <select class="tab-select" name="tab"><option value="1">Years 7-9</option><option value="2">Years 10-11</option><option value="3">Years 12-13</option></select>                    <div class="tab-content current" data-id="1">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Years 7-9 Curriculum</h3>
                    </div>
                                <article class="editor"><p><span style="font-weight: 400;">Students study the International Baccalaureate Middle Years Programme (MYP) for three years. The MYP builds upon the knowledge, skills and attitudes developed in the IB Primary Years Programme (PYP) and prepares students to meet future academic challenges, including IGCSE, BTEC and the IB Diploma Programme (DP).</span></p></article>
                                    <a href="https://kgv.esf.edu.hk/en/outstanding_education/academic_curriculum/curriculum_overview/years-7-9/">
                        <span>Learn More</span>
                    </a>
                            </div>
                    <div class="tab-content" data-id="2">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Years 10-11 Curriculum</h3>
                    </div>
                                <article class="editor"><p><span style="font-weight: 400;">Years 10 &amp; 11 follow the British GCSE, IGCSE or BTEC curricula and lead to examinations and qualifications in each subject. Typically each course spans two years, in Years 10 and 11, with final exams and coursework presented in May or June of Year 11.</span></p></article>
                                    <a href="https://kgv.esf.edu.hk/en/outstanding_education/academic_curriculum/curriculum_overview/years-10-11/">
                        <span>Learn More</span>
                    </a>
                            </div>
                    <div class="tab-content" data-id="3">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Years 12-13 Curriculum</h3>
                    </div>
                                <article class="editor"><p><span style="font-weight: 400;">Students choose to either study a broad-based International Baccalaureate Diploma Programme (IBDP) or to focus their studies and follow a specialised vocational pathway which centres around one or more BTEC qualifications. IBDP and BTEC classes are capped at 16. These small classes enable students to grow as learners in a supportive and nurturing learning environment.</span></p></article>
                                    <a href="https://kgv.esf.edu.hk/en/outstanding_education/academic_curriculum/curriculum_overview/years-12-13/">
                        <span>Learn More</span>
                    </a>
                            </div>
                <script type="text/javascript">
            $(document).ready(function() {
                $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();

                $('.tab', '#section3').click(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $(this).addClass('current');
                    $('.tab-content[data-id=' + $(this).data('id') + ']', '#section3').addClass('current');
                    $('select', '#section3').val($(this).data('id')).selectbox('refresh');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });

                $('.tab-select', '#section3').change(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $('.tab[data-id=' + $(this).val() + ']').addClass('current');
                    $('.tab-content[data-id=' + $(this).val() + ']', '#section3').addClass('current');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });
            });
        </script>
    </div>
</section>
<section id="section4" data-total="3">
