        		</div>
    	        	<script>
    		if(document.readyState != 'loading') {
    			languageRun();
    		} else if (document.addEventListener) {
    			document.addEventListener('DOMContentLoaded', languageRun);
    		} else {
    			document.attachEvent('onreadystatechange', function () {
    				if(document.readState == 'complete') {
    					languageRun();
    				}
    			})
    		}
    
    		function languageRun() {
    			let langButtons = document.querySelectorAll('#languageBarSelection button');
    			let langBarCloseButtons = document.querySelectorAll('.closeLanguageBar');
    			let langBars = document.querySelectorAll('.languageBarDescription');
    			langButtons.forEach(button => {
    				button.addEventListener('click', event => {
    					hideAllLanguareBars(langBars);
    					let buttonLang = button.getAttribute('data-lang');
    					let langBar = document.querySelector('.languageBarDescription[data-lang="' + buttonLang + '"]');
    					if(langBar.classList.contains('hidden')) {
    						langBar.classList.add('show');
    						langBar.classList.remove('hidden');
    					}
    				});
    			});
    
    			langBarCloseButtons.forEach(closeButton => {
    				closeButton.addEventListener('click', event => {
    					hideAllLanguareBars(langBars);
    				});
    			});
    		}
    
    		/**
    		* Hide Languare Bars
    		*/
    		function hideAllLanguareBars(bars) {
    			bars.forEach(bar => {
    				if(bar.classList.contains('show')) {
    					bar.classList.add('hidden');
    					bar.classList.remove('show');
    				}
    			});
    		}
    	</script>
