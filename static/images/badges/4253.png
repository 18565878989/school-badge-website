<div class="post-thumbnail-wrap">
<div class="post-thumbnail">
<a class="post-thumbnail-rollover layzr-bg img-css-resize-wrapper" aria-label="Post image" href="https://www.hktlc.edu.hk/news-zh/19832/"><img decoding="async" width="1200" height="900" src="https://media.hktlc.edu.hk/wp-content/uploads/2024/11/26071156/ddnedu2024.png" class="attachment-full size-full preload-me aspect lazy lazy-load" alt="" sizes="(max-width: 1200px) 100vw, 1200px" style="--ratio: 1200 / 900;" data-src="https://media.hktlc.edu.hk/wp-content/uploads/2024/11/26071156/ddnedu2024.png" loading="eager" data-srcset="https://media.hktlc.edu.hk/wp-content/uploads/2024/11/26071156/ddnedu2024.png 1200w, https://media.hktlc.edu.hk/wp-content/uploads/2024/11/26071156/ddnedu2024-300x225.png 300w, https://media.hktlc.edu.hk/wp-content/uploads/2024/11/26071156/ddnedu2024-1024x768.png 1024w, https://media.hktlc.edu.hk/wp-content/uploads/2024/11/26071156/ddnedu2024-768x576.png 768w" /></a>
