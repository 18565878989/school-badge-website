}</style><script>/* Page fully loaded, including all images and scripts */
window.onload = function() {
/* For Auto Expand Toggle */
var customToggleDiv = document.getElementsByClassName('custom-expand-toggle');
if (customToggleDiv.length > 0) {
var toggles = customToggleDiv[0].getElementsByClassName('elementor-tab-title');
for (var i = 0; i < toggles.length; i++) {
toggles[i].click();  
}
} 
/* For First Layer Items of Main Menu In Mobile */
const hamburgerMenu = document.querySelector('.horizontal-menu-dropdown');
if (hamburgerMenu) {
hamburgerMenu.addEventListener('click', () => {
setTimeout(() => {
const mobileNavItems = document.querySelectorAll('.custom-mobile-menu li a[data-level="1"]');
mobileNavItems.forEach(navItem => {
navItem.addEventListener('click', event => {
event.preventDefault(); // Prevent navigation
});
navItem.classList.add('non-clickable');
});
}, 100);
});
}
};
/* The initial HTML document has been completely loaded without waiting for stylesheets & images */
document.addEventListener('DOMContentLoaded', function() {
/* For Search function in English ver */
const forms = document.querySelectorAll('.custom-search-bar .the7-search-form');
for (var i = 0; i < forms.length; i++) {
forms[i].action = forms[i].action + 'en/';
}
/* For Search result page in Chinese ver */
const searchResultTitle = document.querySelector('.custom-search-result-title-zh .the7-heading-title');
if (searchResultTitle) {
const currentText = searchResultTitle.textContent;
const searchTerm = currentText.split(': ')[1];
searchResultTitle.textContent = `「${searchTerm}」的搜尋結果：`;
}
const resultContent = document.querySelector('.custom-search-result-content-zh p');
if (resultContent && resultContent.textContent === 'Nothing found') {
resultContent.textContent = '找不到搜尋結果';
}
/* For Breadcrumb in Chinese ver */
const breadcrumbHomeLink = document.querySelector('.custom-breadcrumb-zh ol li a[title="Home"]');
if (breadcrumbHomeLink) {
breadcrumbHomeLink.href = breadcrumbHomeLink.href + 'zh/';
const breadcrumbHomeTitle = breadcrumbHomeLink.querySelector('span');
breadcrumbHomeTitle.textContent = '主頁';
}
/* For Download Button in Chinese ver */
if (document.documentElement.lang === 'zh-HK') {
const downloadBtns = document.querySelectorAll('.button-table a');
for (var i = 0; i < downloadBtns.length; i++) {
if (downloadBtns[i].textContent === 'VIEW PDF') {
downloadBtns[i].textContent = '查看PDF';
}
else if (downloadBtns[i].textContent === 'VIEW MEDIA') {
downloadBtns[i].textContent = '查看媒體';
}
}
}
/* For First Layer Items of Main Menu */
const topLevelNavItems = document.querySelectorAll('.custom-main-menu li a[data-level="1"]');
topLevelNavItems.forEach(navItem => {
navItem.addEventListener('click', event => {
event.preventDefault(); // Prevent navigation
});
navItem.classList.add('non-clickable');
});
/* For open new tab for Post Carousel on Home Page */
document.querySelectorAll('.home-school-news article.post a').forEach(link => {
link.setAttribute('target', '_blank');
link.setAttribute('rel', 'noopener noreferrer');
});
document.querySelectorAll('.home-achievements article.post a').forEach(link => {
link.setAttribute('target', '_blank');
link.setAttribute('rel', 'noopener noreferrer');
});
});</script><style class="wpcode-css-snippet">/* Header */
.current-lang .menu-text {
color: #14468C;
}
.horizontal-sub-nav.bottom-overflow {
max-height: 75vh;
overflow-y: scroll;
}
.custom-header-menu {
z-index: 999;
}
/* Video Banner */
.video-banner video {
height: inherit !important;
}
/* Custom Image Carousel (e.g. Facilities in homepage) */
.custom-image-carousel figure {
line-height: normal !important;
}
.custom-image-carousel figcaption {
position: relative;
padding: 5px 20px;
background-color: #FBFBFB;
}
.custom-image-carousel figure:hover img {
opacity: 1;
-webkit-animation: flash 1.5s;
animation: flash 1.5s;
}
.elementor-widget-image-carousel .swiper-slide img { 
aspect-ratio: 4 / 3; 
width: 100%; 
object-fit: cover; 
object-position: center center; 
}
@-webkit-keyframes flash {
0% {
opacity: .6;
}
100% {
opacity: 1;
}
}
@keyframes flash {
0% {
opacity: .6;
}
100% {
opacity: 1;
}
}
/* Copyright section */
.custom-copyright a {
text-decoration: none;
color: rgba(255, 255, 255, 0.5);
}
/* Custom Table */
.custom-table-container {
overflow: auto;
padding: 5px;
}
.custom-table {
box-shadow: 1px 4px 4px 0 rgba(0,0,0,0.1);
margin-bottom: 20px !important;
table-layout: fixed;
}
.custom-table thead th, .first-col-header-table tbody tr .column-1 {
background-color: #14468C;
color: #FFFFFF;
font-weight: 600;
padding: 15px;
width: 30%;
}
.custom-table tbody td {
padding: 10px 15px 10px 15px;
}
.custom-table tbody .odd>* {
background-color: #F7F7F7;
}
.custom-table caption {
display: none;
}
table.custom-table:not(.first-col-header-table) tbody tr:hover>* {
background-color: #EFF4FD !important;
color: #14468C !important;
}
table.first-col-header-table tbody tr td:not(.column-1):hover {
background-color: #EFF4FD !important;
color: #14468C !important;
}
table.width-80-table {
width: 80% !important;
margin: 0px auto 10px !important;
}
table.button-table thead tr th {
text-align: center;
}
table.button-table tbody tr td {
text-align: center;
align-content: center;
}
table.button-table .elementor-button {
text-decoration: none;
}
table.no-alter-table tbody .odd>* {
background-color: #FFFFFF;
}
table.first-col-width-20-table thead tr th:first-child,
table.first-col-width-20-table tbody tr td:first-child {
width: 20%;
}
/* Custom Heading */
div.custom-heading:not(:first-of-type) {
margin-top: 50px;
}
/* List Item */
.elementor-widget-container ul li {
margin: 10px 0px;
}
/* Subject Page */
.hidden {
display: none;
}
.btn-selected {
background-color: var(--the7-btn-hover-bg, #666666) !important;
}
.elementor-button {
cursor: pointer;
background-color: #14468C;
}
.elementor-button:hover {
background-color: #2565BD;
}
.the7-e-sticky-row-yes:has(#curriculum-features-btn) {
z-index: 10;
}
/* General */
.elementor-widget-theme-post-content {
padding-bottom: 20px;
}
.non-clickable {
cursor: default;
}
/* Timeline */
.twae-title {
display: none !important;
}
/* Music Player */
.ai-wrap .ai-track:hover, 
.ai-wrap .ai-audio-control:hover, .ai-wrap .ai-audio-control:focus, .ai-wrap .ai-track.ai-track-active,
.ai-wrap .ai-audio-control, .ai-wrap .ai-volume-bar.ai-volume-bar-active::before, 
.ai-wrap .ai-track-progress, .ai-wrap .ai-btn.ai-btn-active, 
.ai-wrap .ai-scroll-wrap>div:last-child div {
background-color: #2565bd !important;
}
.ai-type-simple {
border-radius: 15px;
}
/* Custom iframe */
.custom-iframe iframe {
max-width: 768px;
}
/* Page */
div[data-elementor-type="single-page"] {
padding-bottom: 30px;
}
/* Post Excerpt (Inner Archive page) */
.elementor-post__excerpt, .elementor-widget-theme-post-excerpt, 
/* Post Excerpt (Homepage - School News, Achievements) */
.post-entry-content .entry-excerpt,
.search-result-excerpt { 
overflow: hidden; 
width:100%; 
display: -webkit-box; 
-webkit-line-clamp: 3; 
-webkit-box-orient: vertical; 
}
/* Testimonial */
.elementor-testimonial-wrapper {
overflow-wrap: anywhere;
}
/* Post Grid Loop */
.custom-post-grid-loop .sGrid-container .post .e-con-boxed {
height: 100%;
}
.elementor-widget-post-info li {
list-style: none;
}
/* Sitemap */
ul.wpvs_wrapper .wpvs_column_3 {
margin: 20px;
}
/* Mobile Device */
@media only screen and (max-width: 767px) {
/* Table */
table.width-80-table {
width: 100% !important;
}
/* Subheading */
.custom-subheading .the7-heading-title {
font-size: 20px !important;
}
/* Sitemap */
ul.wpvs_wrapper .wpvs_column_3 {
margin: 10px 0px;
}
}</style><link rel="icon" href="https://media.hktlc.edu.hk/wp-content/uploads/2024/08/19060501/favicon.svg" sizes="32x32" />
