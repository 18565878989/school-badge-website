		.table-td td {
			padding-left: 5px;
			line-height: 20px;
		}

		.text-5 {
			text-decoration: none;
			border-bottom: 1px solid;
			padding-bottom: 0px;

		}

		a:link {
			text-decoration: none;
		}

		a:visited {
			text-decoration: none;
		}

		a:hover {
			text-decoration: none;
		}

		a:active {
			text-decoration: none;
		}

		/*modal img size */
		.modal-body img {
			width: 100%;
		}

		.mySlides {
			display: none;
		}

		.button {
			background-color: #4CAF50;
			border: none;
			color: white;
			padding: 5px 10px;
			text-align: center;
			text-decoration: none;
			display: inline-block;
			font-size: 16px;
		}

		a:hover {
			color: green;
			background-color: transparent;
		}

		@media only screen and (max-width: 575px) {
			#tb01 {
				width: 100%;
			}
		}

		.carousel-container {
			width: 100%;
			overflow: hidden;
			position: relative;
			margin: 20px 0;
		}

		.carousel-track {
			display: flex;
			animation: scroll 60s linear infinite;
			width: calc(200px * 5);
		}

		.carousel-item2 {

			width: 150px;
			height: 100px;
			margin: 0 10px;
			flex-shrink: 0;
		}

		.carousel-item2 img {

			width: 62%;
			height: 90%;
			object-fit: cover;
			border-radius: 5px;

		}

		@keyframes scroll {
			0% {
				transform: translateX(0);
			}

			100% {
				transform: translateX(-50%);
			}
		}

		.carousel-container:hover .carousel-track {
			animation-play-state: paused;
		}

	</style>
	<style>
		.marquee-wrapper {
			position: relative;
			max-width: 850px;
			width: 100%;
			overflow: hidden;


		}

		.marquee-container {
			display: flex;
			width: 100%;
			height: 150px;
			overflow: hidden;
			position: relative;
		}

		.marquee-group {
			display: flex;
			animation: marquee-scroll 60s linear infinite;
		}

		.marquee-wrapper:hover .marquee-group {
			animation-play-state: paused;
		}

		.marquee-item {
			width: auto;
			height: 100%;
			position: relative;
			overflow: hidden;
			margin: 0 0px;
			transition: all .5s ease .1s;
		}

		.marquee-item:hover {
			transform: scale(1.05);
			z-index: 10;
			box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
		}

		.marquee-item img {
			width: auto;
			height: 100%;
			object-fit: cover;
			display: block;
		}

		@keyframes marquee-scroll {
			0% {
				transform: translateX(0);
			}

			100% {
				transform: translateX(-100%);
			}
		}

		@media (max-width: 576px) {

			.marquee-container {
				display: flex;
				width: 100%;
				height: 80px;
				overflow: hidden;
				position: relative;
			}

			.marquee-item {
				width: auto;
				margin: 0 0px;
			}

			.marquee-item img {
				height: 80px;
			}
		}


		.photoalign {

			text-align: center;

		}

		.divcenter {
			display: flex;
			justify-content: center;
			align-items: center;
		}

	</style>
