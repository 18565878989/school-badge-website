	<section id="content">		
		<script type="text/javascript">
    var timeout = [];

    $(window).load(function() {
		let animate = function() {
			let height = $(window).scrollTop() + Math.round($(window).height() * 0.6);
			$('#content > section').each(function() {
				if(!$(this).hasClass('animate') && height > $(this).offset().top)
				{
					$(this).addClass('animate');
                    if($(this).attr('id') == 'section2') {
						$('li > div', '#section2').each(function(index) {
							let item = $(this);
							setTimeout(function() {
								item.addClass('animate');
							}, index * 200);
						});
					}
				}
			});
		};
		$(window).on('scroll', animate);
		animate();
	});
</script>
<div id="banner">
    <div class="banner-container">
                                                <div class="banner-item">
                    <div class="wrapper">
                        <img src="/cache/img/80479205c1b93628ddb384c8f55c6bcc.png" alt="" loading="lazy" width="1904" height="1200" class="trans" />                        <video id="video" width="1904" height="1200" preload="none" playsinline webkit-playsinline muted loop>
                            <source src="/upload/banner/1/banner/671fb8765525a.mp4" type="video/mp4">
                        </video>
                        <div class="mask"></div>
                        <div class="container">
                            <button class="play"></button>
                        </div>
                    </div>
                                    </div>
                        </div>
    <div class="container">
                <div class="scroll-icon"></div>
    </div>
    <script type="text/javascript">
        $(document).ready(function() {
            let pager_click = false;

            $('#banner').Slider({
                slides: '.banner-item',
                maxSlide: 1,
                swipeControl: true,
                skipBoundary: true,
                infiniteLoop: true,
                pager: '.banner-pager',
                afterSlide: function(slider, slides, current_page, total_page) {
                    $.each(timeout, function(index, value) {
                        clearTimeout(value);
                    });
                    let videos = $('video', slider);
                    videos.each(function(i, video) {
                        video.pause();
                        video.currentTime = 0;
                    });
                    $('button', slider).removeClass('play').addClass('pause');
                    if($('.slider.current video', slider).length) {
                                                        video = document.querySelector('#banner .slider.current video');
                                video.play();
                                            }
                    else if(!pager_click) {
                        timeout = setTimeout(function() {
                            slider.Slider('next');
                        }, 5000);
                    }
                },
                afterResize: function(slider, slides, current_page, total_page) {
                    if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                },
                afterInit: function(slider, slides, current_page, total_page) {
                                            let videos = $('video', slider);
                        videos.each(function(i, video) {
                            video.addEventListener('ended', videoEnd, false);
                        });
                        if($('.slider.current video', slider).length) {
                                                                video = document.querySelector('#banner .slider.current video');
                                    video.play();
                                    $('.slider.current button', slider).removeClass('play').addClass('pause');
                                                    }
                        else {
                            timeout = setTimeout(function() {
                                slider.Slider('next');
                            }, 5000);
                        }
                                        if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                }
            });
            
            $('.banner-item video', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                let button = $(this).parent().find('button');
                if(button.hasClass('pause')) {
                    video.pause();
                    button.removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    button.removeClass('play').addClass('pause');
                }
            });
            $('.banner-item button', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                if($(this).hasClass('pause')) {
                    video.pause();
                    $(this).removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    $(this).removeClass('play').addClass('pause');
                }
            });

            $('body').on('click', '#banner .banner-pager a', function() {
                pager_click = true;
            });

            function videoEnd(e) {
                if(!pager_click) {
                    $('#banner').Slider('next');
                }
                else {
                    $('#banner .slider.current button').removeClass('pause').addClass('play');
                }
            }
        });
    </script>
</div>
<section id="section1">
    <div class="container">
                    <div class="left">
                <article class="editor"><h3 class="homepage-title title"><span style="color: #000000;">Making a Difference</span></h3></article>
            </div>
                            <div class="right">
                <article class="editor"><p><span style="font-weight: 400;">Our purpose at South Island School is to make a difference in the world and to empower our students to live this out. We educate our students socially, emotionally, and academically to help them make informed decisions and take action responsibly.</span></p>
<p><span style="font-weight: 400;">&nbsp;</span></p>
<p><span style="font-weight: 400;">We offer our students the opportunities and guidance to become honest, responsible and courageous global citizens.</span></p>
<p>&nbsp;</p>
<p class="rounded_title bg-colour1"><a href="https://sis.esf.edu.hk/en/about_us/vision_and_mission/" target="_blank" rel="noopener"><span style="color: #ffffff;">Discover Our Vision</span></a></p></article>
            </div>
                            <div class="responsive">
                <article class="editor"><h3 class="homepage-title-r"><span style="font-size: 40px; color: #000000;">Making a Difference</span></h3>
<p>&nbsp;</p>
<p><span style="font-weight: 400;">Our purpose at South Island School is to make a difference in the world and to empower our students to live this out. We educate our students socially, emotionally, and academically to help them make informed decisions and take action responsibly.</span></p>
<p><span style="font-weight: 400;">&nbsp;</span></p>
<p><span style="font-weight: 400;">We offer our students the opportunities and guidance to become honest, responsible and courageous global citizens.</span></p>
<p>&nbsp;</p>
<p class="rounded_title bg-colour1"><a href="https://sis.esf.edu.hk/en/about_us/vision_and_mission/"><span style="color: #ffffff;">Discover Our Vision</span></a></p></article>
            </div>
            </div>
</section>
<section id="section2">
    <div class="container">
        <div class="section-title">
            <h2 class="colour2">What can SIS offer your family?</h2>
            <span class="bg-colour1"></span>
        </div>
    </div>
    <div class="wrapper bg-colour2">
        <div class="container">
            <ul>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/6d95d86c93b2f5e892093d55a3354560.png" alt="World-class Education" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">World Class Education</h3>
                            <div class="overlay bg-colour1">
                                <p>Our world class curriculum gives our students the academic foundation they need to succeed anywhere in the world.</p>
                                                                    <a  href="https://sis.esf.edu.hk/en/outstanding_education/curriculum/curriculum_overview">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/8f52b51c315961d12c12e31dd88627bf.png" alt="SIS offers icon-2" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Student Support</h3>
                            <div class="overlay bg-colour1">
                                <p>Our Pastoral Curriculum supports students with a team of teachers, addressing their emotional and social needs while providing safe spaces for transitioning to adulthood.</p>
                                                                    <a  href="https://sis.esf.edu.hk/en/outstanding_education/student_support_wellbeing/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/6457f57ca171db77b57bce3452287a10.png" alt="Real-world Experience" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Real World Experience</h3>
                            <div class="overlay bg-colour1">
                                <p>Our Values in Action Curriculum offers diverse out-of-class activities for students to apply classroom learning in real-world contexts, fostering leadership, community engagement, and personal growth.</p>
                                                                    <a  href="https://sis.esf.edu.hk/en/outstanding_experiences/experiential_learning/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/9383d041f5d7b3260aed0b8475317c74.png" alt="Strong School-Family Connection" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Strong School-Family Connection</h3>
                            <div class="overlay bg-colour1">
                                <p>When families join South Island School, there are many activities to connect with our teachers to stay involved in your child’s learning and various opportunities to give back and make a difference in our school.</p>
                                                                    <a  href="https://sis.esf.edu.hk/en/outstanding_people/parent-teacher-student_association/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/ef07ba201a365264c3656cb8b4e9c3f6.png" alt="Incredible Results" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Incredible Results</h3>
                            <div class="overlay bg-colour1">
                                <p>With a 98% IBDP pass rate and 35% of our 130 IBDP students achieving 40+ points, South Island School provides a healthy space for our students to excel and succeed, leading to great opportunities across the globe.</p>
                                                                    <a  href="https://sis.esf.edu.hk/en/outstanding_education/student_success/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/67427c31ceab1c4a82090d84887b61ab.png" alt="SIS offers icon-6" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">ESF Network</h3>
                            <div class="overlay bg-colour1">
                                <p>As part of the English Schools Foundation(ESF), our students are supported by the largest English-medium international school organisation in Hong Kong, providing them the resources and opportunities not found outside of ESF Schools.</p>
                                                                    <a  href="https://sis.esf.edu.hk/en/about_us/ESF_family/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                            </ul>
        </div>
    </div>
    <script type="text/javascript">
        $(window).load(function() {
            $('h3', '#section2').each(function() {
                let img = $(this).parent().children('img');
                if(img.length) {
                    $(this).css('top', img.offset().top + img.height() + 25 - $(this).parent().offset().top);
                }
            });
        });
    </script>
</section>
<section id="section3">
    <img src="/cache/img/1f11e1c6f283c3830650352dae9c178b.jpg" alt="IMG_1149" loading="lazy" width="1722" height="1294" />    <div class="wrapper">
        <div class="section-title-container">
            <div class="section-title">
                <h2 class="colour2">International Curriculum</h2>
                <span class="bg-colour1"></span>
            </div>
        </div>
        <div class="tabs">
                            <button class="tab current" data-id="1">Years 7-9</button>
                            <button class="tab" data-id="2">Years 10-11</button>
                            <button class="tab" data-id="3">Years 12-13</button>
                    </div>
        <select class="tab-select" name="tab"><option value="1">Years 7-9</option><option value="2">Years 10-11</option><option value="3">Years 12-13</option></select>                    <div class="tab-content current" data-id="1">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Years 7-9 Curriculum</h3>
                    </div>
                                <article class="editor"><p><span style="font-weight: 400;">South Island School's Years 7 to 9 follow the</span><strong> IB Middle Years Programme (MYP)</strong><span style="font-weight: 400;">, offering a challenging and practical learning framework that supports students' transition and integration into the secondary school community, building a solid foundation of critical thinking and global mindedness for the middle and senior years.</span></p></article>
                                    <a href="https://sis.esf.edu.hk/en/outstanding_education/academic_curriculum/curriculum_overview/years-7-9/">
                        <span>Learn More</span>
                    </a>
                            </div>
                    <div class="tab-content" data-id="2">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Years 10-11 Curriculum</h3>
                    </div>
                                <article class="editor"><p><span style="font-weight: 400;">In Years 10 and 11, South Island School offers a common curriculum and elective subjects, preparing students for </span><strong>I/GCSE</strong><span style="font-weight: 400;"> exams while providing guidance for future pathways both local and abroad.</span></p></article>
                                    <a href="https://sis.esf.edu.hk/en/outstanding_education/academic_curriculum/curriculum_overview/years-10-11/">
                        <span>Learn More</span>
                    </a>
                            </div>
                    <div class="tab-content" data-id="3">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Years 12-13 Curriculum</h3>
                    </div>
                                <article class="editor"><p><span style="font-weight: 400;">In Years 12 and 13, South Island School offers three pathways, </span><strong>the IB Diploma Programme (IBDP), the IB Career-related Programme (IBCP) and the SIS Diploma</strong><span style="font-weight: 400;">, to give students agency in their studies based on their learning style and aspirations, while fostering a well-rounded and global-minded outlook through leadership and community involvement.</span></p></article>
                                    <a href="https://sis.esf.edu.hk/en/outstanding_education/academic_curriculum/curriculum_overview/years-12-13/">
                        <span>Learn More</span>
                    </a>
                            </div>
                <script type="text/javascript">
            $(document).ready(function() {
                $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();

                $('.tab', '#section3').click(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $(this).addClass('current');
                    $('.tab-content[data-id=' + $(this).data('id') + ']', '#section3').addClass('current');
                    $('select', '#section3').val($(this).data('id')).selectbox('refresh');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });

                $('.tab-select', '#section3').change(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $('.tab[data-id=' + $(this).val() + ']').addClass('current');
                    $('.tab-content[data-id=' + $(this).val() + ']', '#section3').addClass('current');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });
            });
        </script>
    </div>
</section>
<section id="section4" data-total="4">
    <div class="container">
        <div class="bg bg-colour4"></div>
        <div class="section-title-container">
            <div class="section-title">
                <h2 class="colour2">Student Support</h2>
                <span class="bg-colour1"></span>
            </div>
        </div>
        <div class="record-slider">
            <div class="slider-container">
                                    <div class="record-item">
                        <img src="/cache/img/cf8f7298a9d01647aaddab2477815e83.png" alt="身心健康" loading="lazy" width="1070" height="802" />                        <div class="overlay">
                            <div class="bg-colour2"></div>
                            <h3>
                                <span>WELL-BEING</span>
                            </h3>
                            <p>At South Island, well-being is at the heart of everything that we do. We want our school to be healthy, inclusive and supportive so that it enables our community to thrive. We promote positive mental health and well-being for our whole school community and recognise how important it is in our lives.</p>
                                                            <a href="https://sis.esf.edu.hk/en/outstanding_education/student_support_wellbeing/">
                                    <span>Learn More</span>
                                </a>
                                                    </div>
                    </div>
                                    <div class="record-item">
                        <img src="/cache/img/4c02f6375e48f7dd7948619324ca86fc.jpg" alt="family support structure" loading="lazy" width="1070" height="802" />                        <div class="overlay">
                            <div class="bg-colour2"></div>
                            <h3>
                                <span>FAMILY SUPPORT STRUCTURE</span>
                            </h3>
                            <p>The SIS Family Leadership Team provides pastoral support to help all students flourish. Each student has trusted adults, including Tutors, Heads of Year, Counsellors, and Medical Professionals, ensuring holistic support.</p>
                                                            <a href="https://sis.esf.edu.hk/en/outstanding_education/student_support_wellbeing/">
                                    <span>Learn More</span>
                                </a>
                                                    </div>
                    </div>
                                    <div class="record-item">
                        <img src="/cache/img/67e3f721c897477a35e58960608a477f.jpg" alt="tutors" loading="lazy" width="1070" height="802" />                        <div class="overlay">
                            <div class="bg-colour2"></div>
                            <h3>
                                <span>TUTORS</span>
                            </h3>
                            <p>The role of the Tutor is a crucial one as they are advocates for their students and they serve as the main adult point of contact, gathering information from other teachers about what the student needs and spearheading efforts to support them. Tutors make every effort to ensure that the relationships fostered between the student, home and school are positive.</p>
                                                            <a href="https://sis.esf.edu.hk/en/outstanding_people/our_team/">
                                    <span>Learn More</span>
                                </a>
                                                    </div>
                    </div>
                                    <div class="record-item">
                        <img src="/cache/img/539725cf382c7681f66a611c53959acc.jpg" alt="PLC" loading="lazy" width="1070" height="802" />                        <div class="overlay">
                            <div class="bg-colour2"></div>
                            <h3>
                                <span>PASTORAL LEARNING CURRICULUM (PLC)</span>
                            </h3>
                            <p>Effective pastoral care is the ‘nourishment for the learning journey’ to which all students have an entitlement. The Pastoral Learning Curriculum (PLC) is taught during Tutor Time and is aimed to explicitly teach and promote health and well-being, build resilience, enhance academic care and build human and social capital among our community.</p>
                                                            <a href="https://sis.esf.edu.hk/en/outstanding_experiences/experiential_learning/">
                                    <span>Learn More</span>
                                </a>
                                                    </div>
                    </div>
                                    <div class="record-item">
                        <img src="/cache/img/cf8f7298a9d01647aaddab2477815e83.png" alt="身心健康" loading="lazy" width="1070" height="802" />                        <div class="overlay">
                            <div class="bg-colour2"></div>
                            <h3>
                                <span>WELL-BEING</span>
                            </h3>
                            <p>At South Island, well-being is at the heart of everything that we do. We want our school to be healthy, inclusive and supportive so that it enables our community to thrive. We promote positive mental health and well-being for our whole school community and recognise how important it is in our lives.</p>
                                                            <a href="https://sis.esf.edu.hk/en/outstanding_education/student_support_wellbeing/">
                                    <span>Learn More</span>
                                </a>
                                                    </div>
                    </div>
                                    <div class="record-item">
                        <img src="/cache/img/4c02f6375e48f7dd7948619324ca86fc.jpg" alt="family support structure" loading="lazy" width="1070" height="802" />                        <div class="overlay">
