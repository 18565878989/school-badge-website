<!-- if page is other -->
<meta name="description" content="A Semmelweis Egyetem Magyarország és a közép-európai régió vezető orvos-egészségügyi felsőoktatási intézménye, mely szakegyetemként egyedülálló az országban. Hat karán általános és fogorvosi, gyógyszerész-, valamint egészségtudományi, egészségügyi közszolgálati és konduktori képzést biztosít Budapesten. Az egyetem közel negyven különálló betegellátó egységével az ország egyik legnagyobb gyógyító intézménye. Hármas feladatkörében a harmadik pillér a kutatás-fejlesztési és innovációs tevékenység, amelyben jelentős mind hazai, mind nemzetközi viszonylatban." />
<meta name="keywords" content="university, health, healthcare, medical, orvosi, egyetem, egészség, egészségügy" />
<meta name="revisit-after" content="1 days">

<meta property="og:url" content="https://semmelweis.hu/apple-touch-icon.png" />
