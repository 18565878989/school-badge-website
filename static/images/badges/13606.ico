<div class="text-not-found text-not-found-custom">
    <div class="tp--container">
        <h3>PAGE NOT FOUND</h3>
        <p>Thank you for visiting the Temasek Polytechnic website. The information you are looking for could have been moved or changed.</p>
        <p>Here are some options you may like to consider:</p>
        
        <p><a href="/">Return to TP Home</a></p>
        <p><a href="/sitemap.html">Use Our Sitemap</a></p>
        <p style="display: none;"><a id="search-page" href="/search.html">Search Page</a></p>

        <p style="margin-top: 20.0px;">
            Or try searching here:&nbsp;
            <input id="not-found-page-search" onkeyup="myFunction(event)" type="text" name="keyword" style="width: 300.0px;">
            <span class="tp--secondary-btn text-left">
                <a href="" class="btn tp--button edit-tp--button" onclick="myClickFunction(event)">
                    Search
                </a>
            </span>
        </p>
    </div>
</div>

<script type="text/javascript">
    function myFunction(event) {
        var value = document.getElementById("not-found-page-search").value;
        var searchPage = document.getElementById("search-page").href;
        var redirect_url = searchPage + "?keyword=" + value;

        if (event.which == 13) {
            window.open(redirect_url, "_self");
        }
    }
    function myClickFunction(event) {
        event.preventDefault();
        var value = document.getElementById("not-found-page-search").value;
        var searchPage = document.getElementById("search-page").href;
        var redirect_url = searchPage + "?keyword=" + value;

        window.open(redirect_url, "_self");
    }
</script>
    
</div>

    

