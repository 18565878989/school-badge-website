    width: calc(100% / 3) !important;
	    padding: 0px 15px;
	    display: table-cell !important;
}
.singel-staff-box {
    background-color: #c5912d;
    padding: 15px;
    border-bottom-left-radius: 20px;
    border-top-right-radius: 20px;
