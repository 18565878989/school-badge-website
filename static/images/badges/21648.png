    <style type="text/css">
        .congratsblock {
            padding: 24px 56px;
            background-image: linear-gradient(#EEE59E,#E6D86E);
            font-size: 18px;
            color: #760e26;
        }

            .congratsblock a {
                text-decoration: underline;
            }

            .congratsblock .fa-video-camera {
                animation: wild 1s infinite;
            }

        .countdown-frame {
            width: 320px;
            height: 120px;
            position: absolute;
            top: 20px;
            left: 120px;
        }

        @media (max-width: 1600px) {
            .countdown-frame {
                width: 320px;
                height: 120px;
                position: absolute;
                top: 20px;
                left: 40px;
            }
        }

        @media (max-width: 1440px) {
            .countdown-frame {
                width: 320px;
                height: 120px;
                position: absolute;
                top: 20px;
                left: 60px;
            }
        }

        @media (max-width: 760px) {
            .congratsblock {
                padding: 12px 28px;
            }

                .congratsblock .btn-primary {
                    white-space: normal;
                }

            .countdown-frame {
                width: 100%;
                height: 120px;
                position: absolute;
                top: 36px;
                left: 0;
            }
        }
    </style>
