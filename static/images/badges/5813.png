        <div class="tabs">
                            <button class="tab current" data-id="1">Years 1 - 6</button>
                    </div>
                            <div class="tab-content current" data-id="1">
                                <article class="editor"><p><span style="font-weight: 400;">Bradbury School is an IB World School committed to educating open-minded seekers, supporting individual student needs, and developing the whole child's skills, attitudes, and global perspectives. The IB curriculum emphasises transdisciplinary learning, research, communication, and critical thinking to foster respect, responsibility, and meaningful action.</span></p></article>
                                    <a href="https://bradbury.esf.edu.hk/en/outstanding_education/curriculum/">
                        <span>Find out more</span>
                    </a>
                            </div>
                <script type="text/javascript">
            $(document).ready(function() {
                $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();

                $('.tab', '#section3').click(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $(this).addClass('current');
                    $('.tab-content[data-id=' + $(this).data('id') + ']', '#section3').addClass('current');
                    $('select', '#section3').val($(this).data('id')).selectbox('refresh');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });

                $('.tab-select', '#section3').change(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $('.tab[data-id=' + $(this).val() + ']').addClass('current');
                    $('.tab-content[data-id=' + $(this).val() + ']', '#section3').addClass('current');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });
            });
        </script>
    </div>
</section>
<section id="section4" data-total="2">
