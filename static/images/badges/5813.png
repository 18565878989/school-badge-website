		<script type="text/javascript">
			$(document).ready(function() {
				$('button', '#accept-cookies').click(function() {
					$('#accept-cookies').remove();
					$.ajax({
						url: genurl('cookies', 'main'),
						type: 'post',
						data: {
							accept: 'y'
						},
						success: function(response) {
						},
						async: false
					});
				});
			});
