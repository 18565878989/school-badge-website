.elementor-nav-menu li a img{
height: 70px;
padding-bottom: 0px !important;
}
.header_icon{
margin: 0;
position: absolute;
top: 50%;
-ms-transform: translateY(-50%);
transform: translateY(-50%);
}
}
.footer_menu img.menu-image.menu-image-title-below {
display: none;
}
span.menu-image-title-below.menu-image-title {
text-align: left;
}
.home .elementor-post__excerpt p{
text-align:left;
overflow: hidden;
text-overflow: ellipsis;
display: -webkit-box;
-webkit-line-clamp: 4;
-webkit-box-orient: vertical;
}
.footer_menu a {
padding-top: 5px !important;
padding-bottom: 20px !important;
}
.footer_menu nav.elementor-nav-menu--dropdown.elementor-nav-menu__container {
background: transparent !important;
}
.footer_menu .current_page_item a {
background: transparent !important;
}
.footer_menu a {
font-size: 16px;
padding-left: 0;
}
