<meta property="og:image" content="https://www.mink.edu.hk/wp-content/uploads/2021/12/our_team-1-scaled.jpg" />
<meta name="twitter:card" content="summary_large_image" />
<script type="application/ld+json" class="yoast-schema-graph">{"@context":"https://schema.org","@graph":[{"@type":"WebPage","@id":"https://www.mink.edu.hk/","url":"https://www.mink.edu.hk/","name":"主頁 - 明雅中英文幼稚園 Mink Anglo-Chinese Kindergarten","isPartOf":{"@id":"https://www.mink.edu.hk/#website"},"about":{"@id":"https://www.mink.edu.hk/#organization"},"primaryImageOfPage":{"@id":"https://www.mink.edu.hk/#primaryimage"},"image":{"@id":"https://www.mink.edu.hk/#primaryimage"},"thumbnailUrl":"https://www.mink.edu.hk/wp-content/uploads/2021/12/our_team-1-scaled.jpg","datePublished":"2021-12-14T03:52:00+00:00","dateModified":"2025-06-09T09:34:23+00:00","breadcrumb":{"@id":"https://www.mink.edu.hk/#breadcrumb"},"inLanguage":"zh-TW","potentialAction":[{"@type":"ReadAction","target":["https://www.mink.edu.hk/"]}]},{"@type":"ImageObject","inLanguage":"zh-TW","@id":"https://www.mink.edu.hk/#primaryimage","url":"https://www.mink.edu.hk/wp-content/uploads/2021/12/our_team-1-scaled.jpg","contentUrl":"https://www.mink.edu.hk/wp-content/uploads/2021/12/our_team-1-scaled.jpg","width":2560,"height":1707},{"@type":"BreadcrumbList","@id":"https://www.mink.edu.hk/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"主頁"}]},{"@type":"WebSite","@id":"https://www.mink.edu.hk/#website","url":"https://www.mink.edu.hk/","name":"明雅中英文幼稚園 Mink Anglo-Chinese Kindergarten","description":"明雅中英文幼稚園為不同國籍的兒童提供一個安全，愉快及輕鬆的學習環境。透過課程的編排，鼓勵兒童自我照顧、發展社交、獨立思考、表達和創作能力。為配合優質教學，本校按照兒童體能及智能上的發展，設置各種實用的專題學習及活動教材，使兒童能在情緒、社交、智力及語言等各方面得到均衡的發展，為兒童升上小學作好充分的準備。","publisher":{"@id":"https://www.mink.edu.hk/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://www.mink.edu.hk/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"zh-TW"},{"@type":"Organization","@id":"https://www.mink.edu.hk/#organization","name":"明雅中英文幼稚園 Mink Anglo-Chinese Kinderga