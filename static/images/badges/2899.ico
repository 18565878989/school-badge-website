<link rel="stylesheet" type="text/css" href="/css/colorbox.css" />
<script type="text/javascript">
	$(document).ready(function() {
				
		$(window).resize(function() {
			$('#home-top').css('padding-top', $('#floating-menu').innerHeight() + 40);
		}).resize();
		
		$('#home-top').Slider({
			slides: '.top-item',
			maxSlide: 1,
			autoPlay: 5000,
			swipeControl: true,
			infiniteLoop: true,
			pager: '.slider-pager',
			pagerTemplate: function(page, total_page) {
				return '<a href="#" title="' + page + '">' + page + '</a>';		
			}
		});
		
		$('#home-bottom').Slider({
			slides: '.bottom-item',
			maxSlide: 4,
			swipeControl: true,
			infiniteLoop: true,
			afterResize: function(slider, slides, current_page, total_page) {
				$('.prev, .next', slider).css('height', $('img', slider).height());
			},
			afterInit: function(slider, slides, current_page, total_page) {
				$('.prev, .next', slider).css('height', $('img', slider).height());
			}
		});
	});
	
	$(window).load(function() {
		var animate = function() {
			var height = $(window).scrollTop() + Math.round($(window).height() * 0.6);
			$.each($('#content > div'), function(key, value) {
				if(! $(this).hasClass('animate') && height > $(this).offset().top)
				{
					$(this).addClass('animate');
					if($(this).attr('id') == 'home-middle') {
						$(this).find('.middle-container > *').each(function(index) {
							var item = $(this);
							setTimeout(function() {
								item.addClass('animate');
							}, index * 200);
						});
					}
				}
			});
		};
		$(window).on('scroll', animate);
		animate();
	});
</script>
<div id="content-start"></div>
<h1>Holy Family Canossian College</h1>
<div id="home-top">
	<div class="container">
		<div class="slider-container"><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/1c7fe6a457e6baee9d76aac2e8143336.jpeg" alt="1" width="800" height="520" title="1" /></div><!--
				--><div class="info">
						<h2>Chinese New Year Celebration 2026</h2>
						<div class="content">Our school community gathered in the Chinese Language Centre to celebrate the Lunar New Year during a festive lunchtime filled with joy, harmony, and a deep sense of cultural pride.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/hfcc_chinese_new_year_celebration_2026" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/e32058e09816d6ea78e20fc41a99c744.jpeg" alt="12" width="800" height="520" title="12" /></div><!--
				--><div class="info">
						<h2>Catholic Formation Programmes <br/>2025-2026</h2>
						<div class="content">On 7 February 2026, our S1 Joint-school Catholic Students’ Formation Day was held at Canossa College.  It was a grace-filled experience where students were inspired to become ‘Messengers of Hope’.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/catholic_formation_programmes_202526" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/0e75621df45c5e769075ac50b97c51c5.jpg" alt="IMG_5196" width="800" height="520" title="IMG_5196" /></div><!--
				--><div class="info">
						<h2>School Outing</h2>
						<div class="content">On 1 December 2025, our S4 students participated in a leadership training programme at the HKFYG Jockey Club Sai Kung Outdoor Training Camp.  It was a valuable experience that allowed us to take a break from our busy school life, bond with our schoolmates, and focus on our well-being.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/school_outing" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/2047551d40afa65484519512522957e2.jpg" alt="Pic 8" width="800" height="520" title="Pic 8" /></div><!--
				--><div class="info">
						<h2>2025/26 School Care Subsidy Scheme – Care and Concern Concert</h2>
						<div class="content">In the Care and Concern Concert, our Holy Family Canossian College Vocal Ensemble and Cantonese Opera Ambassadors delivered an absolutely stellar performance that captivated the elderly from the first note. The musicians brought an element of absolute pure joy and enjoyment to the Care and Concern Concert. Furthermore, games like ‘Hong Kong Slangs from Different Generations’ were organised in the Concert to build a closer relationship with the elderly.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/music_202526_care_and_concern_concert" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/adf7c7d176cba6585ec5430c0bad4417.jpg" alt="6" width="800" height="520" title="6" /></div><!--
				--><div class="info">
						<h2>“Pilgrims of Hope” Journey to Cheung Chau</h2>
						<div class="content">In the Jubilee Year, we, S2 to S5 Catholic students accompanied by Catholic staff embarked on a blessed and joyful “Pilgrims of Hope” journey to Cheung Chau on 22 November 2025.  We were welcomed by beautiful weather, and the journey was full of love, faith, and hope.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/pilgrims_of_hope_Cheung_Chau" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/1b315eb5ef1d8e8e65c04633204fcbd5.jpg" alt="_DSC0382" width="800" height="520" title="_DSC0382" /></div><!--
				--><div class="info">
						<h2>Fruit Day in the First Term</h2>
						<div class="content">On 19 November 2025, our school successfully held Fruit Day, promoting healthy eating habits among all school members.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/fruit_days_202526" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/de4a65e44ecf87381ce80b7fc7fd76b1.jpg" alt="IMG_1934" width="800" height="520" title="IMG_1934" /></div><!--
				--><div class="info">
						<h2>Incense Tree Conservation Scheme on Campus</h2>
						<div class="content">On 11 November 2025, our school successfully launched the Incense Tree Conservation Scheme on Campus.  The Scheme was co-organised by the Chinese University of Hong Kong (CUHK) and our school's Green Education Team..</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/Incense_Tree_Conservation_Scheme_2025" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/de8df19ca9e49a72bf64fc840b988f8a.jpg" alt="IMG_1891" width="800" height="520" title="IMG_1891" /></div><!--
				--><div class="info">
						<h2>Caritas Bazaar <br/>on 9.11.2025</h2>
						<div class="content">On 9 November 2025,we successfully ran our stall at the Caritas Bazaar in Fa Hui Park.  I was pleased to join and support our dedicated teachers and students in this effort to raise funds for Caritas.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/caritas_bazaar_2025" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/24b781293578661850eb92c5b90c1b5f.jpg" alt="IMG_3576" width="800" height="520" title="IMG_3576" /></div><!--
				--><div class="info">
						<h2>An Educational Trip to Croatia and Slovenia</h2>
						<div class="content">On 18-26 July 2025, our schoolmates and I had the incredible opportunity to go on an educational trip to Croatia and Slovenia.  This journey took us through some of the most breathtaking natural landscapes and historical sites in Europe, including Lake Bled, Postojna Cave, Predjama Castle, etc.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/educational_trip_to_Croatia_and_Slovenia" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/bc86931049d0eea05327a65d88ce844f.jpg" alt="DGJM9530" width="800" height="520" title="DGJM9530" /></div><!--
				--><div class="info">
						<h2>Canossian Pilgrims of Hope – Our Root and Our Way: <br/>Pilgrimage to Italy</h2>
						<div class="content">Eight students from our school participated in the Joint Canossian Schools Pilgrimage to Italy from 16 to 25 July 2025.This pilgrimage offered a unique opportunity for our students to reflect on their identity as Canossians.  They deepened their faith through the charism of our Foundress, St. Magdalene of Canossa, while embracing the Jubilee themes of renewal and mercy.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/canossian_schools_pilgrimage_to_Italy" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/b01a2d8498d16de3378471f997c2adde.jpg" alt="A1A03086-2" width="800" height="520" title="A1A03086-2" /></div><!--
				--><div class="info">
						<h2>Opening Mass, Pilgrimage Sharing and Installation Ceremony</h2>
						<div class="content">With the blessings of our Father in heaven, the Opening Mass and Installation Ceremony were successfully held on 12 September 2025, gathering all our schoolmates unto Jesus Christ, our Lord.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/opening_mass_pilgrimage_sharing_and_installation_ceremony" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/03df1be9db33c1173978ea386e5a6350.jpg" alt="MOO01338" width="800" height="520" title="MOO01338" /></div><!--
				--><div class="info">
						<h2>Wellness Carnival</h2>
						<div class="content">Our school theme this year is “Cultivating Self-love  Nourishing Wellness.” A vital aspect of this theme is recognizing the importance of taking time off from our studies to relax.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/wellness_carnival_2025" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/191a4e26b848cc6dd8b9d65a92d66ce5.png" alt="__2DSC_0590" width="800" height="520" title="__2DSC_0590" /></div><!--
				--><div class="info">
						<h2>S1 Orientation Day</h2>
						<div class="content">The S1 Orientation Day was successfully held on 6 September 2025, creating a memorable experience for all participants.  This meaningful event consisted of several activities, including a campus tour and various team-building games...</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/S1_Orientation_Day_2526" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/002cbd1cd42bbd153f0f0865137c5887.jpg" alt="MOO00923" width="800" height="520" title="MOO00923" /></div><!--
				--><div class="info">
						<h2>School Opening Ceremony 2025-2026</h2>
						<div class="content">On 1 September 2025, the school campus once again blossomed with joy and vitality as Holy Familians reunited after a rejuvenating summer break.  Clad in our signature pink uniforms, we gathered in strength and harmony to mark the beginning of a new academic year.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/School_Opening_Ceremony_2025-2026" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/60f52ae4cff7ef431daa630899e663a5.jpg" alt="A1A04887" width="800" height="520" title="A1A04887" /></div><!--
				--><div class="info">
						<h2>Year-end Celebration 2025</h2>
						<div class="content">As the academic year came to a close, our students delivered a remarkable end-of-year performance in the School Hall on 8 July 2025, artfully showcasing their diverse talents both in artistic and instrumental forms..</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/year_end_celebration_202425" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/32072e7b6e1e508f8ec28505589765e0.png" alt="musicpdf800" width="800" height="520" title="musicpdf800" /></div><!--
				--><div class="info">
						<h2>Marvellous Results in Music Competitions</h2>
						<div class="content">Holy Familians distinguished themselves in music competitions with marvellous results in the 2024-2025 school year...</div>
													<a  href="https://hfcc.edu.hk/events/latest_events/music_achievement_2425/?back=0b4cf567856df1036f6872f1b4adce34" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/f37eca28af1ec88b5352d96d5ea42184.jpg" alt="A1A00225-Enhanced-NR" width="800" height="520" title="A1A00225-Enhanced-NR" /></div><!--
				--><div class="info">
						<h2>Graduation Day 2025</h2>
						<div class="content">As we gathered in the hall, a profound sense of significance enveloped us — our graduation ceremony had finally arrived. What once seemed a distant dream had become a vivid reality, filled with joy, gratitude, and a bittersweet farewell to our second home.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/2425_S6_Graduation/" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/15d199c89df4462bd923fa8464a0f443.jpg" alt="Elderly Visit_1" width="800" height="520" title="Elderly Visit_1" /></div><!--
				--><div class="info">
						<h2>Guidance Programmes<br/>2024-25</h2>
						<div class="content">This year, the school has organised a variety of Guidance programmes to support students’ mental well-being.  These activities provided teachers and students with engaging and memorable experiences..</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/guidance_programmes_202425" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/5c5e381d65b0f08aedc78438e7db5a87.jpg" alt="IMG_5430" width="800" height="520" title="IMG_5430" /></div><!--
				--><div class="info">
						<h2>School-based National Education Day</h2>
						<div class="content">On National Education Day, held on 16 May 2025, students from various levels had the opportunity to reinforce classroom learning and participate in a range of exploration tours in Shenzhen, broadening their horizons beyond the curriculum. .</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/school-based_national_education_day_2425" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/5a4aaf35f39258a2901e60aaedd7a900.jpg" alt="IMG_1299" width="800" height="520" title="IMG_1299" /></div><!--
				--><div class="info">
						<h2>Championship for the Hunger-free Meal Design Competition</h2>
						<div class="content">To promote a healthy lifestyle, some senior students participated in the Hunger-free Meal Design Competition organised by Oxfam Hong Kong.  Out of over 700 entries, our S5 team entered the Final Competition on 12 April 2025, where they needed to cook lunch on the spot.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/he_activity_2425/?back=55a6eb0a62e12b79776f109938ae8359" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/91336f7b7ee40f9313ce181b22860cd9.jpg" alt="20250308_885" width="800" height="520" title="20250308_885" /></div><!--
				--><div class="info">
						<h2>Championship for a Sand Painting Competition</h2>
						<div class="content">Through the sand painting courses held by the Nature Club, four students were invited to participate in the 2nd Joint School Sand Painting Creation Competition organised by the Hong Kong Sand Painting Association on 8 March 2025.  The participants devoted significant effort to their preparation, creating unique designs, selecting appropriate music and crafting scripts to complement their sand painting performance.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/sandpainting_202425" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/bcf0ea6c1e4dea3c59c52926860537ca.jpg" alt="99cf740f-fe0e-4b1b-8cb4-2c790a9aebd6" width="800" height="520" title="99cf740f-fe0e-4b1b-8cb4-2c790a9aebd6" /></div><!--
				--><div class="info">
						<h2>Lunchtime Concert</h2>
						<div class="content">The Music Society of Holy Family Canossian College held its Lunchtime Concert on 12 May 2025 in the School Hall.  The concert, themed "Staying Active   Staying Healthy," brought together music lovers to enjoy a diverse and captivating lineup of performances...</div>
													<a  href="https://hfcc.edu.hk/events/latest_events/lunchtime_concert_2425" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/8723f7987de983d963e5fc773bc6084d.png" alt="STEAM Day cover" width="800" height="520" title="STEAM Day cover" /></div><!--
				--><div class="info">
						<h2>STEAM Day</h2>
						<div class="content">On 2 May 2025, the Campus Treasure Hunt, organised by the STEAM Team and the Mathematics Olympiad Team, was held to provide students with a fun puzzle-solving experience.  While exploring the campus, students searched for and attempted a series of logical and mathematical puzzles to win big prizes,..</div>
													<a  href="https://hfcc.edu.hk/events/latest_events/steam_day_2425" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/e4d85c859a3373a5334417677224dc2d.png" alt="wellness" width="800" height="520" title="wellness" /></div><!--
				--><div class="info">
						<h2>Wellness Day</h2>
						<div class="content">On 15 April 2025, our school embraced its theme, “Staying Active. Staying Healthy.”  Organized through the efforts of social workers, guidance teachers, and student helpers, the day offered a variety of enriching activities designed to help staff members and students slow down, connect, and embrace their well-being.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/wellness_day_2425_2ndterm" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/02bdfbc28d609d0458247822b2398823.png" alt="1" width="800" height="520" title="1" /></div><!--
				--><div class="info">
						<h2>Life-wide <br/>Learning Day</h2>
						<div class="content">Life-wide Learning Day on 7 March 2025 was an unforgettable experience.The vibrant atmosphere filled me with excitement from the moment I arrived, setting the tone for a memorable day.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/life-wide_learning_day_2425" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/6944000fa68fe57b8ce94de1017ffefd.jpg" alt="A1A05208" width="800" height="520" title="A1A05208" /></div><!--
				--><div class="info">
						<h2>Fruit Days</h2>
						<div class="content">With the support of our Home Economics teachers and our vibrant school community, innovative “Fruit Day” events were successfully held on 20 November 2024 and 12 March 12 2025.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/fruit_days_202425" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/b613b4ab11815cbcd84006ed84579800.jpg" alt="IMG_2224" width="800" height="520" title="IMG_2224" /></div><!--
				--><div class="info">
						<h2>Famine Lunch</h2>
						<div class="content">Under the blessing of our heavenly Father, the annual Famine Lunch graced our school hall on<br/> 5 March 2025, coinciding with Ash Wednesday <br/>— a day of solemn reflection on human fragility and divine reconciliation, marking the dawn of Lent.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/famine_lunch_2425/" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/b13413d3e942f985cd4d75568e56be8f.jpg" alt="IMG_1524-2-4" width="800" height="520" title="IMG_1524-2-4" /></div><!--
				--><div class="info">
						<h2>Catholic Formation Programmes</h2>
						<div class="content">At Holy Family Canossian College, our Catholic Formation Programmes play a vital role in the holistic development of our students, fostering their spiritual growth as well as equipping them with the values and virtues necessary to live a meaningful and fulfilling life.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/catholic_formation_programmes_202425" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/975f5d24c31f03f55c17b99080e3dcb8.jpg" alt="A1A08174" width="800" height="520" title="A1A08174" /></div><!--
				--><div class="info">
						<h2>A Chinese Cultural Activity at HFCC — Lingnan Harmony: Guangdong Music, Cantonese, and Nanyin</h2>
						<div class="content">On 17 December 2024, our school was blessed to invite a group of musicians led by the veteran Cantonese opera performing artist, Professor Yuen Siu-fai, to introduce and demonstrate the characteristics of Lingnan music, with the theme “Lingnan Harmony: Guangdong Music, Cantonese, and Nanyin” ..</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/music_nanyin_2024" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/a89b87539165c4a6b950e8e07b6870e3.jpg" alt="A1A01342" width="800" height="520" title="A1A01342" /></div><!--
				--><div class="info">
						<h2>Athletics Meet 2024</h2>
						<div class="content">With captains and members of the four Houses marching into Kowloon Tsai Sports Ground, the annual Athletics Meet was successfully held on 9 December 2024.  It was indisputably a joyful and memorable event.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/athletics_meet_2425" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/da96e4b349f05e0e74482cbc92aaf449.jpg" alt="1 First Photo" width="800" height="520" title="1 First Photo" /></div><!--
				--><div class="info">
						<h2>S5 & S6 School Outing – Macau</h2>
						<div class="content">On 2 December 2024, all S5-6 students joyously embarked on a one-day Macau tour.  This journey certainly proved to be an excellent opportunity for us to learn about the culture of a fellow special administrative region of our motherland...</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/school_outing_2024_S5_and_S6" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/9f535939d9b3b6521b0209bb7627f026.jpeg" alt="WhatsApp Image 2024-12-17 at 14.28.15 (1)" width="800" height="520" title="WhatsApp Image 2024-12-17 at 14.28.15 (1)" /></div><!--
				--><div class="info">
						<h2>S4 CS Outing — Sha Tau Kok</h2>
						<div class="content">On 4 October 2024, all Secondary 4 students had the privilege of visiting the Sha Tau Kok Frontier Closed Area.  Over the course of an afternoon, students found themselves immersed in the beauty of this once-isolated village..</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/s4_cs_outing_2024" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/5fdd8479077c15c8e6691b98087ff328.jpeg" alt="1" width="800" height="520" title="1" /></div><!--
				--><div class="info">
						<h2>Advent Liturgy</h2>
						<div class="content">When we walk around our campus, we find some enchanting Christmas decorations.  These decorations are more than just pretty objects.  These remind us to prepare our hearts for Advent.</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/advent_liturgy_2024" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/f32d3c2a0b6231ffc3917a1f20878842.jpeg" alt="2" width="800" height="520" title="2" /></div><!--
				--><div class="info">
						<h2>Our Alumna - <br><em>Juanita Mok</em></h2>
						<div class="content">Holy Family would like to extend our big congratulations to an alumna, Juanita Mok, who received the 2024 Ten Outstanding Young Persons Selection Award organised by the Junior Chamber International Hong Kong (“JCI Hong Kong”).</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/alumnae_juanitaMok_2425" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/10ffb0ad8b590385fa14fffde9400d44.jpeg" alt="1" width="800" height="520" title="1" /></div><!--
				--><div class="info">
						<h2>75<sup>th</sup> Anniversary of the Founding of the People’s Republic of China</h2>
						<div class="content">To celebrate the 75<sup>th</sup> Anniversary of the Founding of the People’s Republic of China, it was an honour for our students to participate in several celebration events..</div>
													<a  href="https://hfcc.edu.hk/events/latest_events/the_75th_anniversary_of_the_founding_of_Peoples_Republic_of_China" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/0999d5be746cacfdee81ab3197ce5056.jpg" alt="20240707_234704" width="800" height="520" title="20240707_234704" /></div><!--
				--><div class="info">
						<h2>Shining Stars at the Territory-wide Cantonese Opera Competition</h2>
						<div class="content">The prestigious Cantonese Opera Competition (第四十九屆全港青年粤曲比賽) competition recently held on 7 July 2024 bore witness to our budding Cantonese Opera talents – Chole Fu from S2A and Queena Ng from S3A..</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/competition_2324_chinese_opera" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/226f363928c44fbc49ce3e384098eaa0.jpg" alt="4.0 D75_5374" width="800" height="520" title="4.0 D75_5374" /></div><!--
				--><div class="info">
						<h2>Teacher-student Fun Day</h2>
						<div class="content">On 14 May 2024, the campus of Holy Family Canossian College was filled with the sound of laughter and cheers as a series of sports activities were held to uphold the Canossian Missions’ education philosophy of ‘Charity in Humility’..</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/teacher_student_fun_day" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/80f18c9eea060551937c2043f9354d00.jpeg" alt="WhatsApp Image 2024-06-24 at 9.39.39 AM" width="800" height="520" title="WhatsApp Image 2024-06-24 at 9.39.39 AM" /></div><!--
				--><div class="info">
						<h2>Educational Trip to Australia</h2>
						<div class="content">From 28 March to 5 April, 30 students from S3 to S5, accompanied by Ms Kary Chan, Ms Tracy Mak, and Ms Anna Ng, embarked on a journey to Sydney and Cairns during Easter..</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/educationaltrip_2324_australia" class="learn-more">Learn more</a>
											</div>
				</div><!--
						--><div class="top-item">
					<div class="photo"><img src="/cache/img/9c153636394a546bd8f96eface375799.jpg" alt="Zhuhai Aerospace Land 8" width="800" height="520" title="Zhuhai Aerospace Land 8" /></div><!--
				--><div class="info">
						<h2>S5 CS Mainland Study Tour</h2>
						<div class="content">On 11-12 December 2023, all Form 5 students embarked on a captivating two-day study tour of Zhuhai.  This incredible journey left an indelible mark on the participants, providing a unique opportunity to broaden our horizons, deepening our knowledge of Chinese economic development, and fostering lifelong memories..</div>
													<a  href="https://www.hfcc.edu.hk/events/latest_events/Mainland_Study_Tour_2324_S5" class="learn-more">Learn more</a>
											</div>
				</div><!--
				--></div>
