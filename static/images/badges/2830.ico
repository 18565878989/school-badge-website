                    $("#urgentMsgButton").delay(500).trigger("click");

                    $('#urgentMsgContentDiv .btn_msg_close').click(function() {
                        $(".layui-layer").hide();
                        $(".layui-layer-shade").hide();
                    });
                    // $("#layui-layer1").css("left", "20%");
                });
                // })
            </script>
    
