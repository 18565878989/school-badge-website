<script>
	function doLogin() 
	{
		document.login_user.submit();
	}
	document.onkeydown = function(e){
                var e=e || event;
                var currKey=e.keyCode||e.which||e.charCode;
                if(currKey == 13) {
                        doLogin();
                }
		}
</script>

