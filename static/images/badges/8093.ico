</header>

        
  <main class="main" id="midd-main" aria-labelledby="midd-page-header-label">
              
      <div class="journey">
    <section id=intro class="journey-section journey-section--intro js-journey-section" data-section=intro aria-labelledby="midd-page-header-label" data-background-video-parent>
      <div class="journey-section__body">
    <div class="container">
      <div class="journey-section__body-content align-center">
        <div class="row">
          <div class="col-12 col-sm-10 journey-section__text">
                          <h1 id="midd-page-header-label">
                Chart your own course of study in one of the most <strong>immersive</strong> and <strong>globally engaged</strong> experiences in higher education
              </h1>
                                      <p class="sub-title">
                Vermont | Monterey, California | The World
              </p>
                                              </div>
        </div>
      </div>
