	<section id="content">		
		<script type="text/javascript">
    var timeout = [];

    $(window).load(function() {
		let animate = function() {
			let height = $(window).scrollTop() + Math.round($(window).height() * 0.6);
			$('#content > section').each(function() {
				if(!$(this).hasClass('animate') && height > $(this).offset().top)
				{
					$(this).addClass('animate');
                    if($(this).attr('id') == 'section2') {
						$('li > div', '#section2').each(function(index) {
							let item = $(this);
							setTimeout(function() {
								item.addClass('animate');
							}, index * 200);
						});
					}
				}
			});
		};
		$(window).on('scroll', animate);
		animate();
	});
</script>
<div id="banner">
    <div class="banner-container">
                                                <div class="banner-item">
                    <div class="wrapper">
                        <img src="/cache/img/de2fee22e53e4c9450b32d05fe6006e1.png" alt="" loading="lazy" width="1904" height="1200" class="trans" />                        <video id="video" width="1904" height="1200" preload="none" playsinline webkit-playsinline muted loop>
                            <source src="/upload/banner/1/banner/671fb6aa58234.mp4" type="video/mp4">
                        </video>
                        <div class="mask"></div>
                        <div class="container">
                            <button class="play"></button>
                        </div>
                    </div>
                                    </div>
                        </div>
    <div class="container">
                <div class="scroll-icon"></div>
    </div>
    <script type="text/javascript">
        $(document).ready(function() {
            let pager_click = false;

            $('#banner').Slider({
                slides: '.banner-item',
                maxSlide: 1,
                swipeControl: true,
                skipBoundary: true,
                infiniteLoop: true,
                pager: '.banner-pager',
                afterSlide: function(slider, slides, current_page, total_page) {
                    $.each(timeout, function(index, value) {
                        clearTimeout(value);
                    });
                    let videos = $('video', slider);
                    videos.each(function(i, video) {
                        video.pause();
                        video.currentTime = 0;
                    });
                    $('button', slider).removeClass('play').addClass('pause');
                    if($('.slider.current video', slider).length) {
                                                        video = document.querySelector('#banner .slider.current video');
                                video.play();
                                            }
                    else if(!pager_click) {
                        timeout = setTimeout(function() {
                            slider.Slider('next');
                        }, 5000);
                    }
                },
                afterResize: function(slider, slides, current_page, total_page) {
                    if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                },
                afterInit: function(slider, slides, current_page, total_page) {
                                            let videos = $('video', slider);
                        videos.each(function(i, video) {
                            video.addEventListener('ended', videoEnd, false);
                        });
                        if($('.slider.current video', slider).length) {
                                                                video = document.querySelector('#banner .slider.current video');
                                    video.play();
                                    $('.slider.current button', slider).removeClass('play').addClass('pause');
                                                    }
                        else {
                            timeout = setTimeout(function() {
                                slider.Slider('next');
                            }, 5000);
                        }
                                        if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                }
            });
            
            $('.banner-item video', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                let button = $(this).parent().find('button');
                if(button.hasClass('pause')) {
                    video.pause();
                    button.removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    button.removeClass('play').addClass('pause');
                }
            });
            $('.banner-item button', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                if($(this).hasClass('pause')) {
                    video.pause();
                    $(this).removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    $(this).removeClass('play').addClass('pause');
                }
            });

            $('body').on('click', '#banner .banner-pager a', function() {
                pager_click = true;
            });

            function videoEnd(e) {
                if(!pager_click) {
                    $('#banner').Slider('next');
                }
                else {
                    $('#banner .slider.current button').removeClass('pause').addClass('play');
                }
            }
        });
    </script>
</div>
<section id="section1">
    <div class="container">
                    <div class="left">
                <article class="editor"><h3 class="homepage-title title"><span style="font-size: 45px;">Responsibility, </span><span style="font-size: 45px;">Individuality, Spirit and Excellence</span></h3>
<p>&nbsp;</p>
<p>&nbsp;</p>
<p>&nbsp;</p></article>
            </div>
                            <div class="right">
                <article class="editor"><p><span style="font-weight: 400;"><img class="round-border" src="/upload/files/1/file/67317e18b469c.jpg" alt="Public Photos / Files - NAM_1472" width="699" height="466" /></span></p>
<p>&nbsp;</p>
<p><span style="font-weight: 400;">Island School creates a nurturing, bilingual environment that fosters diverse, independent learners with strong values, creativity, and the skills to succeed in an evolving world.</span></p>
<p>&nbsp;</p>
<p class="rounded_title bg-colour1"><span style="color: #ffffff;"><a style="color: #ffffff;" href="https://island.esf.edu.hk/en/about_us/vision_and_mission/">Find out more</a></span></p></article>
            </div>
                            <div class="responsive">
                <article class="editor"><h3 class="homepage-title title"><span style="font-size: 36px;">Responsibility, Individuality, Spirit and Excellence</span></h3>
<p>&nbsp;</p>
<p><span style="font-weight: 400;">Island School creates a nurturing, bilingual environment that fosters diverse, independent learners with strong values, creativity, and the skills to succeed in an evolving world.</span></p>
<p>&nbsp;</p>
<p><span style="font-weight: 400;"><img class="round-border" src="/upload/files/1/file/67317e18b469c.jpg" alt="Public Photos / Files - NAM_1472" width="699" height="466" /></span></p>
<p>&nbsp;</p>
<p class="rounded_title bg-colour1"><span style="color: #ffffff;"><a style="color: #ffffff;" href="https://island.esf.edu.hk/en/about_us/vision_and_mission/">Find out more</a></span></p></article>
            </div>
            </div>
</section>
<section id="section2">
    <div class="container">
        <div class="section-title">
            <h2 class="colour2">What can IS offer your family?</h2>
            <span class="bg-colour1"></span>
        </div>
    </div>
    <div class="wrapper bg-colour2">
        <div class="container">
            <ul>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/6ea119547312c3de49fc9e83a1eebd72.png" alt="World-class Education" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">The Futures Curriculum</h3>
                            <div class="overlay bg-colour1">
                                <p>Our Futures curriculum develops your child's key skills - Character, Citizenship, Collaboration, Communication, Creativity, and Critical Thinking - through engaging Elements and Explorations.</p>
                                                                    <a  href="https://island.esf.edu.hk/en/outstanding_education/curriculum/curriculum_overview">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/a9fdab0924217fbc4b59d9ddc3733b2d.png" alt="SIS offers icon-2" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Student Support</h3>
                            <div class="overlay bg-colour1">
                                <p>At Island School, we nurture your child's holistic development through comprehensive pastoral care, counselling, and learning support to help them thrive.</p>
                                                                    <a  href="https://island.esf.edu.hk/en/outstanding_education/student_support_wellbeing/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/f2373c3f3e2c0f5dadeb127abd4368cb.png" alt="Real-world Experience" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Fostering Global Citizenship</h3>
                            <div class="overlay bg-colour1">
                                <p>At Island School, we empower your child to become a global citizen and future leader through a values-driven education focused on excellence, responsibility, and individuality.</p>
                                                                    <a  href="https://island.esf.edu.hk/en/outstanding_experiences/experiential_learning/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/55ed86d7a2d412a4f5950840ae67f03f.png" alt="Strong School-Family Connection" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Inclusive and Diverse</h3>
                            <div class="overlay bg-colour1">
                                <p>At Island School, we champion inclusivity, celebrating diversity and empowering your child to become a compassionate, open-minded global citizen.</p>
                                                                    <a  href="https://island.esf.edu.hk/en/outstanding_people/parent-teacher-student_association/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/d5a5381383e69334176b4fffddb5ebb3.png" alt="Incredible Results" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Greater Heights of Achievement</h3>
                            <div class="overlay bg-colour1">
                                <p>At Island School, we provide a nurturing environment where your child can excel, with a 98% IBDP pass rate and 34% achieving over 40 points.</p>
                                                                    <a  href="https://island.esf.edu.hk/en/outstanding_education/student_success/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/25275dc86f564b8d43cada22a67d8766.png" alt="SIS offers icon-6" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">ESF Network</h3>
                            <div class="overlay bg-colour1">
                                <p>As part of the English Schools Foundation(ESF), our students are supported by the largest English-medium international school organisation in Hong Kong, providing them the resources and opportunities not found outside of ESF Schools.</p>
                                                                    <a  href="https://island.esf.edu.hk/en/about_us/ESF_family/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                            </ul>
        </div>
    </div>
    <script type="text/javascript">
        $(window).load(function() {
            $('h3', '#section2').each(function() {
                let img = $(this).parent().children('img');
                if(img.length) {
                    $(this).css('top', img.offset().top + img.height() + 25 - $(this).parent().offset().top);
                }
            });
        });
    </script>
</section>
<section id="section3">
    <img src="/cache/img/a52b0d108e00cfbf6332b9ce48cd9eee.jpg" alt="islandschool_esf_7684" loading="lazy" width="1722" height="1294" />    <div class="wrapper">
        <div class="section-title-container">
            <div class="section-title">
                <h2 class="colour2">International Curriculum</h2>
                <span class="bg-colour1"></span>
            </div>
        </div>
        <div class="tabs">
                            <button class="tab current" data-id="1">Years 7-9</button>
                            <button class="tab" data-id="2">Years 10-11</button>
                            <button class="tab" data-id="3">Years 12-13</button>
                    </div>
        <select class="tab-select" name="tab"><option value="1">Years 7-9</option><option value="2">Years 10-11</option><option value="3">Years 12-13</option></select>                    <div class="tab-content current" data-id="1">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Years 7-9 Curriculum</h3>
                    </div>
                                <article class="editor"><p>Our curriculum engages your child, nurturing their love of learning to develop responsible, creative, analytical thinkers. We follow the <strong>IB Middle Years Programme (MYP)</strong>, offering a wide range of subjects until Year 9, allowing your child to discover new strengths and interests that will inform their iGCSE choices.</p></article>
                                    <a href="https://island.esf.edu.hk/en/outstanding_education/academic_curriculum/curriculum_overview/years-7-9/">
                        <span>Learn More</span>
                    </a>
                            </div>
                    <div class="tab-content" data-id="2">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Years 10-11 Curriculum</h3>
                    </div>
                                <article class="editor"><p><span style="font-weight: 400;">In Years 10-11, our <strong>iGCSE</strong> curriculum prepares your child academically, while the Futures Curriculum develops their skills and interests, equipping them for the pathways available in Years 12-13 and beyond.</span></p></article>
                                    <a href="https://island.esf.edu.hk/en/outstanding_education/academic_curriculum/curriculum_overview/years-10-11/">
                        <span>Learn More</span>
                    </a>
                            </div>
                    <div class="tab-content" data-id="3">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Years 12-13 Curriculum</h3>
                    </div>
                                <article class="editor"><p><span style="font-weight: 400;">In Years 12-13, your child can pursue the <strong>IB Diploma</strong> or <strong>IB Careers Programme</strong>. Beyond academics, they'll lead diverse school initiatives, from humanitarian to artistic, as Student Council members, House Prefects, and Ambassadors - shaping the school community.</span></p></article>
                                    <a href="https://island.esf.edu.hk/en/outstanding_education/academic_curriculum/curriculum_overview/years-12-13/">
                        <span>Learn More</span>
                    </a>
                            </div>
                <script type="text/javascript">
            $(document).ready(function() {
                $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();

                $('.tab', '#section3').click(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $(this).addClass('current');
                    $('.tab-content[data-id=' + $(this).data('id') + ']', '#section3').addClass('current');
                    $('select', '#section3').val($(this).data('id')).selectbox('refresh');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });

                $('.tab-select', '#section3').change(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $('.tab[data-id=' + $(this).val() + ']').addClass('current');
                    $('.tab-content[data-id=' + $(this).val() + ']', '#section3').addClass('current');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });
            });
        </script>
    </div>
</section>
<section id="section4" data-total="4">
    <div class="container">
        <div class="bg bg-colour4"></div>
        <div class="section-title-container">
            <div class="section-title">
                <h2 class="colour2">Student Support</h2>
                <span class="bg-colour1"></span>
            </div>
        </div>
        <div class="record-slider">
            <div class="slider-container">
                                    <div class="record-item">
                        <img src="/cache/img/d8f16e694258e6d71dcfb80d47c605e2.jpg" alt="IMG_9746 (1)" loading="lazy" width="1070" height="802" />                        <div class="overlay">
                            <div class="bg-colour2"></div>
                            <h3>
                                <span>WELL-BEING</span>
                            </h3>
                            <p>At Island School, your child's wellbeing is our top priority. From exploring identity and self-esteem in Years 7-8, to specialised lessons on relationships, drugs, and life skills, we equip your child with the knowledge and tools to manage their lives. Wellbeing is embedded in our curriculum and community.</p>
                                                            <a href="https://island.esf.edu.hk/en/outstanding_education/student_support_wellbeing/">
                                    <span>Learn More</span>
                                </a>
                                                    </div>
                    </div>
                                    <div class="record-item">
                        <img src="/cache/img/4390014a1729267f8b5830377229239c.jpg" alt="IMG_3391-1 (1)" loading="lazy" width="1070" height="802" />                        <div class="overlay">
                            <div class="bg-colour2"></div>
                            <h3>
                                <span>FAMILY SUPPORT STRUCTURE</span>
                            </h3>
                            <p>We encourage open communication between parents and our dedicated Guidance Team to ensure your child's wellbeing. Our counsellors provide confidential support, and our child protection policies prioritise your child's safety and right to learn in a nurturing environment.</p>
                                                            <a href="https://island.esf.edu.hk/en/outstanding_education/student_support_wellbeing/">
                                    <span>Learn More</span>
                                </a>
                                                    </div>
                    </div>
                                    <div class="record-item">
                        <img src="/cache/img/0f2a78c919918824baf927c31a16975c.jpg" alt="IMG_4330" loading="lazy" width="1070" height="802" />                        <div class="overlay">
                            <div class="bg-colour2"></div>
                            <h3>
                                <span>TUTORS</span>
                            </h3>
                            <p>At Island School, our tutors go beyond just teaching - they mentor and motivate your child to reach their full potential. Through their expertise and dedication, our tutors create a supportive environment where your child feels empowered to ask questions, clarify doubts, and receive tailored guidance for academic success.</p>
                                                            <a href="https://island.esf.edu.hk/en/outstanding_people/our_team/">
                                    <span>Learn More</span>
                                </a>
                                                    </div>
                    </div>
                                    <div class="record-item">
                        <img src="/cache/img/bb87f196c7a3478edfccfd0d15d02157.jpg" alt="IMG_8000-1" loading="lazy" width="1070" height="802" />                        <div class="overlay">
                            <div class="bg-colour2"></div>
                            <h3>
                                <span>THRIVE PROGRAMME</span>
                            </h3>
                            <p>At Island School, we embrace wellbeing as a core part of your child's education, helping them thrive and build resilience. Our Thrive program, guided by our school values, nurtures your child's physical, social, cognitive, and emotional wellbeing - ensuring their holistic development and ability to overcome challenges.</p>
                                                            <a href="https://island.esf.edu.hk/en/outstanding_experiences/experiential_learning/">
