                                                    <h3>Angela, Class of 2023</h3>
                                                </div>
                                                                                    </div>
                                    </div>
                                                                    <div class="record-item">
                                        <div class="left">
                                            <div class="thumbnail bg-colour1">
                                                <span></span>
                                                <img src="/cache/img/f4679ca16210b1e779935706fdc6e179.jpg" alt="" loading="lazy" width="548" height="548" />                                            </div>
                                                                                            <div class="slider-pager">
                                                    <button class="prev"></button>
                                                    <span>2 / 3</span>
