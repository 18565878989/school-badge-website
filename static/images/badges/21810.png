        left: -2%;
        height: 100%;
        opacity: 0.5;
        -moz-transition: opacity .3s .02s ease;
        -o-transition: opacity .3s .02s ease;
        -webkit-transition: opacity .3s .02s ease;
        outline: 0!important;
    }
    .banner-content .banner-img-right {
        position: absolute;
        right: -2%;
        height: 100%;
        -moz-transition: opacity .3s .02s ease;
        -o-transition: opacity .3s .02s ease;
        -webkit-transition: opacity .3s .02s ease;
        outline: 0!important;
        opacity: 0.5;
    }
    .timer__container {
        padding: 24px 0;
