	<script type="text/javascript">
		$.extend( true, $.fn.dataTable.defaults, {
			responsive: true,
			language:{
				"processing": "Подождите...",
				"search": "Поиск:",
				"lengthMenu": "Показать _MENU_ записей",
				"info": "Записи с _START_ по _END_ из _TOTAL_ записей",
