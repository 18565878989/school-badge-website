				"infoFiltered": "(отфильтровано из _MAX_ записей)",
				"infoPostFix": "",
				"loadingRecords": "Загрузка записей...",
				"zeroRecords": "Записи отсутствуют.",
				"emptyTable": "В таблице отсутствуют данные",
				"paginate": {
					"first": "Первая",
					"previous": "Предыдущая",
					"next": "Следующая",
					"last": "Последняя"
				},
				"aria": {
					"sortAscending": ": активировать для сортировки столбца по возрастанию",
					"sortDescending": ": активировать для сортировки столбца по убыванию"
				}
			}

		});
		$.fn.dataTable.render.ellipsis = function () {
			return function ( data, type, row ) {
				return type === 'display' && data.length > 10 ?
				data.substr( 0, 140 ) +'…' :
				data;
			}
		};
		$(document).ready(function() {
			$('.pgwSlider').pgwSlider({
				listPosition: 'left',
				selectionMode: 'mouseOver',
				transitionDuration: 250
			});
			$('#obr1,#obr2,#eduOp-table').dataTable({
				rowGroup: {
					dataSrc:0 
				},
				columnDefs:[{targets:0, visible:false}]
			});
			$('#logic-sup-2').dataTable({
//            columnDefs:[{targets:-1, render: $.fn.dataTable.render.ellipsis()}]
});

			$('.dataTable').DataTable();
		});
	</script>
	<script type="text/javascript">
		$(document).ready(function() {
            if (window.location.href.indexOf('/science/dissertation-tips/the-thesis/') > -1){
                $('#j-calendar').calendarLite(window.calendar_obj);
            } else if (window.location.href.indexOf('/science/scientific-events/') > -1){
                $('#j-calendar').calendarLite(window.calendar_obj);
            } else {
                $('#j-calendar').calendarLite({
                    showYear: true,
                    linkFormat: '/?date={%yyyy}-{%mm}-{%dd}'
                });
            }

			$('.schol-item .white-block .display-table').hover(function(){
				var desc = $(this);
				setTimeout(function(){
					if(desc.is(':hover'))
					{
						desc.closest('.white-block').addClass('before_log');
						desc.next('.desc-block-school').css({'display' : 'block'});
					}
				}, 400)
			}, function(){
				var desc = $(this);
				desc.closest('.white-block').removeClass('before_log');
				desc.next('.desc-block-school').css({'display' : 'none'});
			});
		});
	</script>

	

