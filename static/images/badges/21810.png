    .banner__link:hover {
        text-decoration: none;
    }
    .banner__link:hover .banner-img-left,
    .banner__link:hover .banner-img-right {
        opacity: 1;
        -moz-transition: opacity .3s .02s ease;
        -o-transition: opacity .3s .02s ease;
        -webkit-transition: opacity .3s .02s ease;
        outline: 0!important;
    }
</style>
