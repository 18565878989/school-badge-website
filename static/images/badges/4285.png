                                        <div class="left">
                                            <div class="thumbnail bg-colour1">
                                                <span></span>
                                                <img src="/cache/img/c02ebae2b10271c72a3f5efa3cd0dc5c.jpg" alt="Clearwater Bay-Michael Dewey(1000x1000)" loading="lazy" width="548" height="548" />                                            </div>
                                                                                            <div class="slider-pager">
