	<section id="content">		
		<script type="text/javascript">
    var timeout = [];

    $(window).load(function() {
		let animate = function() {
			let height = $(window).scrollTop() + Math.round($(window).height() * 0.6);
			$('#content > section').each(function() {
				if(!$(this).hasClass('animate') && height > $(this).offset().top)
				{
					$(this).addClass('animate');
                    if($(this).attr('id') == 'section2') {
						$('li > div', '#section2').each(function(index) {
							let item = $(this);
							setTimeout(function() {
								item.addClass('animate');
							}, index * 200);
						});
					}
				}
			});
		};
		$(window).on('scroll', animate);
		animate();
	});
</script>
<div id="banner">
    <div class="banner-container">
                                                <div class="banner-item">
                    <div class="wrapper">
                        <img src="/cache/img/70f2b5b4e9b8e18b465accef6bb96abe.png" alt="" loading="lazy" width="1904" height="1200" class="trans" />                        <video id="video" width="1904" height="1200" preload="none" playsinline webkit-playsinline muted loop>
                            <source src="/upload/banner/1/banner/671fbcfd44505.mp4" type="video/mp4">
                        </video>
                        <div class="mask"></div>
                        <div class="container">
                            <button class="play"></button>
                        </div>
                    </div>
                                    </div>
                        </div>
    <div class="container">
                <div class="scroll-icon"></div>
    </div>
    <script type="text/javascript">
        $(document).ready(function() {
            let pager_click = false;

            $('#banner').Slider({
                slides: '.banner-item',
                maxSlide: 1,
                swipeControl: true,
                skipBoundary: true,
                infiniteLoop: true,
                pager: '.banner-pager',
                afterSlide: function(slider, slides, current_page, total_page) {
                    $.each(timeout, function(index, value) {
                        clearTimeout(value);
                    });
                    let videos = $('video', slider);
                    videos.each(function(i, video) {
                        video.pause();
                        video.currentTime = 0;
                    });
                    $('button', slider).removeClass('play').addClass('pause');
                    if($('.slider.current video', slider).length) {
                                                        video = document.querySelector('#banner .slider.current video');
                                video.play();
                                            }
                    else if(!pager_click) {
                        timeout = setTimeout(function() {
                            slider.Slider('next');
                        }, 5000);
                    }
                },
                afterResize: function(slider, slides, current_page, total_page) {
                    if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                },
                afterInit: function(slider, slides, current_page, total_page) {
                                        if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                }
            });
            
            $('.banner-item video', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                let button = $(this).parent().find('button');
                if(button.hasClass('pause')) {
                    video.pause();
                    button.removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    button.removeClass('play').addClass('pause');
                }
            });
            $('.banner-item button', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                if($(this).hasClass('pause')) {
                    video.pause();
                    $(this).removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    $(this).removeClass('play').addClass('pause');
                }
            });

            $('body').on('click', '#banner .banner-pager a', function() {
                pager_click = true;
            });

            function videoEnd(e) {
                if(!pager_click) {
                    $('#banner').Slider('next');
                }
                else {
                    $('#banner .slider.current button').removeClass('pause').addClass('play');
                }
            }
        });
    </script>
</div>
<section id="section1">
    <div class="container">
                    <div class="left">
                <article class="editor"><h3 class="homepage-title title">TO SEEK</h3>
<h3 class="homepage-title">TO SERVE</h3>
<h3 class="homepage-title">TO STRIVE</h3></article>
            </div>
                            <div class="right">
                <article class="editor"><p><span style="font-size: 18px;">Renaissance College Hong Kong (RCHK) is a student-centred independent school. Through a rigorous and holistic curriculum, the college develops global citizens who strive for excellence, appreciate the aesthetics and are empowered to take progressive action.</span></p>
<p>&nbsp;</p>
<p><span style="font-size: 18px;">RCHK strives to build a culture that promotes peace and democracy, values diversity and works towards a sustainable future for all.</span></p>
<p>&nbsp;</p>
<p>&nbsp;</p>
<p class="rounded_title bg-colour1"><span style="color: #ffffff; font-size: 18px;"><a style="color: #ffffff;" title="What we stand for" href="https://rchk.esf.edu.hk/en/about_us/what_we_stand_for/" target="_blank" rel="noopener">What we stand for</a></span></p></article>
            </div>
                            <div class="responsive">
                <article class="editor"><h3 class="homepage-title title">TO SEEK</h3>
<h3 class="homepage-title">TO SERVE</h3>
<h3 class="homepage-title">TO STRIVE</h3>
<p>&nbsp;</p>
<p>&nbsp;</p>
<p><span style="font-size: 18px;">Renaissance College Hong Kong (RCHK) is a student-centred independent school. Through a rigorous and holistic curriculum, the college develops global citizens who strive for excellence, appreciate the aesthetics and are empowered to take progressive action.</span></p>
<p>&nbsp;</p>
<p><span style="font-size: 18px;">RCHK strives to build a culture that promotes peace and democracy, values diversity and works towards a sustainable future for all.</span></p>
<p>&nbsp;</p>
<p>&nbsp;</p>
<p class="rounded_title bg-colour1"><span style="color: #ffffff; font-size: 18px;"><a style="color: #ffffff;" title="What we stand for" href="https://rchk.esf.edu.hk/en/about_us/what_we_stand_for/" target="_blank" rel="noopener">What we stand for</a></span></p></article>
            </div>
            </div>
</section>
<section id="section2">
    <div class="container">
        <div class="section-title">
            <h2 class="colour2">What can RCHK offer to your family?</h2>
            <span class="bg-colour1"></span>
        </div>
    </div>
    <div class="wrapper bg-colour2">
        <div class="container">
            <ul>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/81a4bad8626d2d25b47a84087315c874.png" alt="All-through Education" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">All-through Education</h3>
                            <div class="overlay bg-colour1">
                                <p>A world-class English education from Year 1 to Year 13 on one campus. As an International Baccalaureate (IB) World School, we are among the few globally authorized to offer all four IB programmes: PYP, MYP, DP, and CP.</p>
                                                                    <a  href="https://rchk.esf.edu.hk/en/outstanding_education/curriculum/curriculum_overview">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/41300f8638092f276dfc29cde4405a71.png" alt="Incredible Results" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Scholarship Opportunities</h3>
                            <div class="overlay bg-colour1">
                                <p>We are proud to offer a wide range of scholarships to deserving students who can share their unique talents with the community while receiving the benefits of a world-class education.</p>
                                                                    <a  href="https://rchk.esf.edu.hk/en/admissions/Scholarships/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/617ee1253b03524505a7697ce69ca1ff.png" alt="Real-world Experience" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Real-world Experience</h3>
                            <div class="overlay bg-colour1">
                                <p>Education Outside the Classroom is central to our curriculum, helping students build confidence and resilience through work placements, NGO collaborations, camps, and international competitions.</p>
                                                                    <a  href="https://rchk.esf.edu.hk/en/outstanding_education/Co-Curricular/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/66c7fe7615202553c1ae4a92f9329a2e.png" alt="Real-world Experience" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Sports Programmes</h3>
                            <div class="overlay bg-colour1">
                                <p>Our athletic programmes include Black Kites and House Sports, and participation in local and international competitions, which are some of the opportunities for students to challenge themselves and to thrive in various disciplines.</p>
                                                                    <a  href="https://rchk.esf.edu.hk/en/outstanding_education/Co-Curricular/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/41644b51ea10cbedeaf3adda8384fee2.png" alt="Comprehensive Student Support" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Safeguarding</h3>
                            <div class="overlay bg-colour1">
                                <p>Wellbeing is at the heart of RCHK. We have strategies in place for every child to feel known and seen in the school community.</p>
                                                                    <a  href="https://rchk.esf.edu.hk/en/about_us/wellbeing/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/ac6c31818dd21d47a5b6f3b124bf00bc.png" alt="SIS offers icon-6" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">ESF Network</h3>
                            <div class="overlay bg-colour1">
                                <p>As part of the English Schools Foundation(ESF), our students are supported by the largest English-medium international school organisation in Hong Kong, providing them the resources and opportunities not found outside of ESF Schools.</p>
                                                                    <a  href="https://rchk.esf.edu.hk/en/about_us/ESF_family/">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                            </ul>
        </div>
    </div>
    <script type="text/javascript">
        $(window).load(function() {
            $('h3', '#section2').each(function() {
                let img = $(this).parent().children('img');
                if(img.length) {
                    $(this).css('top', img.offset().top + img.height() + 25 - $(this).parent().offset().top);
                }
            });
        });
    </script>
</section>
<section id="section3">
    <img src="/cache/img/23c4810499c0d1d41d528ea28bc29197.jpg" alt="renaissance_0931_design RCHK Secondary" loading="lazy" width="1722" height="1294" />    <div class="wrapper">
        <div class="section-title-container">
            <div class="section-title">
                <h2 class="colour2">International Curriculum</h2>
                <span class="bg-colour1"></span>
            </div>
        </div>
        <div class="tabs">
                            <button class="tab current" data-id="1">Years 1-6 | PYP</button>
                            <button class="tab" data-id="2">Years 7-11 | MYP</button>
                            <button class="tab" data-id="3">Years 12-13 | DP / CP</button>
                    </div>
        <select class="tab-select" name="tab"><option value="1">Years 1-6 | PYP</option><option value="2">Years 7-11 | MYP</option><option value="3">Years 12-13 | DP / CP</option></select>                    <div class="tab-content current" data-id="1">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Ages 5 - 10</h3>
                    </div>
                                <article class="editor"><p><span style="font-size: 18px;"><span style="font-weight: 400;">In <strong>Years 1 to 6</strong>, Renaissance College offers the</span><strong> IB Primary Years Programme (PYP) </strong><span style="font-weight: 400;">that</span><strong> </strong><span style="font-weight: 400;">focuses on the total growth of the developing child, touching hearts as well as minds. It meets students&rsquo; social, physical, emotional and cultural needs in addition to academic development.</span></span></p>
<p>&nbsp;</p>
<section>
<article class="editor">
<p class="rounded_title bg-colour1"><span style="color: #ffffff; font-size: 18px;"><a style="color: #ffffff;" title="Our Curriculum" href="https://rchk.esf.edu.hk/en/outstanding_education/curriculum/" target="_blank" rel="noopener">Learn more</a></span></p>
<p>&nbsp;</p>
<p>&nbsp;</p>
</article>
</section></article>
                            </div>
                    <div class="tab-content" data-id="2">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Ages 11 - 16</h3>
                    </div>
                                <article class="editor"><p><span style="font-size: 18px;"><span style="font-weight: 400;">Renaissance College's <strong>Years 7 to 11</strong> follow the</span><strong> IB Middle Years Programme (MYP)</strong><span style="font-weight: 400;">. It provides a comprehensive curriculum framework of academic challenge that enables students to embrace the connections between traditional subjects and the world in which they live through the process of inquiry.</span></span></p>
<section>
<article class="editor">
<p>&nbsp;</p>
<p class="rounded_title bg-colour1"><span style="color: #ffffff; font-size: 18px;"><a style="color: #ffffff;" title="Our Curriculum" href="https://rchk.esf.edu.hk/en/outstanding_education/curriculum/" target="_blank" rel="noopener">Learn more</a></span></p>
<p>&nbsp;</p>
<p>&nbsp;</p>
</article>
</section></article>
                            </div>
                    <div class="tab-content" data-id="3">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Ages 17 - 18</h3>
                    </div>
                                <article class="editor"><p><span style="font-size: 18px;"><span style="font-weight: 400;">In Years 12 and 13, Renaissance College offers two pathways, </span><strong>the IB Diploma Programme (IBDP) and the IB Career-related Programme (IBCP)</strong><span style="font-weight: 400;">, to give students agency in their studies based on their learning style and aspirations, while fostering a well-rounded and global-minded outlook through leadership and community involvement.</span></span></p>
<section>
<article class="editor">
<p>&nbsp;</p>
<p class="rounded_title bg-colour1"><span style="color: #ffffff; font-size: 18px;"><a style="color: #ffffff;" title="Our Curriculum" href="https://rchk.esf.edu.hk/en/outstanding_education/curriculum/" target="_blank" rel="noopener">Learn more</a></span></p>
<p>&nbsp;</p>
<p>&nbsp;</p>
</article>
</section></article>
                            </div>
                <script type="text/javascript">
            $(document).ready(function() {
                $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();

                $('.tab', '#section3').click(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $(this).addClass('current');
                    $('.tab-content[data-id=' + $(this).data('id') + ']', '#section3').addClass('current');
                    $('select', '#section3').val($(this).data('id')).selectbox('refresh');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });

                $('.tab-select', '#section3').change(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $('.tab[data-id=' + $(this).val() + ']').addClass('current');
                    $('.tab-content[data-id=' + $(this).val() + ']', '#section3').addClass('current');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });
            });
        </script>
    </div>
</section>
