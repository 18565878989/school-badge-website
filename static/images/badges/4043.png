	<section id="content">		
		<script type="text/javascript">
    var timeout = [];

    $(window).load(function() {
		let animate = function() {
			let height = $(window).scrollTop() + Math.round($(window).height() * 0.6);
			$('#content > section').each(function() {
				if(!$(this).hasClass('animate') && height > $(this).offset().top)
				{
					$(this).addClass('animate');
                    if($(this).attr('id') == 'section2') {
						$('li > div', '#section2').each(function(index) {
							let item = $(this);
							setTimeout(function() {
								item.addClass('animate');
							}, index * 200);
						});
					}
				}
			});
		};
		$(window).on('scroll', animate);
		animate();
	});
</script>
<div id="banner">
    <div class="banner-container">
                                                <div class="banner-item">
                    <div class="wrapper">
                        <img src="/cache/img/086427112df73e6282a8179661fa732f.png" alt="" loading="lazy" width="1904" height="1200" class="trans" />                        <video id="video" width="1904" height="1200" preload="none" playsinline webkit-playsinline muted loop>
                            <source src="/upload/banner/1/banner/671fb0b6cfdcf.mp4" type="video/mp4">
                        </video>
                        <div class="mask"></div>
                        <div class="container">
                            <button class="play"></button>
                        </div>
                    </div>
                                    </div>
                        </div>
    <div class="container">
                <div class="scroll-icon"></div>
    </div>
    <script type="text/javascript">
        $(document).ready(function() {
            let pager_click = false;

            $('#banner').Slider({
                slides: '.banner-item',
                maxSlide: 1,
                swipeControl: true,
                skipBoundary: true,
                infiniteLoop: true,
                pager: '.banner-pager',
                afterSlide: function(slider, slides, current_page, total_page) {
                    $.each(timeout, function(index, value) {
                        clearTimeout(value);
                    });
                    let videos = $('video', slider);
                    videos.each(function(i, video) {
                        video.pause();
                        video.currentTime = 0;
                    });
                    $('button', slider).removeClass('play').addClass('pause');
                    if($('.slider.current video', slider).length) {
                                                        video = document.querySelector('#banner .slider.current video');
                                video.play();
                                            }
                    else if(!pager_click) {
                        timeout = setTimeout(function() {
                            slider.Slider('next');
                        }, 5000);
                    }
                },
                afterResize: function(slider, slides, current_page, total_page) {
                    if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                },
                afterInit: function(slider, slides, current_page, total_page) {
                                            let videos = $('video', slider);
                        videos.each(function(i, video) {
                            video.addEventListener('ended', videoEnd, false);
                        });
                        if($('.slider.current video', slider).length) {
                                                                video = document.querySelector('#banner .slider.current video');
                                    video.play();
                                    $('.slider.current button', slider).removeClass('play').addClass('pause');
                                                    }
                        else {
                            timeout = setTimeout(function() {
                                slider.Slider('next');
                            }, 5000);
                        }
                                        if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                }
            });
            
            $('.banner-item video', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                let button = $(this).parent().find('button');
                if(button.hasClass('pause')) {
                    video.pause();
                    button.removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    button.removeClass('play').addClass('pause');
                }
            });
            $('.banner-item button', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                if($(this).hasClass('pause')) {
                    video.pause();
                    $(this).removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    $(this).removeClass('play').addClass('pause');
                }
            });

            $('body').on('click', '#banner .banner-pager a', function() {
                pager_click = true;
            });

            function videoEnd(e) {
                if(!pager_click) {
                    $('#banner').Slider('next');
                }
                else {
                    $('#banner .slider.current button').removeClass('pause').addClass('play');
                }
            }
        });
    </script>
</div>
<section id="section1">
    <div class="container">
                    <div class="left">
                <article class="editor"><h3 class="homepage-title title" style="line-height: 44px;"><span style="font-size: 32px;"><strong>A learning community working together to develop internationally minded students who act to make a better world.</strong></span></h3>
<p>&nbsp;</p>
<p class="rounded_border_title"><a class="colour1" href="https://cwbs.esf.edu.hk/en/about_us/what_we_stand_for/">Discover Our Vision</a></p>
<p>&nbsp;</p></article>
            </div>
                            <div class="right">
                <article class="editor"><p><img class="round-border" src="https://cwbs.esf.edu.hk/upload/page/35/self/6758f693df4b6.jpg" width="359" height="479" /></p></article>
            </div>
                            <div class="responsive">
                <article class="editor"><h3 class="homepage-title title" style="line-height: 31px;"><span style="font-size: 28px;"><strong>A learning community working together to develop internationally minded students who act to make a better world.</strong></span></h3>
<p>&nbsp;</p>
<p><img class="round-border" src="https://cwbs.esf.edu.hk/upload/page/35/self/6758f693df4b6.jpg" width="359" height="479" /></p>
<p>&nbsp;</p>
<p class="rounded_border_title"><a class="colour1" href="https://cwbs.esf.edu.hk/en/about_us/what_we_stand_for/">Discover Our Vision</a></p></article>
            </div>
            </div>
</section>
<section id="section2">
    <div class="container">
        <div class="section-title">
            <h2 class="colour2">What can Clearwater Bay School offer your family?</h2>
            <span class="bg-colour1"></span>
        </div>
    </div>
    <div class="wrapper bg-colour2">
        <div class="container">
            <ul>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/96d5a2dcef893b4ad12d5a54a9d26b38.png" alt="ESF_Logomark_BW_RGB" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">ESF Network</h3>
                            <div class="overlay bg-colour1">
                                <p>As part of the English Schools Foundation(ESF), our students are supported by the largest English-medium international school organisation in Hong Kong, providing them the resources and opportunities not found outside of ESF Schools.</p>
                                                                    <a  href="https://cwbs.esf.edu.hk/en/about_us/marketing_family/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/8df7472f9c56b187012744012f549d43.png" alt="World-class Education" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">World-class Education</h3>
                            <div class="overlay bg-colour1">
                                <p>At Clearwater Bay School, we provide a world-class education that is renowned for its academic excellence and rigorous curriculum. Our dedicated teachers and staff ensure that every student receives the best possible learning experience.</p>
                                                                    <a  href="https://cwbs.esf.edu.hk/en/outstanding_education/our_approach/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/1ddd1eb4c9079fc2271f145232c7a1f1.png" alt="Strong Community Network" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Caring, Connected Community</h3>
                            <div class="overlay bg-colour1">
                                <p>CWBS immerses you in a vibrant community of students, parents, teachers, and alumni. We prioritize strong partnerships with families, encouraging active parental involvement and open communication to ensure parents feel engaged in their child's educational journey. Together, we create an environment where lifelong friendships and meaningful experiences thrive.</p>
                                                                    <a  href="https://cwbs.esf.edu.hk/en/outstanding_people/parent_teacher_association/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/9efda214b723f9f696c62d57f1ac0129.png" alt="Multicultural Environment" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Multicultural Environment</h3>
                            <div class="overlay bg-colour1">
                                <p>Our school embraces diversity and creates a multicultural environment where students from different backgrounds come together to learn and grow. We celebrate cultural differences, promote inclusivity, and prepare students to thrive in a globalised world.</p>
                                                                    <a  href="https://cwbs.esf.edu.hk/en/about_us/what_we_stand_for/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/bc15d724a1de48fef2572139ec8ec3ef.png" alt="Comprehensive Student Support" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Comprehensive Student Support</h3>
                            <div class="overlay bg-colour1">
                                <p>We believe in nurturing the holistic development of our students. Our school offers comprehensive support systems, including personalised guidance, pastoral care, and counselling services, to help students thrive academically, emotionally, and socially.</p>
                                                                    <a  href="https://cwbs.esf.edu.hk/en/outstanding_education/student_support_wellbeing/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/275a871d673e7c757f11edaf80f87d1a.png" alt="Real-world Experience" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Innovative Teaching Methods</h3>
                            <div class="overlay bg-colour1">
                                <p>Our dedicated teachers employ innovative teaching methods and leverage the latest educational technologies to enhance learning. We strive to create dynamic and engaging classrooms that inspire creativity, critical thinking, and problem-solving skills.</p>
                                                                    <a  href="https://cwbs.esf.edu.hk/en/outstanding_education/specialist_provision/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                            </ul>
        </div>
    </div>
    <script type="text/javascript">
        $(window).load(function() {
            $('h3', '#section2').each(function() {
                let img = $(this).parent().children('img');
                if(img.length) {
                    $(this).css('top', img.offset().top + img.height() + 25 - $(this).parent().offset().top);
                }
            });
        });
    </script>
</section>
<section id="section3">
    <img src="/cache/img/cdc0fa23d7223241d2f30087e6115352.jpg" alt="clearwaterbay_school_5439" loading="lazy" width="1722" height="1294" />    <div class="wrapper">
        <div class="section-title-container">
            <div class="section-title">
                <h2 class="colour2">Primary Years Programme (PYP)</h2>
                <span class="bg-colour1"></span>
            </div>
        </div>
        <div class="tabs">
                            <button class="tab current" data-id="1">Years 1 - 6</button>
                    </div>
                            <div class="tab-content current" data-id="1">
                                <article class="editor"><p><span style="font-weight: 400;">Clearwater Bay School follows the</span><strong> IB Primary Years Programme (PYP)</strong><span style="font-weight: 400;">. It is an international, transdisciplinary program designed to foster the development of the whole child, both in the classroom and in the world outside. The program focuses on students&rsquo; intellectual, social, emotional, and physical development.</span><span style="font-weight: 400;"><br /></span></p></article>
                                    <a href="https://cwbs.esf.edu.hk/en/outstanding_education/curriculum/">
                        <span>Find out more</span>
                    </a>
                            </div>
                <script type="text/javascript">
            $(document).ready(function() {
                $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();

                $('.tab', '#section3').click(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $(this).addClass('current');
                    $('.tab-content[data-id=' + $(this).data('id') + ']', '#section3').addClass('current');
                    $('select', '#section3').val($(this).data('id')).selectbox('refresh');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });

                $('.tab-select', '#section3').change(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $('.tab[data-id=' + $(this).val() + ']').addClass('current');
                    $('.tab-content[data-id=' + $(this).val() + ']', '#section3').addClass('current');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });
            });
        </script>
    </div>
</section>
<section id="section4" data-total="3">
    <div class="container">
        <div class="bg bg-colour4"></div>
        <div class="section-title-container">
            <div class="section-title">
                <h2 class="colour2">CWBS Experience</h2>
                <span class="bg-colour1"></span>
            </div>
        </div>
        <div class="record-slider">
            <div class="slider-container">
