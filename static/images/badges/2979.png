<script>
    (function() {
        // 更新滾動狀態
        function updateScroll() {
            var header = document.getElementById('sjc-main-header');
            if (header) {
                var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
                if (scrollTop > 50) {
                    header.classList.add('is-scrolled');
                } else {
                    header.classList.remove('is-scrolled');
                }
            }
        }
        window.addEventListener('scroll', updateScroll);

        document.addEventListener("DOMContentLoaded", function() {
            var header = document.getElementById('sjc-main-header');
            if (header && document.body) { document.body.prepend(header); }

            // 手機版漢堡選單的開關邏輯
            var mobileToggle = document.querySelector('.sjc-mobile-toggle');
            var menuItems = document.querySelector('.sjc-menu-items');
            if (mobileToggle && menuItems) {
                mobileToggle.addEventListener('click', function() {
                    menuItems.classList.toggle('is-mobile-open');
                });
            }

            function terminateBadElements() {
                var candidates = document.querySelectorAll('h1, h2, h3, .page-title, .entry-title');
                candidates.forEach(function(el) {
                    if (el.textContent && el.textContent.includes('Protected:')) {
                        var container = el.closest('header, .page-header, .page-header-bg, .superb-hero, section');
                        if (container && container.id !== 'sjc-main-header') {
                            container.style.display = 'none'; 
                        } else {
                            el.style.display = 'none'; 
                            if(el.parentElement) el.parentElement.style.display = 'none';
                        }
                    }
                });
                var headers = document.getElementsByTagName('header');
                for (var i = 0; i < headers.length; i++) {
                    if (headers[i].id !== 'sjc-main-header') { headers[i].style.display = 'none'; }
                }
                var oldNavs = document.querySelectorAll('.superb-navigation, .main-navigation, #site-navigation');
                oldNavs.forEach(function(nav) { nav.style.display = 'none'; });
            }

            var intervalId = setInterval(terminateBadElements, 100);
            setTimeout(function() { clearInterval(intervalId); }, 3000);
            terminateBadElements();
        });
    })();
</script></header>


