    document.addEventListener("DOMContentLoaded", function() {
        var footer = document.getElementById('sjc-main-footer');
        if (footer && document.body) {
            document.body.appendChild(footer);
        }
        var oldFooters = document.querySelectorAll('footer:not(#sjc-main-footer), .site-footer, #colophon, .superb-footer, .elementor-location-footer');
        oldFooters.forEach(function(el) { el.style.display = 'none'; });
    });
