<footer class="wp-block-template-part"><style>
    /* =================================================================
       PART A: 核心樣式與全寬設定
       ================================================================= */
    
    :root {
        --sjc-footer-bg: #0d2546; /* 深海軍藍 */
        --sjc-footer-text: #ffffff; /* 強制純白文字 */
        --sjc-gold: #C5A059;
        --sjc-blue-accent: #2D8FCE;
    }

    body, html {
        margin: 0 !important;
        padding: 0 !important;
        overflow-x: hidden !important;
    }

    /* 隱藏原本主題的 Footer */
    footer:not(#sjc-main-footer), .site-footer, #colophon, .superb-footer, .elementor-location-footer {
        display: none !important;
    }

    /* ★ 關鍵修復：確保 Footer 內部所有元素寬高計算包含 padding，避免手機版撐破螢幕 */
    #sjc-main-footer, #sjc-main-footer * {
        box-sizing: border-box;
    }

    /* SJC Footer 主容器 */
    #sjc-main-footer {
        background-color: var(--sjc-footer-bg) !important;
        color: var(--sjc-footer-text) !important;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        padding: 50px 0 30px 0;
        position: relative;
        font-size: 0.95rem;
        line-height: 1.6;
        border-top: 5px solid var(--sjc-gold);
        
        /* ★ 關鍵修復：將 100vw 改為 100%，防止手機出現橫向捲軸 */
        width: 100% !important; 
        max-width: 100% !important;
        margin-left: 0 !important;
        margin-right: 0 !important;
        left: 0 !important;
        z-index: 999;
    }

    /* 使用 Flexbox 替代 Grid，解決欄位消失問題 */
    .sjc-footer-container {
        max-width: 1300px;
        width: 100%;
        margin: 0 auto;
        padding: 0 40px;
        display: flex;
        flex-wrap: wrap; /* 允許換行 */
        justify-content: space-between;
        gap: 40px;
    }

    /* =================================================================
       PART B: 各欄位設定 (Flexbox)
       ================================================================= */

    /* 1. 品牌欄位 (Logo) - 佔比較寬 */
    .sjc-footer-brand {
        flex: 2 1 350px; /* 彈性寬度，最小 350px */
        padding-right: 20px;
    }

    /* 2. 連結欄位 - 佔比較窄 */
    .sjc-footer-links {
        flex: 1 1 180px; /* 彈性寬度，最小 180px */
    }

    /* 3. 校區資訊欄位 */
    .sjc-footer-campus {
        flex: 1 1 220px; /* 彈性寬度，最小 220px */
    }

    /* =================================================================
       PART C: Logo 與內容樣式
       ================================================================= */

    .sjc-logo-link {
        display: inline-block;
        text-decoration: none;
        transition: opacity 0.3s;
    }
    .sjc-logo-link:hover { opacity: 0.8; }

    .sjc-footer-logo {
        /* Logo 大小與間距設定 */
        max-width: 330px;
        width: 100%;
        height: auto;
        margin-bottom: 15px; /* 縮小間距 */
        display: block;
        
        /* 白色濾鏡 */
        filter: brightness(0) invert(1);
        -webkit-filter: brightness(0) invert(1);
        opacity: 0.95; 
    }

    .sjc-footer-desc {
        font-size: 0.9rem;
        color: #e0e6ed !important;
        margin-bottom: 25px;
        margin-top: 0;
        line-height: 1.5;
        max-width: 400px; /* 限制文字寬度讓閱讀更舒適 */
    }

    /* =================================================================
       PART D: 修復社群圖示與文字顏色
       ================================================================= */

    .sjc-social-links { display: flex; gap: 15px; }
    
    .sjc-social-icon {
        width: 36px; height: 36px; border-radius: 50%;
        border: 1px solid rgba(255,255,255,0.3);
        display: flex; align-items: center; justify-content: center;
        transition: all 0.3s ease;
        background: transparent;
    }
    
    /* 強制圖示顏色為白色 */
    .sjc-social-icon svg { 
        width: 18px; 
        height: 18px; 
        fill: #ffffff !important; 
        display: block;
    }
    
    .sjc-social-icon:hover {
        background-color: var(--sjc-gold); 
        border-color: var(--sjc-gold); 
        transform: translateY(-3px);
    }

    /* 標題樣式 */
    .sjc-footer-heading {
        color: var(--sjc-gold) !important; 
        font-size: 1.1rem; 
        font-weight: 700;
        text-transform: uppercase; 
        letter-spacing: 1px; 
        margin-top: 0;
        margin-bottom: 20px;
        position: relative; 
        display: inline-block;
    }
    .sjc-footer-heading::after {
        content: ''; position: absolute; left: 0; bottom: -8px;
        width: 30px; height: 2px; background-color: var(--sjc-blue-accent);
    }

    /* 連結列表 */
    .sjc-footer-links ul { list-style: none; padding: 0; margin: 0; }
    .sjc-footer-links li { margin-bottom: 12px; }
    .sjc-footer-links a {
        color: #ffffff !important; /* 強制白色 */
        text-decoration: none !important;
        transition: color 0.3s ease, padding-left 0.3s ease; 
        display: inline-block;
        font-size: 0.95rem;
    }
    .sjc-footer-links a:hover { color: var(--sjc-gold) !important; padding-left: 5px; }

    /* 聯絡資訊 */
    .sjc-campus-info { display: flex; flex-direction: column; gap: 15px; }
    .sjc-contact-item { display: flex; align-items: flex-start; gap: 12px; font-size: 0.9rem; }
    
    .sjc-contact-icon {
        min-width: 18px; width: 18px; height: 18px; 
        fill: var(--sjc-gold) !important; /* 強制金色 */
        margin-top: 3px;
    }
    
    .sjc-contact-text, .sjc-contact-text a {
        color: #ffffff !important; /* 強制白色 */
        text-decoration: none;
        line-height: 1.5;
        word-break: break-word; /* 避免長 Email 或網址超出手機螢幕 */
    }
    .sjc-contact-text a:hover { color: var(--sjc-gold) !important; }

    /* 底部版權列 */
    .sjc-footer-bottom {
        max-width: 1300px; 
        margin: 0 auto; 
        margin-top: 50px; 
        padding-top: 20px;
        border-top: 1px solid rgba(255,255,255,0.1);
        display: flex; 
        justify-content: space-between; 
        align-items: center;
        padding-left: 40px; padding-right: 40px;
        font-size: 0.85rem; 
        color: rgba(255,255,255,0.6) !important;
        flex-wrap: wrap;
        gap: 15px;
    }
    .sjc-bottom-links a {
        color: rgba(255,255,255,0.6) !important; 
        text-decoration: none; 
        margin-left: 20px; 
        transition: color 0.3s;
    }
    .sjc-bottom-links a:hover { color: white !important; }

    /* =================================================================
       RWD 手機與平板版調整
       ================================================================= */
       
    @media (max-width: 1024px) {
        .sjc-footer-brand { flex: 1 1 100%; text-align: center; padding-right: 0; margin-bottom: 20px; }
        .sjc-footer-logo { margin: 0 auto 15px; }
        .sjc-footer-desc { margin: 0 auto 25px; }
        .sjc-social-links { justify-content: center; }
        .sjc-footer-links, .sjc-footer-campus { text-align: left; }
    }
    
    @media (max-width: 768px) {
        .sjc-footer-container { 
            padding: 0 25px; 
            flex-direction: column; /* 強制垂直堆疊避免擠壓 */
            gap: 40px; 
        }
        .sjc-footer-brand { margin-bottom: 0; }
        .sjc-footer-logo { max-width: 260px; }
        
        .sjc-footer-bottom { 
            flex-direction: column; 
            text-align: center; 
            padding-left: 20px; /* 縮小兩側邊距 */
            padding-right: 20px;
        }
        .sjc-bottom-links {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
        }
        .sjc-bottom-links a { margin: 5px 10px; } /* 調整間距避免折行時太擠 */
    }

    @media (max-width: 480px) {
        #sjc-main-footer { padding: 40px 0 20px 0; }
        .sjc-footer-container { padding: 0 20px; gap: 30px; }
        .sjc-footer-logo { max-width: 220px; } /* 極小螢幕進一步縮小 Logo */
        .sjc-contact-item { font-size: 0.85rem; }
    }
</style>

