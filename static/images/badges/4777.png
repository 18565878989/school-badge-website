	<section id="content">		
		<script type="text/javascript">
    var timeout = [];

    $(window).load(function() {
		let animate = function() {
			let height = $(window).scrollTop() + Math.round($(window).height() * 0.6);
			$('#content > section').each(function() {
				if(!$(this).hasClass('animate') && height > $(this).offset().top)
				{
					$(this).addClass('animate');
                    if($(this).attr('id') == 'section2') {
						$('li > div', '#section2').each(function(index) {
							let item = $(this);
							setTimeout(function() {
								item.addClass('animate');
							}, index * 200);
						});
					}
				}
			});
		};
		$(window).on('scroll', animate);
		animate();
	});
</script>
<div id="banner">
    <div class="banner-container">
                                                <div class="banner-item">
                    <div class="wrapper">
                        <img src="/cache/img/5023e5c373884d7f0c5f49f66cf5bbe5.png" alt="" loading="lazy" width="1904" height="1200" class="trans" />                        <video id="video" width="1904" height="1200" preload="none" playsinline webkit-playsinline muted loop>
                            <source src="/upload/banner/1/banner/671e2a5173928.mp4" type="video/mp4">
                        </video>
                        <div class="mask"></div>
                        <div class="container">
                            <button class="play"></button>
                        </div>
                    </div>
                                    </div>
                        </div>
    <div class="container">
                <div class="scroll-icon"></div>
    </div>
    <script type="text/javascript">
        $(document).ready(function() {
            let pager_click = false;

            $('#banner').Slider({
                slides: '.banner-item',
                maxSlide: 1,
                swipeControl: true,
                skipBoundary: true,
                infiniteLoop: true,
                pager: '.banner-pager',
                afterSlide: function(slider, slides, current_page, total_page) {
                    $.each(timeout, function(index, value) {
                        clearTimeout(value);
                    });
                    let videos = $('video', slider);
                    videos.each(function(i, video) {
                        video.pause();
                        video.currentTime = 0;
                    });
                    $('button', slider).removeClass('play').addClass('pause');
                    if($('.slider.current video', slider).length) {
                                                        video = document.querySelector('#banner .slider.current video');
                                video.play();
                                            }
                    else if(!pager_click) {
                        timeout = setTimeout(function() {
                            slider.Slider('next');
                        }, 5000);
                    }
                },
                afterResize: function(slider, slides, current_page, total_page) {
                    if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                },
                afterInit: function(slider, slides, current_page, total_page) {
                                            let videos = $('video', slider);
                        videos.each(function(i, video) {
                            video.addEventListener('ended', videoEnd, false);
                        });
                        if($('.slider.current video', slider).length) {
                                                                video = document.querySelector('#banner .slider.current video');
                                    video.play();
                                    $('.slider.current button', slider).removeClass('play').addClass('pause');
                                                    }
                        else {
                            timeout = setTimeout(function() {
                                slider.Slider('next');
                            }, 5000);
                        }
                                        if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                }
            });
            
            $('.banner-item video', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                let button = $(this).parent().find('button');
                if(button.hasClass('pause')) {
                    video.pause();
                    button.removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    button.removeClass('play').addClass('pause');
                }
            });
            $('.banner-item button', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                if($(this).hasClass('pause')) {
                    video.pause();
                    $(this).removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    $(this).removeClass('play').addClass('pause');
                }
            });

            $('body').on('click', '#banner .banner-pager a', function() {
                pager_click = true;
            });

            function videoEnd(e) {
                if(!pager_click) {
                    $('#banner').Slider('next');
                }
                else {
                    $('#banner .slider.current button').removeClass('pause').addClass('play');
                }
            }
        });
    </script>
</div>
<section id="section1">
    <div class="container">
                    <div class="left">
                <article class="editor"><h3 class="homepage-title title"><strong><span style="font-size: 40px;">Learning for Life</span><br /></strong></h3>
<p><span style="font-size: 19px;"><span style="font-weight: 400;">Everything we do at SJS guides our communit<span style="font-size: 19px;">y to </span></span></span><span style="font-weight: 400; font-size: 19px;">a love of </span><strong style="font-size: 19px;">&lsquo;learning for life'</strong><span style="font-weight: 400;">.</span></p>
<p>&nbsp;</p>
<p><span style="font-weight: 400; font-size: 19px;">SJS is an inspiring learning community. We provide an inclusive environment where effort is valued, learning is engaging and creativity is fostered.</span></p>
<p>&nbsp;</p>
<p class="rounded_title bg-colour1"><span style="color: #ffffff;"><a style="color: #ffffff;" href="https://sjs.esf.edu.hk/en/about_us/what_we_stand_for/">Discover our vision</a></span></p>
<p>&nbsp;</p></article>
            </div>
                            <div class="right">
                <article class="editor"><p><img class="round-border" src="https://sjs.esf.edu.hk/upload/page/35/self/675fa774d9b4d.jpg" alt="" width="580" height="435" /></p></article>
            </div>
                            <div class="responsive">
                <article class="editor"><h3 class="homepage-title title"><strong><span style="font-size: 40px;">Learning for Life</span><br /></strong></h3>
<p>&nbsp;</p>
<p><span style="font-size: 16px;"><span style="font-weight: 400;">Everything we do at SJS guides our community to a love of </span><strong>&lsquo;learning for life'</strong><span style="font-weight: 400;">.</span></span></p>
<p><span style="font-weight: 400; font-size: 16px;">SJS is an inspiring learning community. We provide an inclusive environment where effort is valued, learning is engaging and creativity is fostered.</span></p>
<p>&nbsp;</p>
<p><img class="round-border" src="https://sjs.esf.edu.hk/upload/page/35/self/675fa774d9b4d.jpg" alt="" width="580" height="435" /></p>
<p>&nbsp;</p>
<p class="rounded_title bg-colour1"><span style="color: #ffffff;"><a style="color: #ffffff;" href="https://sjs.esf.edu.hk/en/about_us/what_we_stand_for/">Discover our vision</a></span></p>
<p>&nbsp;</p></article>
            </div>
            </div>
</section>
<section id="section2">
    <div class="container">
        <div class="section-title">
            <h2 class="colour2">What can Sha Tin Junior School offer your family?</h2>
            <span class="bg-colour1"></span>
        </div>
    </div>
    <div class="wrapper bg-colour2">
        <div class="container">
            <ul>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/d01025f8303292ca023ba75190823298.png" alt="ESF_Logomark_BW_RGB" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">ESF Network</h3>
                            <div class="overlay bg-colour1">
                                <p>As part of the English Schools Foundation(ESF), our students are supported by the largest English-medium international school organisation in Hong Kong, providing them the resources and opportunities not found outside of ESF Schools.</p>
                                                                    <a  href="https://sjs.esf.edu.hk/en/about_us/marketing_family/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/0a7a41bea958df69cfa11e642948a1e6.png" alt="Strong School-Family Connection" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Strong School-Family Connection</h3>
                            <div class="overlay bg-colour1">
                                <p>We believe in fostering a strong partnership between schools and families. We actively encourage parental involvement and maintain open lines of communication to ensure that parents are fully engaged in their child's educational journey.</p>
                                                                    <a  href="https://sjs.esf.edu.hk/en/outstanding_education/parent_partnership/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/9e292d9c7034bb1362249b4db8b9ca3b.png" alt="Comprehensive Student Support" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Comprehensive Student Support</h3>
                            <div class="overlay bg-colour1">
                                <p>Our schools offer comprehensive support systems, including personalised guidance, pastoral care, and counselling services, to help students thrive academically, emotionally, and socially.</p>
                                                                    <a  href="https://sjs.esf.edu.hk/en/outstanding_education/student_support_wellbeing/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/af0f868fb8fa59950a088e01da0dec43.png" alt="Well-rounded Education" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Well-rounded Education</h3>
                            <div class="overlay bg-colour1">
                                <p>Alongside academic excellence, our well-rounded education cultivates talents, interests, and character through diverse co-curricular activities in sports, arts, music, and community service.</p>
                                                                    <a  href="https://sjs.esf.edu.hk/en/outstanding_education/our_approach/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/5d511f7a8bf931c24d2ad98fafb7e966.png" alt="Real-world Experience" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Student Agency and Action</h3>
                            <div class="overlay bg-colour1">
                                <p>Nurturing student agency and action empowers learners to take ownership, apply knowledge, and become agents of positive change in their communities.</p>
                                                                    <a  href="https://sjs.esf.edu.hk/en/outstanding_experiences/action_student_leadership/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/e141bd91f8085a9618ec6ef2cebc19ee.png" alt="World-class Education" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Student Well-Being</h3>
                            <div class="overlay bg-colour1">
                                <p>We foster students' social-emotional learning through assemblies, classroom integration, and cultivating respectful school relationships - empowering well-being and academic achievement.</p>
                                                                    <a  href="https://sjs.esf.edu.hk/en/outstanding_education/student_support_wellbeing/">
                                        <span>Find out more</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                            </ul>
        </div>
    </div>
    <script type="text/javascript">
        $(window).load(function() {
            $('h3', '#section2').each(function() {
                let img = $(this).parent().children('img');
                if(img.length) {
                    $(this).css('top', img.offset().top + img.height() + 25 - $(this).parent().offset().top);
                }
            });
        });
    </script>
</section>
<section id="section3">
    <img src="/cache/img/4d54942cd1a69e4513ffef53ba4951ca.jpg" alt="shatinjunior_esf_7066" loading="lazy" width="1722" height="1294" />    <div class="wrapper">
        <div class="section-title-container">
            <div class="section-title">
                <h2 class="colour2">Primary Years Programme (PYP)</h2>
                <span class="bg-colour1"></span>
            </div>
        </div>
        <div class="tabs">
                            <button class="tab current" data-id="1">Years 1 - 6</button>
                    </div>
                            <div class="tab-content current" data-id="1">
                                <article class="editor"><p><strong>SJS can offer you a world-class education that nurtures your child's holistic development</strong><span style="font-weight: 400;">.</span></p>
<p>&nbsp;</p>
<p><span style="font-weight: 400;">At SJS, our students follow a curriculum inspired by the International Baccalaureate Primary Years Programme (PYP). This international, transdisciplinary framework fosters the development of the whole child, encompassing academic, social, physical, emotional, and cultural growth.</span></p></article>
                                    <a href="https://sjs.esf.edu.hk/en/outstanding_education/curriculum/">
                        <span>Find out more</span>
                    </a>
                            </div>
                <script type="text/javascript">
            $(document).ready(function() {
                $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();

                $('.tab', '#section3').click(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $(this).addClass('current');
                    $('.tab-content[data-id=' + $(this).data('id') + ']', '#section3').addClass('current');
                    $('select', '#section3').val($(this).data('id')).selectbox('refresh');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });

                $('.tab-select', '#section3').change(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $('.tab[data-id=' + $(this).val() + ']').addClass('current');
                    $('.tab-content[data-id=' + $(this).val() + ']', '#section3').addClass('current');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });
            });
        </script>
    </div>
</section>
