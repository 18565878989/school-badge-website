    <script type="text/javascript" src="//customer.cludo.com/scripts/bundles/search-script.min.js"></script>
    <script>
    var CludoSearch;
    var cludoSettings; 
    callCludo();
    function callCludo() {
           var searchTerm = '/search/';
           cludoSettings = {
                  customerId: 10000068, 
                  engineId: 10000076,
                  searchUrl: searchTerm,
                  language: 'en',
                  richAutocomplete: false,
                  disableAutocomplete: true,
                  initSearchBoxText: "",
                  hideSearchFilters: true,
                  searchInputs: ['search-block-form','mobile-search-block-form','search-form'],
                  loading: "<img src='//customer.cludo.com/img/loading.gif' alt='Loading' class='loading' role='progressbar' /><div class='loading-more-text'>Loading results. Please wait ...</div>",
                  hideSearchFilters: true,
                  hideResultsCount: true,
           };
           CludoSearch = new Cludo( cludoSettings );
        CludoSearch.setIsSearchResultPage = function() {
            var currentUrl = this.helpers.getWindowLocation();
            if (currentUrl.indexOf(this.searchUrl) > -1) {
                this.isSearchResultPage = true;
            } else {
                this.isSearchResultPage = false;
            }
        }
           CludoSearch . init();
    }
    </script>
    <!--End Cludo Footer Code-->	
