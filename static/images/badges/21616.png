               <style>
    /* Basic styling for suggestions */
    #suggestions {
      border: 1px solid #ccc;
      max-width: 219px;
	   margin-top: 34px;
	   /*margin-left: 102px;*/
		position: absolute;
      background: white;
      z-index: 1000;
