<!-- animation -->
<script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/ScrollTrigger.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/SplitText.min.js"></script>
		


<script>

	document.addEventListener("DOMContentLoaded", (event) => {
		gsap.registerPlugin(ScrollTrigger,SplitText);	
		document.body.classList.add('loaded');
		
		document.querySelectorAll(".fadeRight").forEach((fadeRight) => {
			gsap.from(fadeRight, {
				scrollTrigger: fadeRight, // start the animation when ".fadeRight" enters the viewport (once)
				x: -100,
				opacity: 0,
				stagger: 0.8
			});		
		});

		document.querySelectorAll(".fadeLeft").forEach((fadeLeft) => {
			gsap.from(fadeLeft, {
				scrollTrigger: fadeLeft, // start the animation when ".fadeLeft" enters the viewport (once)
				x: 100,
				opacity: 0,
				stagger: 0.8
			});		
		});

		document.querySelectorAll(".fadeUp").forEach((fadeUp) => {
			gsap.from(fadeUp, {
				scrollTrigger: fadeUp, // start the animation when ".fadeUp" enters the viewport (once)
				y: 100,
				opacity: 0,
				stagger: 0.8
			});		
		});

		document.querySelectorAll(".fadeDown").forEach((fadeDown) => {
			gsap.from(fadeDown, {
				scrollTrigger: fadeDown, // start the animation when ".fadeDown" enters the viewport (once)
				y: -100,
				opacity: 0,
				stagger: 0.8
			});	
		});
		
		document.querySelectorAll(".fadeIn").forEach((fadeIn) => {
			gsap.from(fadeIn, {
				scrollTrigger: fadeIn, // start the animation when ".fadeIn" enters the viewport (once)
				opacity: 0,
				duration: 2,
				stagger: 0.8
			});	
		});
		
		document.querySelectorAll(".fadeInSlow").forEach((fadeInSlow) => {
			gsap.from(fadeInSlow, {
				scrollTrigger: fadeInSlow, // start the animation when ".fadeInSlow" enters the viewport (once)
				opacity: 0,
				ease: "sine.inOut",
				duration: 4,
				stagger: 0.8
			});	
		});
		
		document.querySelectorAll(".fadeIn20").forEach((fadeIn20) => {
			gsap.from(fadeIn20, {
				scrollTrigger: fadeIn20, // start the animation when ".fadeIn20" enters the viewport (once)
				opacity: .2,
				duration: 2,
				stagger: 0.8
			});		
		});
		
		document.querySelectorAll(".splitText").forEach((splitClass) => {

			gsap.set(splitClass, { opacity: 1 });
			let split;

			SplitText.create(splitClass, {
				type: "words,lines",
				linesClass: "line",
				autoSplit: true,
				mask: "lines",
				onSplit: (self) => {
					split = gsap.from(self.lines, {
						delay: 0.4,
						duration: 1.2,
						yPercent: 100,
						opacity: 0.2,
						stagger: 0.25,
						ease: "expo.out",
					});
					return split;
				}
			});


			ScrollTrigger.create({
				trigger: splitClass,
				start: "top bottom", 
				end: "bottom",
				onEnter: () => {
					split.timeScale(1.75).play(0)
				},
				onEnterBack: () => {
					split.timeScale(1.5).play(0)
				},
				scrub: 1
			});
		});



		// animate pop stripe counter start

		const sections = gsap.utils.toArray(".pop-stripe");

		sections.forEach((section) => {
			const children = gsap.utils.toArray(".pop-fact", section);
			const timeline = gsap.timeline({
				scrollTrigger: {
					trigger: section,
					start: "top 80%", // Adjust as needed
					end: "bottom 20%", // Adjust as needed

					markers: false // Use for debugging
				}
			});

			timeline.fromTo(
				children,
				{
					opacity: 0
				},
				{
					opacity: 1,
					stagger: 0.3, // Adjust the stagger amount
					duration: 2 // Adjust the duration
				}
			);
		});

		window.addEventListener("DOMContentLoaded", function () {
			gsap.registerEffect({
				name: "counter",
				extendTimeline: true,
				defaults: {
					end: 0,
					duration: 2,
					ease: "power1",
					increment: .1
				},
				effect: (targets, config) => {
					let tl = gsap.timeline();
					let num = targets[0]?.innerText?.replace(/,/g, "") || "";
					if (targets.length > 0) { 
						targets[0].innerText = num;
					}
					

					tl.to(
						targets,
						{
							duration: config.duration,
							innerText: config.end,
							stagger: 0.5,
							//snap:{innerText:config.increment},
							modifiers: {
								innerText: function (innerText) {
									return gsap.utils
										.snap(config.increment, innerText)
										.toString()
										.replace(/\B(?=(\d{3})+(?!\d))/g, ",");
								}
							},
							ease: config.ease
						},
						0
					);

					return tl;
				}
			});
			const statsections = gsap.utils.toArray(".stats-section");

			statsections.forEach((statsection) => {
				const statNumber = gsap.utils.toArray(".stat-number", statsection);
				const numbers = statNumber.map((e) => e.dataset.fig);

				const timeline = gsap.timeline({
					scrollTrigger: {
						trigger: statsection,
						start: "top 80%", // Adjust as needed
						end: "bottom 20%", // Adjust as needed
						markers: false // Use for debugging
					}
				});

				timeline.counter(
					statNumber,
					{
						end: (i) => numbers[i],
						increment: .1,
						ease: "linear",
						duration: 1
					},
					"-=0.5"
				);
			});
		});

		// end pop-stripe counter 
		//end onFontReady
	});	

</script>


