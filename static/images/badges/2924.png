        <script type="text/javascript">
        $(document).ready(function() {
            const ori_total = parseInt($('#section7').data('total'));
            let slider_loop = ori_total >= 5 ? true : false;
            $('.record-slider', '#section7').Slider({
                slides: '.post-item',
                maxSlide: 1,
                swipeControl: true,
                skipBoundary: true,
                infiniteLoop: slider_loop,
                dummySlide: slider_loop,
				afterSlide: function(slider, slides, current_page, total_page) {
					if(slider_loop) {
						if(current_page == ori_total) {
							slider.Slider('jump', ori_total * 2).Slider('start');
						}
						if(current_page == ori_total * 2 + 1) {
							slider.Slider('jump', ori_total + 1).Slider('start');
						}
					}
				},
                afterInit: function(slider, slides, current_page, total_page) {
                    if(slider_loop) {
                        slider.Slider('jump', ori_total + 1);
                    }
                }
            });

            $('.post', '#section7').click(function() {
                $('.lightbox[data-id=' + $(this).data('id') + ']').addClass('show');
                disableScroll();
            });

            $('.lightbox .gallery', '#section7').Slider({
                slides: '.gallery-item',
                fixedSlide: 1,
                swipeControl: true,
                skipBoundary: true,
                afterSlide: function(slider, slides, current_page, total_page) {
                    let videos = $('.slider video', slider);
                    videos.each(function(i, video) {
                        video.pause();
                        video.currentTime = 0;
                    });
                    slider.parent().find('.slider-pager').html(current_page + ' / ' + total_page);
                },
                afterInit: function(slider, slides, current_page, total_page) {
                    if(total_page > 1) {
                        slider.parent().find('.slider-pager').html('1 / ' + total_page);
                    }
                }
            });
        });
    </script>
</section>
