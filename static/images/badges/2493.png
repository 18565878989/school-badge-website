o apply for admission to universities anywhere in the world.\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"b7e5e09a030e\",\"_type\":\"block\",\"children\":[{\"_key\":\"ea70227364af\",\"_type\":\"span\",\"marks\":[],\"text\":\"\"}],\"markDefs\":[],\"style\":\"normal\"},{\"_key\":\"2bd2cf62afb9\",\"_type\":\"linkButton\",\"document\":{\"_type\":\"file\",\"asset\":{\"_ref\":\"file-58e84823406666bd492f106c5ced5ce6c7b78347-pdf\",\"_type\":\"reference\"}},\"newTab\":true,\"style\":\"yellow\",\"text\":\"View Academic Calendar (Secondary)\"}],\"coverImage\":{\"_type\":\"curvedHeroNoHeading\",\"image\":{\"_type\":\"sanityImage\",\"alt\":\"Exterior view of Invictus School Hong Kong building, featuring the school name in bold yellow letters on a navy blue facade above classroom windows.\",\"asset\":{\"_ref\":\"image-8f6c90fdbfa9bd6c3309949bde64582d98313efb-2560x1080-jpg\",\"_type\":\"reference\"}}},\"orderRank\":\"0|09002a:\",\"seo\":{\"_type\":\"seo\",\"description\":\"Explore the academic calendar at Invictus School Hong Kong. Our school year runs from August to June, with small class sizes and a world-class curriculum leading to internationally recognised qualifications.\\n\\n\",\"image\":{\"_type\":\"sanityImage\",\"alt\":\"Three Invictus School Hong Kong students smiling and laughing outdoors under a sun umbrella, wearing school uniforms and hats.\",\"asset\":{\"_ref\":\"image-b49837b6ee3782dbd1d9cbc51029f3a0175a8519-2056x1371-png\",\"_type\":\"reference\"}},\"keywords\":\"Invictus Hong Kong school calendar, academic calendar, term dates, school year schedule, Invictus Kindergarten calendar, Invictus Primary calendar, Hong Kong international school term dates, Chai Wan Hong Kong\\n\\n\",\"title\":\"School Calendar | Chaiwan Invictus School Hong Kong\"},\"slug\":{\"_type\":\"slug\",\"current\":\"school-calendar\"},\"title\":\"School Calendar\"},\"quickLinks\":[{\"_key\":\"1ee9abf90ae6\",\"_type\":\"quickLink\",\"buttonLabel\":\"Register Now\",\"image\":{\"_type\":\