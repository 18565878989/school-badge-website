-hidden"><img alt="Exterior view of Invictus School Hong Kong building, featuring the school name in bold yellow letters on a navy blue facade above classroom windows." width="2560" height="1080" decoding="async" data-nimg="1" class="w-full h-[50vh] lg:h-[70vh] object-cover clip-bottom-curve object-cover transition-all" style="color:transparent" src="https://cdn.sanity.io/images/5sbzp4n2/production/8f6c90fdbfa9bd6c3309949bde64582d98313efb-2560x1080.jpg?w=2560&amp;h=1080&amp;q=70&amp;auto=format"/></div><div class="flex flex-col items-center text-center"></div></section><div class="default-section pt-4 md:pt-16 xl:pt-20"><div class="default-container"><div class="default-grid gap-6"><div class="col-span-3 col-start-1"><div class="sticky top-[20vh] gap-6 z-20"><aside class="flex flex-col gap-2 fixed lg:relative bottom-4 left-4 right-4 lg:left-auto lg:right-auto lg:bottom-auto z-[9999] lg:z-auto bg-white-main rounded-lg overflow-hidden"><div class="bg-yellow-secondary text-black-main font-bold px-4 py-3 rounded-lg flex items-center justify-between cursor-pointer md:cursor-default"><span>Chai Wan Campus</span><div class="flex items-center"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 md:block"><path d="M11.9993 1.33325H3.99935C3.26297 1.33325 2.66602 1.93021 2.66602 2.66659V13.3333C2.66602 14.0696 3.26297 14.6666 3.99935 14.6666H11.9993C12.7357 14.6666 13.3327 14.0696 13.3327 13.3333V2.66659C13.3327 1.93021 12.7357 1.33325 11.9993 1.33325Z" stroke="black" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"></path><path d="M6 14.6667V12H10V14.6667" stroke="black" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"></path><path d="M5.33398 4H5.34065" stroke="black" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"></path><path d="M10.666 4H10.6727" stroke="black" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"></path><path d="M8 4H8.00667" stroke="black" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"></path><path d="M8 6.66675H8.00667" stroke="black" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"></path><path d="M8 9.33325H8.00667" stroke="black" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"></path><path d="M10.666 6.66675H10.6727" stroke="black" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"></path><path d="M10.666 9.33325H10.6727" stroke="black" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"></path><path d="M5.33398 6.66675H5.34065" stroke="black" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"></path><path d="M5.33398 9.33325H5.34065" stroke="black" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"></path></svg><div class="md:hidden ml-2"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4"><path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.33333" stroke-linecap="round" stroke-linejoin="round"></path></svg></div></div></div><nav class="flex flex-col divide-y divide-black-main/10 bg-white-main overflow-y-auto rounded-lg md:rounded-none shadow-lg md:shadow-none" style="max-height:none;height:0px;opacity:0"></nav></aside></div></div><div class="col-start-1 md:col-start-6 col-span-10 flex flex-col gap-6 min-w-0"><h1 class="~text-4xl/5xl md:~text-5xl/6xl font-ebGaramond !leading-[1.2]">School Calendar</h1><div class="prose max-w-none"><div><p class="~text-base/lg [&amp;:not(:last-child)]:mb-6">Our school year runs from August to June with a maximum student-to-teacher ratio of 25:1 in the classroom. Your children will undergo a world-class curriculum while achieving internationally-recognised qualifications that enable them to apply for admission to universities anywhere in the world.</p><p class="~text-base/lg [&amp;:not(:last-child)]:mb-6"></p><div class="flex flex-col my-4"><a target="_blank" href="ht