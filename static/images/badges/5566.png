	<section id="content">		
		<script type="text/javascript">
	$(document).ready(function(){
		$('.banner').Slider({
			slides: '.banner-item',
			maxSlide: 1,
			autoPlay: 5000,
			pager: '.page',
			skipBoundary: true
		});
		
		$('.news.responsive').Slider({
			slides: '.news-item',
			maxSlide: 1,
			infiniteLoop: true,
			dummySlide: true,
			swipeControl: true,
			skipBoundary: true,
			autoMargin: false,
			fixWidth: false
		});
		
		var setting = {
			slides: '.news2-item',
			maxSlide: 1,
			infiniteLoop: true,
			dummySlide: false,
			swipeControl: true,
			skipBoundary: true,
			autoMargin: false,
			fixWidth: false,
			afterInit: function(slider, slides, current_page, total_page) {
				$('.prev', slider).hide();
				if(total_page < 4) {
					$('.next', slider).hide();
				}
			},
			afterSlide: function(slider, slides, current_page, total_page) {
				if(current_page == 1) {
					$('.prev', slider).hide();
				}
				else {
					$('.prev', slider).show();
				}
				if(current_page == total_page - 2) {
					$('.next', slider).hide();
				}
				else {
					$('.next', slider).show();
				}
			}
		}
		var setting2 = {
			slides: '.news2-item',
			maxSlide: 1,
			infiniteLoop: true,
			dummySlide: true,
			swipeControl: true,
			skipBoundary: true,
			autoMargin: false,
			fixWidth: false,
			afterInit: function(slider, slides, current_page, total_page) {
				$('.prev, .next', slider).hide();
			}
		}
		
		$('.news2').Slider(setting);
		
		$(window).resize(function() {
			$('.news2').Slider('destroy');
			if($(window).width() >= 1200) {
				$('.news2').Slider(setting);
			}
			else {
				$('.news2').Slider(setting2);
			}
		}).resize();
	});
</script>
