<noscript><img src="https://pixel.wp.com/b.gif?v=noscript" style="height:1px;width:1px;overflow:hidden;position:absolute;bottom:1px;" alt="" /></noscript>
<meta id="bilmur" property="bilmur:data" content="" data-provider="wordpress.com" data-service="simple" data-site-tz="Asia/Hong_Kong" data-custom-props="{&quot;logged_in&quot;:&quot;0&quot;,&quot;wptheme&quot;:&quot;pub\/infield&quot;,&quot;wptheme_is_block&quot;:&quot;0&quot;}"  >
		<script defer src="/wp-content/js/bilmur.min.js?i=17&amp;m=202613"></script> 			<script type="text/javascript">
			// Apply class names to enable mobile and platform-specific content in app promo.
			var htmlTag = document.getElementsByTagName( 'html' )[0];
			if ( /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test( navigator.userAgent ) ) {
				htmlTag.className = "is-mobile";
			}

			if ( /iPhone|iPad|iPod/i.test( navigator.userAgent ) ) {
				htmlTag.className += " is-mobile-ios ";
			}

			if ( /Android/i.test( navigator.userAgent ) ) {
				htmlTag.className += " is-mobile-android ";
			}

			// Set an appropriate app icon in the footer, based on whether the site is loaded in dark mode.
			var isDarkMode = window.matchMedia && window.matchMedia("(prefers-color-scheme:dark)").matches;

			if ( isDarkMode ) {
				var darkAppIcon = document.getElementById("footer-logo").src.split('.svg').join("-dark.svg");
				document.getElementById("footer-logo").src = darkAppIcon;
			}
		</script>
	</body>
</html>
