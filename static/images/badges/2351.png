		<script type="text/javascript">
		  $(document).ready(function () {
			$('#showLess').hide();

			  size_li = $("#myList li").size();
			  x=3;
			  $('#myList li:lt('+x+')').show();
			  $('#loadMore').click(function () {
				  
				  $('#myList li:lt(' + size_li + ')').show();
				  
				  $(this).hide();
				  $('#showLess').show();
			  });
			  $('#showLess').click(function () {
				  x=(x-5<0) ? 3 : x-5;
				  $('#myList li').not(':lt('+x+')').hide();
				  
				  $(this).hide();
				  $('#loadMore').show();
			  });
			  
			  
			  /*$(".SubDropdown").click(function() {
				  $(".SubDropdown + .nav").toggle();
			  });
			  
			  
			  $(".SubDropdown + .nav li a").click(function() {
				  $(".SubDropdown + .nav").toggle();
			  });*/
			  
			   
		  });

                          $(window).bind('resize', function () { 
				if ($(window).width() <= 480){	

					
					  $(".SubDropdown").click(function() {
						  $(".SubDropdown + .nav").toggle();
					  });
					  
					  $(".SubDropdown + .nav li a").click(function() {
						  $(".SubDropdown + .nav").toggle();
					  });
					
				}	
			});
		</script>
		
