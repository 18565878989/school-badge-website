			<div class="left"></div>
			<div class="right"></div><script type="text/javascript">
	$(document).ready(function() {
						$('.body_overlay').addClass('open');
				$.colorbox({
					href: "/zh-hant/index/popup/",
					maxWidth: 960,
					width: function() {
						var resizeWidth = Math.floor($(window).width() * 0.85);
						if(resizeWidth > 960) {
							resizeWidth = 960;
						}
						else if(resizeWidth < 480) {
							resizeWidth = 360;
						}
						return resizeWidth;
					},
					scrolling: false,
					close: '',
					onComplete: function() {
						setTimeout(function() {
							$.colorbox.resize();
						}, 2000);
						setTimeout(function() {
							$('.body_overlay').fadeOut();
						}, 5000);
					}
				});
				
					$('.banner').Slider({
				slides: '.banner-item',
				maxSlide: 1,
				autoPlay: 5000,
				pager: '.page',
				skipBoundary: true
			});
		
		var event = {};
		$('#calendar').fullCalendar({
			header: {
				left: '',
				center: '',
				right: ''
			},
			dayNamesShort: lang.dayNames,
			height: 290,
			buttonIcons: false,
			buttonText: {
				prev: '<span class="prev-arrow"><img src="img/calendar-arrow-green.svg" alt="" width="20" height="20" /></span>',
				next: '<span class="next-arrow"><img src="img/calendar-arrow-green.svg" alt="" width="20" height="20" /></span>',
			},
			editable: false,
			eventLimit: false,
			events: function(start, end, callback) {
				$.ajax({
					url: genurl('calendar', 'events'),
					dataType: 'json',
					data: {
						start: Math.round(start.getTime() / 1000),
						end: Math.round(end.getTime() / 1000)
					},
					success: function(response) {
						$.each(response, function() {
							event[this.timestamp] = [this.background, this.border, this.colour, this.tooltip];
						});
						callback(response);
						$('#calendar').fullCalendar('render');
					}
				});		
			},
			dayRender: function(date, cell) {
				date.setHours(0);
				date.setMinutes(0);
				date.setSeconds(0);
				date.setMilliseconds(0);
				if(date.getTime() in event)
				{					
					cell.css('backgroundColor', event[date.getTime()][0]);
					if(event[date.getTime()][0] == "") {
						cell.css({
							"border-width": "2px",
							"border-style": "solid",
							"border-color": event[date.getTime()][1]
						})
					}
					cell.find('.fc-day-number').css('color', event[date.getTime()][2]);
					cell.find('.fc-day-number').html(cell.find('.fc-day-number').html() + '<span>' + event[date.getTime()][3] + '</span>');
				}
			}
		});
		
		var d = new Date();
		var m = d.getMonth() + 1;
		$.get(genurl('calendar', 'ajax', m), function(response) {
			$('.events-list').html(response);
		});
		
		$('.fc-button span').click(function(){
			var date = $("#calendar").fullCalendar('getDate');
			var year = date.getFullYear();
			var month = date.getMonth();
			if($(this).parent().hasClass('fc-button-prev')) {
				if(month == 0) {
					month = 12;
					year -= 1;
				}
			}
			else {
				month += 2;
				if(month == 13) {
					month = 1;
					year += 1;
				}
			}
			$.get(genurl('calendar', 'ajax', month + '/' + year), function(response) {
				$('.events-list').html(response);
			});
		});
		
		$('.selects').selectbox();
		
		$('.selects').change(function() {
			var year = $('#year').val();
			var month = parseInt($('#month').val());
			year = $('.selects.year').children('option[value='+year+']').html();
			$('#calendar').fullCalendar('gotoDate', year, month, 1);
			month += 1;
			$.get(genurl('calendar', 'ajax', month + '/' + year), function(response) {
				$('.events-list').html(response);
			});
		});
	});
</script>
