        height: 44px;
        transition: all 300ms ease !important;
    }</style> <script type="litespeed/javascript">window.addEventListener('scroll',(e)=>{const nav=document.querySelector('.nav');const notification=document.querySelector('.notification');const hearts=document.querySelectorAll('.hearts');const logo=document.querySelector('.anfield_logo');if(window.pageYOffset>0){nav.classList.add("add-shadow");notification.classList.add("bye");hearts.forEach(heart=>heart.classList.add("bye"));logo.classList.add("minimise")}else{nav.classList.remove("add-shadow");notification.classList.remove("bye");hearts.forEach(heart=>heart.classList.remove("bye"));logo.classList.remove("minimise")}})</script> </div></div><div class="elementor-element elementor-element-d21c822 notification hearts elementor-hidden-tablet elementor-hidden-mobile e-flex e-con-boxed e-con e-child" data-id="d21c822" data-element_type="container" data-settings="{&quot;background_background&quot;:&quot;classic&quot;}"><div class="e-con-inner"><div class="elementor-element elementor-element-8792c7a elementor-widget elementor-widget-text-editor" data-id="8792c7a" data-element_type="widget" data-widget_type="text-editor.default"><div class="elementor-widget-container"><p>Contact: Whampoa Campus +852 2766 3882 | Kowloon Tong Campus +852 2794 3668</p></div></div></div></div><div class="elementor-element elementor-element-d708ff0 e-flex e-con-boxed e-con e-child" data-id="d708ff0" data-element_type="container" data-settings="{&quot;background_background&quot;:&quot;classic&quot;}"><div class="e-con-inner"><div class="elementor-element elementor-element-b271d3c anfield_logo elementor-widget elementor-widget-image" data-id="b271d3c" data-element_type="widget" data-widget_type="image.default"><div class="elementor-widget-container">
