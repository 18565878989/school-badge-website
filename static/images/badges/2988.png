    .notification {
    height: 41px;
    opacity: 1;
    transition: all 300ms ease;
    }
    
    .bye {
        height: 0px !important;
        opacity: 0;
        transition: all 300ms ease;
        margin-top: 0;
    }
    
    .bye a {
        pointer-events: none;
    }
    
    .anfield_logo img {
        height: 60px;
        transition: all 300ms ease;
    }
    @media (min-width: 1025px) {
    .minimise img {
        height: 42px !important;
        transition: all 300ms ease;
    }
    }
    
