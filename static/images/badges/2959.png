<script type="text/javascript">
	String.prototype.endWith=function(s){
		if(s==null||s==""||this.length==0||s.length>this.length)
			return false;
		if(this.substring(this.length-s.length)==s)
			return true;
		else
			return false;
		return true;
	}

	String.prototype.startWith=function(s){
		if(s==null||s==""||this.length==0||s.length>this.length)
		return false;
		if(this.substr(0,s.length)==s)
			return true;
		else
			return false;
		return true;
	}

	$(document).ready(function() {
		$('.news_list li img').each(function(i, item) {
			if(item.src.endWith('/school_footer_logo.jpg')) {
				$(item).css('height','86%');
				$(item).css('margin','10px auto 0 auto');
				$(item).css('opacity','0.5');
			}
		});
			});


function initiLightBox(el)
 {
  if(typeof el == "string") {
   el = document.getElementById(el);
  }
  
  $(el).iLightBox({
   skin: 'metro-white',
   path: 'horizontal',
   mousewheel: false,
   infinite: true,
    overlay: {
    opacity: 0.3,
    blur: true,
   },
   controls: {
    fullscreen: false,
    toolbar: true,
    arrows: false,
    mousewheel: false,
    thumbnail: false,
    swipe: false
   }
  });
 }
 
 function initPassBtn(el, type)
 {
  if(typeof el == "string") {
   el = document.getElementById(el)
  }
  
  if(null != el && '1' == el.getAttribute('needPass'))
  {
   el.removeAttribute('data-toggle','');
   el.setAttribute('data-type','iframe');
   el.setAttribute('data-options','width:\'80%\', height:\'100%\'');
   el.href = 'modulePass.php?passName=' + type;
   initiLightBox(el);
  }
 }


 function initPassBtn_class(el, type)
 {
	 
  if(typeof el == "string") {
   el = document.getElementsByClassName(el)
  }
	for(var i=0;i<el.length;i++){
	if(null != el[i] && '1' == el[i].getAttribute('needPass'))
		{
		el[i].removeAttribute('data-toggle','');
		el[i].setAttribute('data-type','iframe');
		el[i].setAttribute('data-options','width:\'80%\', height:\'100%\'');
		el[i].href = 'modulePass.php?passName=' + type;
		initiLightBox(el[i]);
		}
	}
 }


 $(document).ready(function() {
  $('#news_list li img').each(function(i, item) {
   if(item.src.endWith('/school_footer_logo.jpg')) {
    $(item).css('height','75%');
    $(item).css('margin','10px auto 0 auto');
    $(item).css('opacity','0.5');
   }
  });
   });
 //btn_schoolnotice_more
 var replyslipBtn = document.getElementById('btn_replyslip');
 var schoolnoticeBtn = document.getElementsByClassName('btn_schoolnotice');
 var btn_schoolnotice_more = document.getElementById('btn_schoolnotice_more');
 var btn_schoolfile_more = document.getElementById('btn_schoolfile_more');
 initPassBtn(replyslipBtn, 'noticePass');
 initPassBtn_class(schoolnoticeBtn, 'noticePass');
 initPassBtn(btn_schoolnotice_more, 'noticePass');
 initPassBtn(btn_schoolfile_more, 'noticePass');

 //图片

 var Gallery_pass = document.getElementsByClassName('Gallery_pass');
 initPassBtn_class(Gallery_pass, 'albumPass');

 var GalleryList_pass = document.getElementsByClassName('GalleryList_pass');
 initPassBtn_class(GalleryList_pass, 'albumPass');

 var gallerylist_more = document.getElementById('gallerylist_more');
 initPassBtn(gallerylist_more, 'albumPass');


