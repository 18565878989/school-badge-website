<script type="text/javascript">
		document.onkeydown = function(e){
			var e=e || event;
			var currKey=e.keyCode||e.which||e.charCode;
			if(currKey == 13) {
				doEClassLogin();
			}
		};
function doEClassLogin() {
				document.forms["loginform"].submit();
				document.loginform.UserLogin.value="";
				document.loginform.UserPassword.value="";				
			
		}
		
</script>
<script type="text/javascript" src="../../../../js/md5.js"></script>
<script type="text/javascript">
		function doLogin() {
			if (validate()) {
				document.forms["loginform"].submit();
				document.loginform.userloginid.value = "";
				document.loginform.password.value = "";
			}
		}
		
		function validate(){ 
			thisform = document.loginform;	 
			v =true; 
			if (thisform.userloginid.value == ""){ 
				v = false;	
				thisform.userloginid.focus();
			} 
			if (v && thisform.password.value ==	""){ 
				v = false;	
				thisform.password.focus();
			}
			if (v) {
				thisform.elements["password"].value = MD5(thisform.elements["password"].value);
			}	
			
			return v;
		}
		
		document.onkeydown = function(e){
			var e=e || event;
			var currKey=e.keyCode||e.which||e.charCode;
			if(currKey == 13) {
				doEClassLogin();
			}
		};
</script>                </div>
