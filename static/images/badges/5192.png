			#banner{height:640px;overflow:hidden;box-shadow: 20px 20px 10px 0px rgba(0, 0, 0, 0.1);border-radius: 175px 0px 50px 0;
}
#banner rs-slides, #banner rs-slide,#banner .rs-progress{border-radius: 175px 0px 50px 0;}

.scroll{writing-mode: vertical-lr}
 .ue-menu >  li.lang-item{display:none !important}
	.header {padding-top:40px !important;padding-bottom:40px !important}
@media (max-width: 1850px){
	.left{width:300px}
	.btext2 	.elementor-widget-container{margin-left:155px !important}
		.btext3 	.elementor-widget-container{margin-left:155px !important}
}

@media (max-width: 1680px){
	.left{width:250px}
	.btext .elementor-heading-title{font-size:90px !important;line-height:65px !important;}
		.btext2 	.elementor-widget-container{margin-left:65px !important}
		.btext3 	.elementor-widget-container{margin-left:65px !important;}
}
@media (max-width: 1440px){
	.btext .elementor-heading-title{font-size:75px !important;line-height:55px !important }
}
@media (max-width: 1443px){
	html[lang="en-US"] .ue-menu a{padding-left:10px !important;padding-right:10px !important;}
}
	@media (max-width: 1368px){
	
	.btext .elementor-heading-title{font-size:70px !important;line-height:55px !important }
}
@media (max-width: 1367px){
	.header {width:100% !important;padding-top:0px !important;padding-bottom:0px !important;}
	.menu{order:1;margin-right:-10px;margin-top:-3px !important}
	}
@media (max-width: 1280px){
.btext .elementor-heading-title{font-size:65px !important;line-height:50px !important }
#banner{height:auto;box-shadow: 20px 20px 10px 0px rgba(0, 0, 0, 0.1);border-radius: 45px 0px 25px 0;}
#banner rs-slides,#banner rs-slide,.#banner rs-progress{border-radius: 45px 0px 25px 0}
 .ue-menu >  li.lang-item{display:block !important}
}
@media (max-width: 1279px){
.left{display:none}	
.cpel-switcher--layout-horizontal .cpel-switcher__list {
    flex-direction: row;
    flex-wrap: nowrap  !important;
}
.elementor-widget-social-icons.e-grid-align-left .elementor-grid {
    display: flex  !important;
    flex-direction: row;
    flex-wrap: nowrap !important;
}
.btext .elementor-heading-title{font-size:50px !important;line-height:45px !important }

}

@media (max-width: 1024px){
	.menu{order:1;margin-right:0px;margin-top:0px}
.left{width:100%;}
#banner{box-shadow: 0px 0px 0px 0px rgba(0, 0, 0, 0.1);border-radius: 0px 0px 0px 0;
}
#banner rs-slides, #banner rs-slide,#banner .rs-progress{border-radius: 0px 0px 0px 0;}

}
@media (max-width: 530px){
.btext .elementor-heading-title{font-size:30px !important;line-height:30px !important }
}

.cpel-switcher__list li a{line-height:normal !important}


.footmenu .uc-list-menu li.lang-item{display:none}

