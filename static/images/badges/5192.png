		/*font-family:  "Roboto", sans-serif!important;;*/
	font-weight: 600!important;
}
.cpel-switcher__lang--active a span{font-weight:600 !important;}

.cpel-switcher__list li::after {
	content: '|';
	position:absolute;
padding-right:0px;
	transform: translateX(50%);
color: var(--e-global-color-primary);
}
.cpel-switcher__list li:last-child:after{	content: '';}

.btn .{
  transition: transform 0.5s ease; 
  transform: scale(1); 
}
 
.btn:hover  p {
  /*transform: scale(1.11); */
	color:var(--e-global-color-primary)
}

.btn img{image-rendering:-moz-crisp-edges;
	image-rendering:-o-crisp-edges;
	image-rendering:-webkit-optimize-contrast;
	image-rendering: crisp-edges;
	-ms-interpolation-mode:nearest-neighbor;}

/*顏寶鈴*/

.sinfo{	 position: relative;overflow:hidden;border-radius:20px;}
.sinfo:after{content: '';
  position: absolute;z-index:1;
  bottom: 0;
  left: -66.69px;;
top:129px;
  width: 467px;
  height: 475px;
  background-color: #FDEB53;
  border-radius: 50%;}

.sinfo ._blox_image_box{z-index:2;background:#fff;}
.sinfo ._blox_text p:after{content:'';
display:block;padding-bottom:10px;
margin-left: 8%;margin-right:8%;
  width: 82%;

 border-bottom:1px dashed var(--e-global-color-e85420f);
}
.sinfo ._blox_paragraph{margin-bottom:20px;}
.sinfo .ue_list_row_text{text-align: left !important;}
.sinfo .ue_list_row {display: flex;
align-items: flex-start !important;}
.sinfo ._blox_image_box img{padding:6px 8px;border-radius:25px;object-fit:cover !important;  }


.sinfo .ue-content{z-index:2;}
.sinfo .ue_badge {
    position: absolute;
    top: 24px !important;
right: -8px;
    left:8px;
    transform: rotate(0deg) !important;
    padding: 2px 0px 2px 5px!important;
    width: 58px !important;
    text-align: center;
}
html[lang=en-US]  .sinfo .ue_badge {
    position: absolute;
    top: 24px !important;
right: -8px;
    left:8px;
    transform: rotate(0deg) !important;
    padding: 2px 0px 2px 5px!important;
    width: 90px !important;
    text-align: center;
}
.sinfo .ue_badge::after{
content: ' ';
position: absolute;
top: 0;
right: -10px;
border-width: 25px 10px;
border-style: solid;
border-color:#C8161E transparent transparent transparent;
}

