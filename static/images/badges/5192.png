		<link id='uc_ac_assets_file_uc_creative_link_effects_css_26314-css' href='https://www.yotkg.edu.hk/wp-content/uploads/ac_assets/nav_menu/uc-creative-link-effects.css' type='text/css' rel='stylesheet' >

			<style type="text/css">/* widget: WordPress Menu */

#uc_nav_menu_elementor_32d60ef{
	position: relative;
}

#uc_nav_menu_elementor_32d60ef .ue-nav-menu-mobile-wrapper{
 	display: flex;
}

#uc_nav_menu_elementor_32d60ef .ue-menu{
    display:flex;
    list-style:none;
    margin:0;
    padding:0;
    position:relative;
  	justify-content:inherit;
}

#uc_nav_menu_elementor_32d60ef a{
  	position: relative;
	text-decoration: none;
 	display: flex;
  	align-items: center;  
}

  #uc_nav_menu_elementor_32d60ef a:after,
  #uc_nav_menu_elementor_32d60ef a:before{
      content: "";
      z-index: 2;
      position:absolute;
  }

	








#uc_nav_menu_elementor_32d60ef .sub-menu a{
	justify-content: space-between;
}

#uc_nav_menu_elementor_32d60ef .ue-menu > li {
	display: block;
  	}

/* Simple multilevel dropdown */
#uc_nav_menu_elementor_32d60ef .ue-menu > li > .sub-menu {
	opacity: 0;
	visibility: hidden;
	position: absolute;
	list-style: none;
	text-align: inherit;
	padding: 0px;
    display:block;
	z-index: 99;
}

/* First level appear */
#uc_nav_menu_elementor_32d60ef .ue-menu > li:hover > .sub-menu{
	opacity: 1;
	visibility: visible;
}

#uc_nav_menu_elementor_32d60ef .ue-menu > li.uc-active > .sub-menu {
	opacity: 1;
	visibility: visible;
}

/* Style for dropdown links */
#uc_nav_menu_elementor_32d60ef .ue-menu li > .sub-menu li {
	position: relative;
	display: block;
}

/* Second and third dropdown level */
#uc_nav_menu_elementor_32d60ef .ue-menu > li > .sub-menu li{
  display: block;
}

#uc_nav_menu_elementor_32d60ef .ue-menu > li > .sub-menu > li .sub-menu {
	opacity: 0;
	visibility: hidden;
	position: absolute;
	list-style: none;
	top:0px;
	padding: 0px;
  	z-index: 100;
}

/* Second and third level appears */
#uc_nav_menu_elementor_32d60ef .ue-menu > li .sub-menu li:hover > .sub-menu {
	opacity: 1;
	visibility: visible;
}

#uc_nav_menu_elementor_32d60ef .ue-menu > li .sub-menu li.uc-active > .sub-menu {
	opacity: 1;
	visibility: visible;
}

#uc_nav_menu_elementor_32d60ef li,
#uc_nav_menu_elementor_32d60ef a{
	transition: all 0.3s ease-in-out;
}

#uc_nav_menu_elementor_32d60ef ul{
	transition: opacity 0.3s ease-in-out;
}

#uc_nav_menu_elementor_32d60ef .ue-nav-menu-checkbox{ 
  	display: none; 
}

#uc_nav_menu_elementor_32d60ef .ue-nav-menu-mobile{
  	display: none;
	transition: all .3s;
    cursor: pointer;
}

#uc_nav_menu_elementor_32d60ef .ue-nav-menu-icon{
	display: flex;
}

#uc_nav_menu_elementor_32d60ef .ue-nav-menu-mobile > *{
	display: none;
  	justify-content: center;
  	align-items: center;
}
#uc_nav_menu_elementor_32d60ef .ue-nav-menu-mobile > .uc-active{
	display: flex;
}

/* hover effects */
















/* end hover effects */

@media only screen and (max-width: 1024px) {
    
      #uc_nav_menu_elementor_32d60ef .ue-menu{
          justify-content:flex-end;
      }
      }

@media only screen and (max-width: 767px) {
    
  	 #uc_nav_menu_elementor_32d60ef .ue-menu{
          justify-content:;
     }
     }


@media only screen and (max-width: 1367px) {
  
	#uc_nav_menu_elementor_32d60ef .ue-menu {
     	opacity: 0;
      	transform: translate(0, -20px);
      	pointer-events: none;
      	transition: all .3s;
      	flex-direction: column;
      	position: absolute;
      	width: 100%;
      	top: 100%;
      	left: 0;
      	z-index: 1000;
    }
  
    #uc_nav_menu_elementor_32d60ef .sub-menu{
      	visibility: visible !important;
      	opacity: 1 !important;
      	inset-inline-start: unset !important;
        transition-timing-function: ease;
    } 	

	#uc_nav_menu_elementor_32d60ef .ue-nav-menu-mobile {
        position: relative;
        display: flex;
        align-items:center;
        justify-content:center;      
	}

	#uc_nav_menu_elementor_32d60ef .ue-nav-menu-checkbox:checked + .ue-menu {
		opacity: 1;
      	transform: translate(0, 0px);
      	pointer-events: all;
	}

	#uc_nav_menu_elementor_32d60ef .ue-menu > li > .sub-menu {
		width: 100%;
        position:relative;
        top:auto;
	}

	#uc_nav_menu_elementor_32d60ef .ue-menu > li > .sub-menu > li .sub-menu {
		width: 100%;
		left: 0;
		z-index: 2;
        position:relative;
        top:auto;
	}

	#uc_nav_menu_elementor_32d60ef .ue-menu > li > ul li ul li ul {
		width: 100%;
      	position:relative;
	}
  
}

</style>

			<div id="uc_nav_menu_elementor_32d60ef" class="ue-nav-menu" data-show-icons="false" data-breakpoint="1367" data-full-width="true" data-effect-style="no-hover-effects">
  
