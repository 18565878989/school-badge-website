/* 選取月份 */
.filter-m h5{
	display: none;
}
.filter-m select{
	width: 100%;
	padding: 16px;
	border:none;
	border-radius: 3px;
	font-size: 15px;
	color: rgba(0,0,0,0.5);
	cursor: pointer;
	-o-appearance: none;
	-ms-appearance: none;
	-webkit-appearance: none;
	-moz-appearance: none;
	appearance: none;
	background: url(/wp-content/uploads/2024/07/angle-down.svg) no-repeat scroll 95% center rgba(0,0,0,0.05);
}
.filter-m select:focus{
	outline:none;
}
.filter-m option[value="1"]{display:none ;}
.filter-m option[value="12"]{display:none ;}
@media (max-width: 1024px){
	.filter-m select{
		padding: 12px;
	}
}
/* 搜尋按鈕 */
.elementor-widget-search-form .elementor-search-form__submit{
	background-color: var(--e-global-color-primary)!important;
}
.elementor-widget-search-form .elementor-search-form__submit:hover{
	background-color: var(--e-global-color-accent)!important;
}

/*文章列表*/
.page-title{
	position: absolute;
}
.postlist .elementor-post .elementor-post__title:hover a{
	color:var(--e-global-color-secondary);
}
.postlist .elementor-post .elementor-post__read-more:hover{
	color:var(--e-global-color-accent);
}
.postlist .elementor-post__excerpt{
	display: -webkit-box;
	-webkit-box-orient: vertical;
	-webkit-line-clamp: 3;
	overflow: hidden;
}
.postlist .elementor-post__excerpt:lang(en-US){
	-webkit-line-clamp: 2;
}
@media only screen and (min-width: 768px) and (max-width: 1024px) {
	.postlist .elementor-posts-container.elementor-has-item-ratio .elementor-post__thumbnail{
		left: 25px;
		top: 50%;
		transform: translate(0, -50%);
	}
	.postlist .elementor-post__excerpt:lang(en-US){
		-webkit-line-clamp: 3;
	}
}
@media (max-width: 767px) {
	.postlist .elementor-widget-container .elementor-posts .elementor-post{
		flex-direction:column!important;
	}
}

/*文章列表 - 選擇月份*/
.postlist-date .elementor-post{
	border: 1px solid #1F1F1F40;
	border-radius: 15px;
	background: #FFF;
}
.postlist-date .elementor-post__text{
	padding: 32px 30px 32px 30px;
}
/* 文章資訊 */
.post-info .elementor-icon-list-item{
	align-items: initial!important;
}
.post-info .elementor-icon-list-icon{
	top: 7px!important;
}
/* 文章導航列 */
.elementor-post-navigation{
	gap: 20px;
}
@media (max-width: 767px) {
	.post-nav .elementor-post-navigation{
		flex-direction: column;
	}
	.post-nav .elementor-post-navigation__link{
		width: 100%!important;
	}
}
@media (max-width: 540px) {
.elementor-post-navigation {
    display: contents !important;
}
.elementor-post-navigation .elementor-post-navigation__next {
    text-align: left;
}
	.elementor-post-navigation .elementor-post-navigation__link{		width: 100%!important;}
.elementor-post-navigation span.elementor-post-navigation__link__next {
    text-align: left !important;
    margin-left: 25px;
}
.elementor-post-navigation .elementor-post-navigation__next a {
    justify-content: flex-start  !important;
}
.elementor-post-navigation .post-navigation__arrow-wrapper.post-navigation__arrow-next {
    font-size: 30px;
padding-left: 5px !important;
    position: absolute;
    left: 0;
}
}		</style>
