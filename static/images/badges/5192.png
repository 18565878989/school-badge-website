.gotoup .ue-scroll-to-cta{color:#fff !important;}
.gotoup .ue-scroll-to-cta:after{content: "\f077";	color:#fff;
font-weight: 600;	font-size:12px;top:-11px;position:absolute;left:0;font-family:"Font Awesome 5 Free";}
.gotoup .ue-scroll-to-cta:before{content:"";background:var(--e-global-color-e658dda);width:16px;height:16px;left:-2px;top:2px;position:absolute;border-radius:50px}
