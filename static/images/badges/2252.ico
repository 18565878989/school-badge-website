	<section id="content">		
		<script type="text/javascript">
    var timeout = [];

    $(window).load(function() {
		let animate = function() {
			let height = $(window).scrollTop() + Math.round($(window).height() * 0.6);
			$('#content > section').each(function() {
				if(!$(this).hasClass('animate') && height > $(this).offset().top)
				{
					$(this).addClass('animate');
                    if($(this).attr('id') == 'section2') {
						$('li > div', '#section2').each(function(index) {
							let item = $(this);
							setTimeout(function() {
								item.addClass('animate');
							}, index * 200);
						});
					}
				}
			});
		};
		$(window).on('scroll', animate);
		animate();
	});
</script>
<div id="banner">
    <div class="banner-container">
                                                <div class="banner-item">
                    <div class="wrapper">
                        <img src="/cache/img/c1d7f25d04f0a719d78482f1056b3b74.png" alt="" loading="lazy" width="1904" height="1200" class="trans" />                        <video id="video" width="1904" height="1200" preload="none" playsinline webkit-playsinline muted loop>
                            <source src="/upload/banner/1/banner/671fbac8a5548.mp4" type="video/mp4">
                        </video>
                        <div class="mask"></div>
                        <div class="container">
                            <button class="play"></button>
                        </div>
                    </div>
                                    </div>
                        </div>
    <div class="container">
                <div class="scroll-icon"></div>
    </div>
    <script type="text/javascript">
        $(document).ready(function() {
            let pager_click = false;

            $('#banner').Slider({
                slides: '.banner-item',
                maxSlide: 1,
                swipeControl: true,
                skipBoundary: true,
                infiniteLoop: true,
                pager: '.banner-pager',
                afterSlide: function(slider, slides, current_page, total_page) {
                    $.each(timeout, function(index, value) {
                        clearTimeout(value);
                    });
                    let videos = $('video', slider);
                    videos.each(function(i, video) {
                        video.pause();
                        video.currentTime = 0;
                    });
                    $('button', slider).removeClass('play').addClass('pause');
                    if($('.slider.current video', slider).length) {
                                                        video = document.querySelector('#banner .slider.current video');
                                video.play();
                                            }
                    else if(!pager_click) {
                        timeout = setTimeout(function() {
                            slider.Slider('next');
                        }, 5000);
                    }
                },
                afterResize: function(slider, slides, current_page, total_page) {
                    if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                },
                afterInit: function(slider, slides, current_page, total_page) {
                                            let videos = $('video', slider);
                        videos.each(function(i, video) {
                            video.addEventListener('ended', videoEnd, false);
                        });
                        if($('.slider.current video', slider).length) {
                                                                video = document.querySelector('#banner .slider.current video');
                                    video.play();
                                    $('.slider.current button', slider).removeClass('play').addClass('pause');
                                                    }
                        else {
                            timeout = setTimeout(function() {
                                slider.Slider('next');
                            }, 5000);
                        }
                                        if(slider.width() < 768) {
                        $('.banner-pager', slider).css('bottom', slider.height() - $('img', slider).height() + 15);
                    }
                    else {
                        $('.banner-pager, .scroll-icon', slider).removeAttr('style');
                    }
                }
            });
            
            $('.banner-item video', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                let button = $(this).parent().find('button');
                if(button.hasClass('pause')) {
                    video.pause();
                    button.removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    button.removeClass('play').addClass('pause');
                }
            });
            $('.banner-item button', '#banner').click(function() {
                var video = document.querySelector('#banner .slider.current video');
                if($(this).hasClass('pause')) {
                    video.pause();
                    $(this).removeClass('pause').addClass('play');
                }
                else {
                    video.play();
                    $(this).removeClass('play').addClass('pause');
                }
            });

            $('body').on('click', '#banner .banner-pager a', function() {
                pager_click = true;
            });

            function videoEnd(e) {
                if(!pager_click) {
                    $('#banner').Slider('next');
                }
                else {
                    $('#banner .slider.current button').removeClass('pause').addClass('play');
                }
            }
        });
    </script>
</div>
<section id="section1">
    <div class="container">
                    <div class="left">
                <article class="editor"><h2 class="title" style="line-height: 35px;"><span style="font-size: 60px;">Grow.</span></h2>
<h2 class="title" style="line-height: 35px;"><span style="font-size: 60px;">Discover.</span></h2>
<h2 class="title" style="line-height: 35px;"><span style="font-size: 60px;">Dream.</span></h2></article>
            </div>
                            <div class="right">
                <article class="editor"><p>ESF Discovery College is a Year 1 - 13 IB World Through-School. We are a community of learners who respect the diversity of experiences and perspectives we each possess. Here, we strive to create an environment that fosters a passion for learning, that enables all students to Grow. Discover. Dream. We have exceptional teachers and staff who provide wonderful classroom experiences that are engaging and fun for students.</p>
<p>&nbsp;</p>
<p class="rounded_title bg-colour1"><a href="https://discovery.esf.edu.hk/en/about_us/our_vision_and_outcomes/" target="_blank" rel="noopener"><span style="color: #ffffff;">Discover Our Vision</span></a></p></article>
            </div>
                            <div class="responsive">
                <article class="editor"><h2 class="title" style="line-height: 35px;"><span style="font-size: 48px;">Grow.</span></h2>
<h2 class="title" style="line-height: 35px;"><span style="font-size: 48px;">Discover.</span></h2>
<h2 class="title" style="line-height: 35px;"><span style="font-size: 48px;">Dream.</span></h2>
<p>&nbsp;</p>
<p>ESF Discovery College is a Year 1 - 13 IB World Through-School. We are a community of learners who respect the diversity of experiences and perspectives we each possess. Here, we strive to create an environment which fosters a passion for learning, which enables all students to Grow. Discover. Dream. We have exceptional teachers and staff who provide wonderful classroom experiences that are engaging and fun for students.</p>
<p>&nbsp;</p>
<p class="rounded_title bg-colour1"><a href="https://discovery.esf.edu.hk/en/about_us/our_vision_and_outcomes/" target="_blank" rel="noopener"><span style="color: #ffffff;">Discover Our Vision</span></a></p></article>
            </div>
            </div>
</section>
<section id="section2">
    <div class="container">
        <div class="section-title">
            <h2 class="colour2">What can DC offer your family?</h2>
            <span class="bg-colour1"></span>
        </div>
    </div>
    <div class="wrapper bg-colour2">
        <div class="container">
            <ul>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/b79a65f3539d94c3cefabf9a87e7eec7.png" alt="SIS offers icon-6" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">ESF Network</h3>
                            <div class="overlay bg-colour1">
                                <p>As part of the English Schools Foundation(ESF), our students are supported by the largest English-medium international school organisation in Hong Kong, providing them the resources and opportunities not found outside of ESF Schools.</p>
                                                                    <a  href="https://discovery.esf.edu.hk/en/about_us/ESF_family/" target="_blank" rel="nofollow">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/e695d61eb9962f34387474bf56a9e55b.png" alt="A Holistic Continuum" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">A Holistic Continuum</h3>
                            <div class="overlay bg-colour1">
                                <p>Discovery College promotes a holistic continuum that nurtures students' intellectual, emotional, and physical well-being, fostering growth and development for lifelong learning and success.</p>
                                                                    <a  href="https://discovery.esf.edu.hk/en/outstanding_education/curriculum/curriculum_overview" target="_blank" rel="nofollow">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/6925d72501641e769310324edbf159be.png" alt="Multicultural Environment" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Multicultural Environment</h3>
                            <div class="overlay bg-colour1">
                                <p>At ESF Discovery College, students thrive in a vibrant multicultural environment, learning from diverse perspectives that foster understanding, respect, and global citizenship in our interconnected world.</p>
                                                                    <a  href="https://discovery.esf.edu.hk/en/outstanding_education/inclusion/" target="_blank" rel="nofollow">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/3c80a5414207b82842cc577a6aab1408.png" alt="Wonderful Campus" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Wonderful Campus</h3>
                            <div class="overlay bg-colour1">
                                <p>Our stunning campus provides state-of-the-art facilities and inspiring spaces for learning, creativity, and collaboration, ensuring students enjoy a conducive environment that supports their educational journey.</p>
                                                                    <a  href="https://discovery.esf.edu.hk/en/outstanding_experiences/campus/" target="_blank" rel="nofollow">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/a6ee3e02ba124435bb3edf19b6ed8cbd.png" alt="Well Rounded Education" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Well Rounded Education</h3>
                            <div class="overlay bg-colour1">
                                <p>We emphasise on a well-rounded education, integrating academics, arts, and athletics, empowering students to explore their passions, develop critical skills, and prepare for a successful future in any field.</p>
                                                                    <a  href="https://discovery.esf.edu.hk/en/outstanding_experiences/co-curricular_experiences/" target="_blank" rel="nofollow">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                                    <li>
                        <div class="bg-colour3">
                                                            <img src="/cache/img/ad9a58af392b525ee52889c7334c01c3.png" alt="Scholarships" loading="lazy" width="270" height="270" />                             
                            <h3 class="colour1">Scholarships</h3>
                            <div class="overlay bg-colour1">
                                <p>At Discovery College, we celebrate exceptional students, offering scholarships to those excelling in academics, service, arts, and more. Our program recognizes talent and supports students to unlock their full potential.</p>
                                                                    <a  href="https://discovery.esf.edu.hk/en/admissions/scholarship_programme/" target="_blank" rel="nofollow">
                                        <span>Learn More</span>
                                    </a>
                                                            </div>
                        </div>
                    </li>
                            </ul>
        </div>
    </div>
    <script type="text/javascript">
        $(window).load(function() {
            $('h3', '#section2').each(function() {
                let img = $(this).parent().children('img');
                if(img.length) {
                    $(this).css('top', img.offset().top + img.height() + 25 - $(this).parent().offset().top);
                }
            });
        });
    </script>
</section>
<section id="section3">
    <img src="/cache/img/5749e5d3d296442bc22d2f6559e7a3fe.jpg" alt="DC_2024_MagazineAF-10" loading="lazy" width="1722" height="1294" />    <div class="wrapper">
        <div class="section-title-container">
            <div class="section-title">
                <h2 class="colour2">Academic Pathways</h2>
                <span class="bg-colour1"></span>
            </div>
        </div>
        <div class="tabs">
                            <button class="tab current" data-id="1">PYP</button>
                            <button class="tab" data-id="2">MYP</button>
                            <button class="tab" data-id="3">DP</button>
                            <button class="tab" data-id="4">CP</button>
                    </div>
        <select class="tab-select" name="tab"><option value="1">PYP</option><option value="2">MYP</option><option value="3">DP</option><option value="4">CP</option></select>                    <div class="tab-content current" data-id="1">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Years 1-6</h3>
                    </div>
                                <article class="editor"><p><span style="font-weight: 400;">The IB Primary Years Programme (PYP), for our students from Years 1 to 6, focuses on inquiry-based learning and developing internationally-minded individuals. The PYP provides a framework of six transdisciplinary themes to explore the world and foster a love of learning. The culmination of the experience is the PYP Exhibition where students showcase their learning in diverse and creative ways, evidencing their understanding and agency through taking action.</span></p></article>
                                    <a href="https://discovery.esf.edu.hk/en/outstanding_education/curriculum/curriculum_overview/PYP/" target="_blank" rel="nofollow">
                        <span>Learn More</span>
                    </a>
                            </div>
                    <div class="tab-content" data-id="2">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Years 7-11</h3>
                    </div>
                                <article class="editor"><p><span style="font-weight: 400;">Tailored for our Year 7 to Year 11 students, the IB Middle Years Programme (MYP) emphasises critical thinking and connecting learning to real-world issues. The programme culminates in a personal project demonstrating student inquiry and application of their acquired skills.&nbsp;</span></p>
<p>&nbsp;</p></article>
                                    <a href="https://discovery.esf.edu.hk/en/outstanding_education/curriculum/curriculum_overview/MYP/" target="_blank" rel="nofollow">
                        <span>Learn More</span>
                    </a>
                            </div>
                    <div class="tab-content" data-id="3">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Years 12-13</h3>
                    </div>
                                <article class="editor"><p><span style="font-weight: 400;">A rigorous pre-university course for students in Year 12 and Year 13, the IB Diploma Programme (DP) is recognised globally for its academic breadth and depth. Students study six subjects, while also undertaking core components such as the Extended Essay and Theory of Knowledge, which promote independent research and critical thinking skills.&nbsp;</span></p></article>
                                    <a href="https://discovery.esf.edu.hk/en/outstanding_education/curriculum/curriculum_overview/DP_CP/" target="_blank" rel="nofollow">
                        <span>Learn More</span>
                    </a>
                            </div>
                    <div class="tab-content" data-id="4">
                                    <div class="title">
                        <span class="bg-colour1"></span>
                        <h3 class="colour1">Years 12-13</h3>
                    </div>
                                <article class="editor"><p><span style="font-weight: 400;">The IB Career-related Programme (CP), offered to Year 12 and Year 13 students, combines real-word and practical career-related studies with academic rigour. The CP integrates a career-related core consisting of 4 components, with students offered to take two or more DP subjects. The CP prepares students for future pathways including apprenticeships, higher education and entry into employment.</span></p></article>
                                    <a href="https://discovery.esf.edu.hk/en/outstanding_education/curriculum/curriculum_overview/DP_CP/" target="_blank" rel="nofollow">
                        <span>Learn More</span>
                    </a>
                            </div>
                <script type="text/javascript">
            $(document).ready(function() {
                $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();

                $('.tab', '#section3').click(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $(this).addClass('current');
                    $('.tab-content[data-id=' + $(this).data('id') + ']', '#section3').addClass('current');
                    $('select', '#section3').val($(this).data('id')).selectbox('refresh');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });

                $('.tab-select', '#section3').change(function() {
                    $('.tab, .tab-content', '#section3').removeClass('current');
                    $('.tab[data-id=' + $(this).val() + ']').addClass('current');
                    $('.tab-content[data-id=' + $(this).val() + ']', '#section3').addClass('current');
                    $('.select .select-container div', '#section3').show();
                    $('.select .select-container div:nth-child(' + ($('.tab.current', '#section3').index() + 1) + ')', '#section3').hide();
                });
            });
        </script>
    </div>
</section>
<section id="section5" data-total="6">
