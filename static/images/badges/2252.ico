    <script type="text/javascript">
        $(document).ready(function() {
            const ori_total = parseInt($('#section5').data('total'));
            let slider_loop = ori_total >= 3 ? true : false;
            $('#section5').Slider({
                slides: '.record-item',
                maxSlide: 1,
                swipeControl: true,
                skipBoundary: true,
                infiniteLoop: slider_loop,
                dummySlide: slider_loop,
				afterSlide: function(slider, slides, current_page, total_page) {
					if(slider_loop) {
						if(current_page == ori_total) {
							slider.Slider('jump', ori_total * 2).Slider('start');
						}
						if(current_page == ori_total * 2 + 1) {
							slider.Slider('jump', ori_total + 1).Slider('start');
						}
					}
				},
                afterInit: function(slider, slides, current_page, total_page) {
                    if(slider_loop) {
                        slider.Slider('jump', ori_total + 1);
                    }
                }
            });
        });
    </script>
</section>
<section id="section6">
    <div class="container">
        <div class="section-title">
            <h2 class="colour2">Testimonials</h2>
            <span class="bg-colour1"></span>
        </div>
        <div class="wrapper">
            <div class="tabs">
                                    <button class="tab current" data-id="1">Students</button>
                                    <button class="tab" data-id="2">Parents</button>
                                    <button class="tab" data-id="3">Alumni</button>
                            </div>
            <select class="tab-select" name="tab"><option value="1">Students</option><option value="2">Parents</option><option value="3">Alumni</option></select>                            <div class="tab-content current" data-id="1">
                                            <div class="record-slider">
                            <div class="slider-container">
                                                                    <div class="record-item">
                                        <div class="left">
                                            <div class="thumbnail bg-colour1">
                                                <span></span>
                                                <img src="/cache/img/7bf68ac81baf48e468a884ebc09fa624.jpg" alt="DC_SELIVANOVA_Nadia_2024_Class10G_selivn1-1" loading="lazy" width="548" height="548" />                                            </div>
