<!DOCTYPE html>
<html lang="en" class="page-error">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=1.0, user-scalable=yes">
  <title>404 Not found</title>

<!-- icon -->
  <link rel="icon" href="/_skin/eng/layout/ico/favicon.ico" type="image/x-icon">
  <link rel="shortcut icon" href="/_skin/eng/layout/ico/favicon.ico" type="image/x-icon">
  <link rel="apple-touch-icon-precomposed" href="/_skin/eng/layout/image/mobileicon.png">

<!--jquery-->
  <script type="text/javascript" src="/js/jquery.js"></script>
  <script type="text/javascript" src="/js/jquery-migrate-3.0.0.min.js"></script>
  <script type="text/javascript" src="/js/jquery-ui-1.10.js"></script>

<!--sample-->
  <link rel="stylesheet" href="/_skin/eng/layout/css/base_en.css?ver=1581683841">

</head>
<body>

<main role="main" class="ly-main" id="skip-content" tabindex="0">
 <!-- 테스트용 임시 코딩 -->
<!-- 컨텐츠 영역 시작// -->
      <section class="ly-section error-section">
        <div class="ly-container">
          <div class="ly-inner">
            <figure class="figure">
              <img src="/webdata/uploads/eng/image/2020/02/logo-large.png" alt="SNU Logo" class="img" draggable="false">
              <div class="texts">
                <h2 class="title">Sorry</h2>
                <p class="desc">Page not found</p>
              </div>
              <div class="links">
                <a href="/" class="btn-link">SNU Home</a>
                <button type="button" target="_self" class="btn-link back es">Back</button>
              </div>
            </figure>
          </div>
        </div>
      </section>
    <!-- //컨텐츠 영역 끝 -->
 </main>

<script>
jQuery(function($) {
  $(document).ready(function(){
    $('.btn-link.back.es').on('click', function() {
      history.back();
    });
  });
});
</script>

</body>
</html>