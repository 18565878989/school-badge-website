<script>
document.addEventListener('DOMContentLoaded', function() {
    function adjustTitleLines() {
        const titles = document.querySelectorAll('#slider-news-section .title');
        
        titles.forEach(function(title) {
            const cellTitle = title.closest('.cell_title');
            const cellContent = title.closest('.cell_content');
            const topSection = cellContent.querySelector('.top');
            
            // 獲取可用高度（總高度減去 top 區域的高度）
            const cellContentHeight = cellContent.offsetHeight;
            const topHeight = topSection.offsetHeight;
            const availableHeight = cellContentHeight - topHeight - 10; // 減少減去的空間
            
            // 獲取單行文字高度
            const lineHeight = parseFloat(window.getComputedStyle(title).lineHeight);
            
            // 計算可顯示的行數，增加一點容錯空間
            const maxLines = Math.floor((availableHeight + 5) / lineHeight);
            
            // 設置行數限制（至少1行，最多10行）
            const clampedLines = Math.max(1, Math.min(maxLines, 10));
            
            title.style.webkitLineClamp = clampedLines;
            title.style.display = '-webkit-box';
            title.style.webkitBoxOrient = 'vertical';
            title.style.overflow = 'hidden';
            title.style.textOverflow = 'ellipsis';
        });
    }
    
    // 初始調整
    adjustTitleLines();
    
    // 視窗大小改變時重新調整
    window.addEventListener('resize', adjustTitleLines);
    
    // 使用 ResizeObserver 監聽容器大小變化
    const observer = new ResizeObserver(function(entries) {
        adjustTitleLines();
    });
    
    // 監聽所有 cell 元素
    const cells = document.querySelectorAll('#slider-news-section .cell');
    cells.forEach(function(cell) {
        observer.observe(cell);
    });
});
</script>


             

            
            
            
            

            
            
            
            
            
            
            
              

       
            

                                
