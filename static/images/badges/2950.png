			function equal_height() {
				$(window).resize(function() {
					if($(window).width()>=1024-getScrollBarWidth()) {
						/* height follow the biggest one*/
						len=$(".nd:not(.quicklink)").length;
						$(".nd").height("auto");
						width_array = [];
						for(i=0;i<len;i++) {
							width_array.push( $(".nd:not(.quicklink):eq("+i+")").height() );
						}
						max_width=Math.max.apply(null,width_array);
						$(".nd:not(.quicklink)").height(max_width);
						
						len=$(".news-title-b").length;
						$(".news-title-b").height("auto");
						width_array = [];
						for(i=0;i<=len;i++) {
							width_array.push( $(".news-title-b:eq("+i+")").height() );
						}
						max_width=Math.max.apply(null,width_array);
						$(".news-title-b").height(max_width);
						
						
						/* height follow the biggest one End*/
					} 
					if($(window).width()>750-getScrollBarWidth() && $(window).width()<1024-getScrollBarWidth()) {
						/* height follow the biggest one*/
						len=$(".news-div").length;
						$(".news-div").height("auto");
						width_array = [];
						for(i=0;i<len;i++) {
							width_array.push( $(".news-div:eq("+i+")").height() );
						}
						max_width=Math.max.apply(null,width_array);
						$(".news-div").height(max_width);
						/* height follow the biggest one End*/
						
						len=$(".news-title-b").length;
						$(".news-title-b").height("auto");
						width_array = [];
						for(i=0;i<len;i++) {
							width_array.push( $(".news-title-b:eq("+i+")").height() );
						}
						max_width=Math.max.apply(null,width_array);
						$(".news-title-b").height(max_width);
						
						
						$(".quicklink").height("auto");
					}
					if($(window).width()<=750-getScrollBarWidth()) {
						$(".nd").height("auto");
					}
				});
			}
			
			function slider1() {
				/* $('.slider1').cycle('pause'); */
				/* initial text */
				$(".slider1-title").html(banner_title[0]);
				$(".slider1-msg").html(banner_msg[0]);
				$(".slider1-tab").html(banner_tab[0]);
				$(".slider1 span:eq(0)").addClass("cycle-pager-active");
				
				$('.slider1').on('cycle-update-view', function (e, optionHash, slideOptionsHash, currSlideEl) {
					hit2++;
					if(hit2 % 2 == 1) { return false; }
					
					i=$(".slider1 .cycle-slide-active").attr("data");
					$(".slider1-title").html(banner_title[i]);
					$(".slider1-msg").html(banner_msg[i]);
					$(".slider1-tab").html(banner_tab[i]);
				});
			}
			
			function slider2() {
				/* initial text */
				$(".bannerb-box2 .bannerb-title").html($(".cycle-slide-active .bannerb-title").html());
				$(".bannerb-box2 .bannerb-msg").html($(".cycle-slide-active .bannerb-msg").html());
				$(".bannerb-box2 .bannerb-pager span:eq(0)").addClass("cycle-pager-active");
				
				$('.slider2').on('cycle-update-view', function (e, optionHash, slideOptionsHash, currSlideEl) {
					hit++;
					if(hit % 2 == 1) { return false; }
					$(".bannerb-box2 .bannerb-title").html($(".cycle-slide-active .bannerb-title").html());
					$(".bannerb-box2 .bannerb-msg").html($(".cycle-slide-active .bannerb-msg").html());
				});
			}
			
			function news() {
				$(".news-page").html("");
				html='<span class="news-circle">•</span>';
				num_of_page=3;
				news_len=news_title.length;
				
				for(i=0;i<news_len/num_of_page;i++) {
					$(".news-page").html($(".news-page").html()+html);
				}
				$(".news-circle").eq(0).addClass("news-circle-active");
						
				$(window).resize(function() {					
					if($(window).width()>=1024-getScrollBarWidth()) {
						num_of_page=3;
					}
					if($(window).width()<1023-getScrollBarWidth() && $(window).width()>750-getScrollBarWidth()) {			
						num_of_page=2;
					}
					if($(window).width()<=750-getScrollBarWidth()) {			
						num_of_page=1;
					}
					
					/* resize set to first content */
					for(i=0;i<num_of_page;i++) {
						if(news_img[i]) {
							$(".news-img").eq(i).attr("src","../files/event/thumbnail/"+news_img[i]);
							$(".news-title-b").eq(i).html(news_title[i]);
							$(".news-date").eq(i).html(news_date[i]);
							$(".news-msg").eq(i).html(news_msg[i]);
							if(news_link[i] != ""){
								$(".news-plus a").eq(i).attr("href",""+news_link[i]+"");
								$('.news-div').eq(i).attr('onClick','location.href="'+news_link[i]+'"');
							}else{
								$(".news-plus a").eq(i).css("display","none");	
							}
							//$(".news-plus a").eq(i).attr("href",""+news_link[i]+"");
						} else {
							$(".news-div").eq(i).hide();
						}
					}
					/* resize set to first content */
					
					$(".news-page").html("");
					for(i=0;i<news_len/num_of_page;i++) {
						$(".news-page").html($(".news-page").html()+html);
					}
					$(".news-pages1 .news-circle").eq(0).addClass("news-circle-active");
					$(".news-pages2 .news-circle").eq(0).addClass("news-circle-active");
					
					$(".news-pages1 .news-circle").click(function() {
						index=$(".news-pages1 .news-circle").index(this);
						$(".news-pages1 .news-circle").removeClass("news-circle-active");
						$(".news-pages1 .news-circle").eq(index).addClass("news-circle-active");
						cur_news=index*num_of_page;
						
						$(".news-div-container").fadeOut(function() {
							$(".news-div").css("display","inline-block");
							for(i=0;i<num_of_page;i++,cur_news++) {
								if(news_img[cur_news]) {
									$(".news-img").eq(i).attr("src","../files/event/thumbnail/"+news_img[cur_news]);
									$(".news-title-b").eq(i).html(news_title[cur_news]);
									$(".news-date").eq(i).html(news_date[cur_news]);
									$(".news-msg").eq(i).html(news_msg[cur_news]);
									if(news_link[cur_news] != ""){
										$(".news-plus a").eq(i).attr("href",""+news_link[cur_news]+"");
									}else{
										$(".news-plus a").eq(i).css("display","none");	
									}
									$('.news-div').eq(i).attr('onClick','location.href="'+news_link[cur_news]+'"');
								} else {
									$(".news-div").eq(i).hide();
								}
							}
							$(".news-div-container").fadeIn();
						});
					});
					
					$(".news-pages2 .news-circle").click(function() {
						index=$(".news-pages2 .news-circle").index(this);
						$(".news-pages2 .news-circle").removeClass("news-circle-active");
						$(".news-pages2 .news-circle").eq(index).addClass("news-circle-active");
						cur_news=index*num_of_page;
						
						$(".news-div-container").fadeOut(function() {
							$(".news-div").css("display","inline-block");
							for(i=0;i<num_of_page;i++,cur_news++) {
								if(news_img[cur_news]) {
									$(".news-img").eq(i).attr("src","../files/event/thumbnail/"+news_img[cur_news]);
									$(".news-title-b").eq(i).html(news_title[cur_news]);
									$(".news-date").eq(i).html(news_date[cur_news]);
									$(".news-msg").eq(i).html(news_msg[cur_news]);
									if(news_link[cur_news] != ""){
										$(".news-plus a").eq(i).attr("href",""+news_link[cur_news]+"");
									}else{
										$(".news-plus a").eq(i).css("display","none");	
									}
									//$(".news-plus a").eq(i).attr("href",""+news_link[cur_news]+"");
									$('.news-div').eq(i).attr('onClick','location.href="'+news_link[cur_news]+'"');
								} else {
									$(".news-div").eq(i).hide();
								}
							}
							$(".news-div-container").fadeIn();
						});
					});
				});
				
				/*previous,next button*/
				cur_news2=0;
				$(".news-previous").addClass("visibility");
				
				$(".news-previous").click(function() {
					cur_news2--;
					if(news_img[cur_news2]) {
						$(".news-img").eq(0).attr("src","../files/event/thumbnail/"+news_img[cur_news2]);
						$(".news-title-b").eq(0).html(news_title[cur_news2]);
						$(".news-date").eq(0).html(news_date[cur_news2]);
						$(".news-msg").eq(0).html(news_msg[cur_news2]);
						$(".news-next").removeClass("visibility");
						$(".news-div").eq(0).attr('onClick','location.href="'+news_link[cur_news2]+'"');
					}
					
					if(!news_img[cur_news2-1]) {
						$(".news-previous").addClass("visibility");
					}
				});
				
				$(".news-next").click(function() {
					cur_news2++;
					if(news_img[cur_news2]) {
						$(".news-img").eq(0).attr("src","../files/event/thumbnail/"+news_img[cur_news2]);
						$(".news-title-b").eq(0).html(news_title[cur_news2]);
						$(".news-date").eq(0).html(news_date[cur_news2]);
						$(".news-msg").eq(0).html(news_msg[cur_news2]);
						$(".news-previous").removeClass("visibility");
						$(".news-div").eq(0).attr('onClick','location.href="'+news_link[cur_news2]+'"');
					}
					
					if(!news_img[cur_news2+1]) {
						$(".news-next").addClass("visibility");
					}
				});
				
				$(window).resize(function() {
					cur_news2=0;
					$(".news-previous").addClass("visibility");
				});
			}
			
			
		</script>
