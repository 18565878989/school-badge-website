 <script type="text/javascript">

            document.onkeydown = function(e){
                var e=e || event;
                var currKey=e.keyCode||e.which||e.charCode;
                if(currKey == 13) {
                    doEClassLogins();
                }
            };
        function validates()
        {
			thisform =	document.loginforms;
            v =true;
            if (document.getElementById("UserLogin").value == ""){
                v = false;
                document.getElementById("UserLogin").focus();
            }
            if (v && document.getElementById("UserPassword").value ==	""){
                v = false;
                document.getElementById("UserPassword").focus();
            }
			
			/*
			if (v)
			thisform.elements["password"].value	= MD5(thisform.elements["password"].value);
			*/
			
            return v;
        }


        function doEClassLogins() {
            if (validates() )
            {
                document.forms["loginforms"].submit();
                document.getElementById("UserLogin").value="";
                document.getElementById("UserPassword").value="";
            }
        }






    </script>			</div>
