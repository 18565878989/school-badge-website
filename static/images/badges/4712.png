 <script type="text/javascript">

            document.onkeydown = function(e){
                var e=e || event;
                var currKey=e.keyCode||e.which||e.charCode;
                if(currKey == 13) {
                    doEClassLogins2();
                }
            };
        function validates2()
        {
			thisform =	document.loginforms2;
            v =true;
            if (document.getElementById("UserLogin2").value == ""){
                v = false;
                document.getElementById("UserLogin2").focus();
            }
            if (v && document.getElementById("UserPassword2").value ==	""){
                v = false;
                document.getElementById("UserPassword2").focus();
            }
			
			/*
			if (v)
			thisform.elements["password"].value	= MD5(thisform.elements["password"].value);
			*/
			
            return v;
        }


        function doEClassLogins2() {
            if (validates2() )
            {
                document.forms["loginforms2"].submit();
                document.getElementById("UserLogin2").value="";
                document.getElementById("UserPassword2").value="";
            }
        }






    </script>
