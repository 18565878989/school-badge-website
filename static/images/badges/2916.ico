						<script data-cfasync="false" type="text/javascript">
					(function() {
		/* Add Material Icon */
		const head = document.head;
		const materialIconLink = document.createElement('link');
		materialIconLink.rel = 'stylesheet';
		materialIconLink.href = 'https://fonts.googleapis.com/icon?family=Material+Icons';
		head.appendChild(materialIconLink);
		/* Add mobile function rows */
		const nav = document.getElementsByClassName('tm-table');
		const check = document.getElementsByClassName('nav-icon-bar');
		if(nav.length > 0 && check.length === 0) {
				const div = document.createElement('div');
			 	div.innerHTML = `
<span id="nav_toggle_languages" class="material-icons nav-icon">language</span>
<span id="nav_toggle_search" class="material-icons nav-icon">search</span>
<span class="material-icons nav-icon" onclick="eClassToggleDialogActive()">school</span>
`;
				nav[0].insertBefore(div, nav[0].firstChild);
				div.classList.add('nav-icon-bar');
				
				const languageRow = document.createElement('div');
				languageRow.id = 'nav_toggle_languages_row';
				languageRow.innerHTML = `
<a href="https://www.tangkingpo.edu.hk" class="nav-icon">繁</a>
<a href="https://www.tangkingpo.edu.hk" class="nav-icon">Eng</a>
`;
				languageRow.classList.add('nav-function-row');
				
				const searchRow = document.createElement('div');
				searchRow.id = 'nav_toggle_search_row';
				searchRow.innerHTML = `
<form action="https://www.tangkingpo.edu.hk/" method="get" role="search">
	<input type="text" name="s" placeholder="搜尋..." />
	<button type="submit" name="button" class="button">搜尋</button>
</form>
`;
				searchRow.classList.add('nav-function-row');
				
				const eclassRow = document.createElement('div');
				eclassRow.id = 'nav_toggle_eclass_row';
				eclassRow.innerHTML = `
<form method="post" action="https://eclass.tangkingpo.edu.hk/login.php" onsubmit="return checkLoginForm(this);" target="_blank">
	<input name="UserLogin" type="text" placeholder="eClass Login" />
	<input name="UserPassword" type="password" placeholder="Password" />
	<button type="submit" name="button" class="button">Login</button>
</form>
`;
				eclassRow.classList.add('nav-function-row');
				const header = document.getElementById('masthead');
				header.appendChild(languageRow);
				header.appendChild(searchRow);
				header.appendChild(eclassRow);
				
				['nav_toggle_languages', 'nav_toggle_search', 'nav_toggle_eclass'].map(key=> {
					const element = document.getElementById(key);
					if(!!element) {
						element.addEventListener('click', function() {
							const rowId = `${key}_row`;
							const arr = document.getElementsByClassName('nav-function-row active');
							for(let i = 0; i < arr.length; i++) {
								if(arr[i].id !== rowId) {
									 arr[i].classList.remove('active');
								}
							}
							const row = document.getElementById(rowId);
							if(!!row) row.classList.toggle('active');
						});
					}
				});
		}
})();				</script>
							<script>
				const lazyloadRunObserver = () => {
					const lazyloadBackgrounds = document.querySelectorAll( `.e-con.e-parent:not(.e-lazyloaded)` );
					const lazyloadBackgroundObserver = new IntersectionObserver( ( entries ) => {
						entries.forEach( ( entry ) => {
							if ( entry.isIntersecting ) {
								let lazyloadBackground = entry.target;
								if( lazyloadBackground ) {
									lazyloadBackground.classList.add( 'e-lazyloaded' );
								}
								lazyloadBackgroundObserver.unobserve( entry.target );
							}
						});
					}, { rootMargin: '200px 0px 200px 0px' } );
					lazyloadBackgrounds.forEach( ( lazyloadBackground ) => {
						lazyloadBackgroundObserver.observe( lazyloadBackground );
					} );
				};
				const events = [
					'DOMContentLoaded',
					'elementor/lazyload/observe',
				];
				events.forEach( ( event ) => {
					document.addEventListener( event, lazyloadRunObserver );
				} );
			</script>
