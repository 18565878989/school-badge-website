<!-- start Simple Custom CSS and JS -->
<style>
  .search-login-dialog-base {
    display: none;
    position: fixed;
    top: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(60,60,60,0.8);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }
  .search-login-dialog-base.active {
    display: flex !important;
  }
  .search-login-dialog {
    position: relative;
    width: 95%;
    max-width: 300px;
    height: 95%;
    max-height: 150px;
    padding: 2rem;
    background-color: white;
    border-radius: 12px;
  }
  .search-form {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }
  .search-form > .material-icons {
    font-size: 3.2em;
  }
  .search-form > input {
    width: 100%;
    margin-top: 12px;
    margin-bottom: 12px;
    border-radius: 30px !important;
  }
  .search-form > .text-input {
    padding-top: 12px;
    padding-bottom: 12px;
    padding-left: 14px;
    padding-right: 14px;
  }
  .search-form > .error-message {
    color: #e53935;
  }
  .search-login-dialog .close-btn {
    position: absolute;
    top: 12px;
    right: 12px;
    cursor: pointer;
    opacity: 0.6;
  }
  .search-login-dialog .close-btn:hover {
    opacity: 1 !important;
  }
  .site-header .navbar-nav {
    text-align: center !important;
  }
  
  
  nav.width-navigation.table-cell.table-right {
    display: flex !important;
    flex-direction: column !important;
    align-items: stretch !important;
  }
  nav.width-navigation.table-cell.table-right div.nav-btn-row {
    text-align: right;
    margin-right: 1rem;
  }
  @media (max-width: 1024px) {
    nav.width-navigation.table-cell.table-right > ul div.nav-btn-row.desktop {
      display: none;
    }
    .widget_text.widget.widget_custom_html {
      list-style-type: none;
    }
  }
  div.nav-btn-row button {
    max-height: 35px;
  }
  div.nav-btn-row img {
    height: 30px;
    margin-bottom: 10px !important;
  }
  @media (min-width: 1200px) {
    .navigation .navbar-nav>li>a, .navigation .navbar-nav>li>span {
      padding-left: 20px !important;
      padding-right: 20px !important;
    }
  }
  @media (min-width: 1100px) and (max-width: 1199px) {
    .navigation .navbar-nav>li>a, .navigation .navbar-nav>li>span {
      padding-left: 17px !important;
      padding-right: 17px !important;
    }
  }
  .navigation .navbar-nav>li>a, .navigation .navbar-nav>li>span {
    padding-left: 10px !important;
    padding-right: 10px !important;
  }
  #search_form {
    display: flex;
    flex-direction: column;
  }
  #search_input {
    margin-top: 25px;
    margin-bottom: 10px;
  }
  #nav_toggle_languages {
    display: none !important;
  }
</style>

<div id="search_login_dialog" class="search-login-dialog-base" onclick="SearchToggleDialogActive()">
  <div class="search-login-dialog" onclick="SearchDialogChild(event)">
    <span class="material-icons close-btn" onclick="SearchToggleDialogActive()">close</span>

    <form id="search_form" onsubmit="return searchSubmit(event)">
      <input id="search_input" type="text" placeholder="通告、校園資訊⋯"/>
      <input type="submit" value="Go"/>
    </form>
  </div>
</div>

<script>
  function SearchToggleDialogActive() {
    const element = document.getElementById("search_login_dialog");
    element.classList.toggle("active");
    toggleSearchForm();
  }
  function SearchDialogChild(event) {
    event.stopPropagation();
  }
  window.onload = function() {
        const {href} = window.location;
        if(href.includes("/?s=")) {
            const arr = href.split("/?s=");
            const inputElem = document.getElementById("search_input");
            inputElem.value = arr[1];
            const formElem = document.getElementById("search_form");
            formElem.classList.add("active");
        }
    };
    function toggleSearchForm() {
      const {href} = window.location;
        if(href.includes("/?s=")) {
            const arr = href.split("/?s=");
            const inputElem = document.getElementById("search_input");
            inputElem.value = arr[1];
            const formElem = document.getElementById("search_form");
            formElem.classList.add("active");
        }
      else{
        const formElem = document.getElementById("search_form");
        formElem.classList.toggle("active");
        const inputElem = document.getElementById("search_input");
        inputElem.focus();
      }
    }
    function searchSubmit(event) {
//         event.preventdefault();
        const element = document.getElementById("search_input");
        if(element.value !== "") {
            console.log(`https://www.tangkingpo.edu.hk/?s=${element.value}`);
            window.location.href = `https://www.tangkingpo.edu.hk/?s=${element.value}`;
            return false;
        } else {
//             event.preventdefault();
            return false;
        }
    }
  
  	setTimeout(() => {
      const mainNavElems = document.getElementsByClassName('thim-nav-wrapper container');
      if(mainNavElems.length > 0) {
        const elem = mainNavElems[0];
        // Make the nav bar full width
        elem.classList.remove('container');
        
        const actionElems = elem.getElementsByClassName('menu-right');
        if(actionElems.length > 0) {
          const actionElem = actionElems[0];
          const ulElem = actionElem.childNodes[0];
          actionElem.remove();
          
          const navElems = elem.getElementsByClassName('width-navigation table-cell table-right');
          if(navElems.length > 0) {
            const navElem = navElems[0];
            navElem.appendChild(ulElem);
            
            const rowElem = ulElem.getElementsByClassName('nav-btn-row')[0];
            rowElem.classList.add('desktop');
              
            const rows = document.getElementsByClassName('nav-btn-row');
            for(let i = 0; i < rows.length; i++) {
              const hyreadImg = document.createElement('img');
              hyreadImg.setAttribute('src', 'https://www.tangkingpo.edu.hk//wp-content/uploads/2021/10/logo_hyread.png');
              const hyreadLink = document.createElement('button');
              hyreadLink.setAttribute('class', 'nav-btn');
              hyreadLink.setAttribute('onClick', 'window.open("https://tangkingpohk.ebook.hyread.com.tw/index.jsp", "_blank")');
              hyreadLink.appendChild(hyreadImg);
              rows[i].appendChild(hyreadLink);
            }
          }
        }
      }
	  /*Adj*/
		console.log('script works');
	const nav_mobile_icons = document.getElementsByClassName('nav-icon-bar');
	const hyreadImg2 = document.createElement('img');
	hyreadImg2.setAttribute('src', 'https://www.tangkingpo.edu.hk//wp-content/uploads/2021/10/logo_hyread.png');
	const hyreadLink2 = document.createElement('button');
	/*hyreadLink2.setAttribute('class', 'nav-btn');*/
	hyreadLink2.setAttribute('onClick', 'window.open("https://tangkingpohk.ebook.hyread.com.tw/index.jsp", "_blank")');
	hyreadLink2.appendChild(hyreadImg2);
	nav_mobile_icons[0].appendChild(hyreadLink2);
    }, 100);
    
</script><!-- end Simple Custom CSS and JS -->
