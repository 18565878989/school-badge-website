<style>
  .eclass-login-dialog-base {
    display: none;
    position: fixed;
    top: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(60,60,60,0.8);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }
  .eclass-login-dialog-base.active {
    display: flex !important;
  }
  .eclass-login-dialog {
    position: relative;
    width: 95%;
    max-width: 300px;
    height: 95%;
    max-height: 450px;
    padding: 2rem;
    background-color: white;
    border-radius: 12px;
  }
  .eclass-form {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }
  .eclass-form > .material-icons {
    font-size: 3.2em;
  }
  .eclass-form > input {
    width: 100%;
    margin-top: 12px;
    margin-bottom: 12px;
    border-radius: 30px !important;
  }
  .eclass-form > .text-input {
    padding-top: 12px;
    padding-bottom: 12px;
    padding-left: 14px;
    padding-right: 14px;
  }
  .eclass-form > .error-message {
    color: #e53935;
  }
  .eclass-login-dialog .close-btn {
    position: absolute;
    top: 12px;
    right: 12px;
    cursor: pointer;
    opacity: 0.6;
  }
  .eclass-login-dialog .close-btn:hover {
    opacity: 1 !important;
  }
  #nav_toggle_languages {
    display: none !important;
  }
</style>

<div id="eclass_login_dialog" class="eclass-login-dialog-base" onclick="eClassToggleDialogActive()">
  <div class="eclass-login-dialog" onclick="eClassDialogChild(event)">
    <span class="material-icons close-btn" onclick="eClassToggleDialogActive()">close</span>
    <form method="post" action="https://eclass.tangkingpo.edu.hk/login.php" onsubmit="eClassFormValidate(event)" target="_blank" class="eclass-form">
      <span class="material-icons">school</span>
      <h3>eClass 登入</h3>
      <input type="text" name="UserLogin" id="name" class="text-input" placeholder="eClass Login" >
	  <input type="password" name="UserPassword" id="password" class="text-input" placeholder="Password">
	  <input type="submit" name="button" id="button" value="Login" class="btn">
      <h6 id="eclass_login_error_message" class="error-message"></h6>
    </form>
  </div>
</div>

<script>
  function eClassToggleDialogActive() {
    const element = document.getElementById("eclass_login_dialog");
    element.classList.toggle("active");
  }
  function eClassDialogChild(event) {
    event.stopPropagation();
  }
  function eClassFormValidate(event) {
    if(document.getElementById("name").value === "" || document.getElementById("password").value === "") {
      event.preventDefault();
      const element = document.getElementById("eclass_login_error_message");
      element.innerHTML = "請輸入用戶名稱和密碼"
      return false;
    } else {
      return true;
    }
  }
</script><!-- end Simple Custom CSS and JS -->
