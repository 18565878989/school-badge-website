	$(window).load(function() {
		var animate = function() {
			var height = $(window).scrollTop() + Math.round($(window).height() * 0.8);
			$.each($('#content > div'), function(key, value) {
				if(! $(this).hasClass('animate') && height > $(this).offset().top)
				{
					$(this).addClass('animate');
				}
			});	
			if(! $('.news_inner').hasClass('animatec') && $('.news_box').hasClass('animate'))
			{
				   $('.news_inner .news_loop').each(function(k,v) {
						setTimeout(function () {
							$s = k +1;
							$('.news_inner .news_loop:nth-child('+ $s +')').addClass('animate');
						}, k * 250);
				  });
					$('.news_inner').addClass('animatec');
			}
			if(! $('.edu_inner').hasClass('animatec') && $('.edu_box').hasClass('animate'))
			{
				   $('.edu_inner .edu_cate').each(function(k,v) {
						setTimeout(function () {
							$s = k +1;
							$('.edu_inner .edu_cate:nth-child('+ $s +')').addClass('animate');
						}, k * 400);
				  });
					$('.edu_inner').addClass('animatec');
			}
		};
		$(window).on('scroll', animate);
		animate();
	});
</script>
