<style>
.cloud1 {
    height: 415px;
    width: 100%;
    z-index: -1;
    position: absolute;
    pointer-events: none;
    top: 0px;
}
.cloud2 {
    height: 415px;
    width: 100%;
    z-index: -1;
    position: absolute;
    pointer-events: none;
    top: 0px;
}
.cloud1 div {
    width: 1800px;
    height: 415px;
    position: absolute;
    animation: myfirst 70s linear infinite;
    -o-animation: myfirst 70s linear infinite;
    -moz-animation: myfirst 70s linear infinite;
    -webkit-animation: myfirst 70s linear infinite;
    background: url(https://www.karlam.edu.hk/wp-content/uploads/2021/09/header_aniCloud1.png) no-repeat center 0;
    background-size: 1800px 415px;
}
.cloud2 div {
    top: 0px;
    left: 0px;
    width: 1800px;
    height: 415px;
    position: absolute;
    animation: myfirst 70s linear infinite;
    -o-animation: myfirst 70s linear infinite;
    -moz-animation: myfirst 70s linear infinite;
    -webkit-animation: myfirst 70s linear infinite;
    background: url(https://www.karlam.edu.hk/wp-content/uploads/2021/09/header_aniCloud2.png) no-repeat center 0;
    background-size: 1800px 415px;
}
@keyframes myfirst {
  0% {
    left: 0%;
  }
  100% {
    left: 100%;
  }
}

</style>
