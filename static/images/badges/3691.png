6a44964269b37fee7fbbdb0a3e~mv2.jpg/v1/crop/x_245,y_0,w_2912,h_5616/fill/w_1120,h_2160,al_c,q_90,usm_0.66_1.00_0.01,enc_avif,quality_auto/IMG_2206.jpg 2x" id="img_comp-kguix4mx1" src="https://static.wixstatic.com/media/7f1702_49fb9f6a44964269b37fee7fbbdb0a3e~mv2.jpg/v1/crop/x_245,y_0,w_2912,h_5616/fill/w_560,h_1080,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/IMG_2206.jpg" alt="IMG_2206.jpg" style="object-fit:cover" class="BI8PVQ Tj01hh" width="560" height="1080"/></div></div><div id="comp-kguix4mx2" class="jbrj02 comp-kguix4mx2"><div class="IvR70V wixui-box" data-testid="container-bg"></div><div data-mesh-id="comp-kguix4mx2inlineContent" data-testid="inline-content" class=""><div data-mesh-id="comp-kguix4mx2inlineContent-gridContainer" data-testid="mesh-container-content"><div id="comp-lmmytajc" class="comp-lmmytajc SPY_vo"><div data-mesh-id="comp-lmmytajcinlineContent" data-testid="inline-content" class=""><div data-mesh-id="comp-lmmytajcinlineContent-gridContainer" data-testid="mesh-container-content"><div id="comp-kguix4mx3" class="ku3DBC zQ9jDz qvSjx3 Vq6kJx comp-kguix4mx3 wixui-rich-text" data-testid="richTextElement"><h3 class="font_3 wixui-rich-text__text" style="font-size:30px; text-align:left;"><span style="font-size:30px;" class="wixui-rich-text__text">Not your average kindergarten.</span></h3></div><div id="comp-kguix4mx4" class="ku3DBC zQ9jDz qvSjx3 Vq6kJx comp-kguix4mx4 wixui-rich-text" data-testid="richTextElement"><p class="font_7 wixui-rich-text__text" style="line-height:1.67em; font-size:20px;"><span style="letter-spacing:normal;" class="wixui-rich-text__text"><span class="color_15 wixui-rich-text__text"><span style="font-weight:700;" class="wixui-rich-text__text">Leaders of the future.</span></span></span></p></div><div id="comp-kguix4my" class="ku3DBC zQ9jDz qvSjx3 Vq6kJx comp-kguix4my wixui-rich-text" data-testid="richTextElement"><p class="font_8 wixui-rich-text__text" style="line-height:1.75em; font-size:15px;"><span style="letter-spacing:normal;" class="wixui-rich-text__text"><span class="color_15 wixui-rich-text__text">Every child is born with an innate interest to learn and explore.</span></span></p>

<p class="font_8 wixui-rich-text__text" style="line-height:1.75em; font-size:15px;">&nbsp;</p>

<p class="font_8 wixui-rich-text__text" style="line-height:1.75em; font-size:15px;"><span style="letter-spacing:normal;" class="wixui-rich-text__text"><span class="color_15 wixui-rich-text__text">Early Childhood Education should not be designed to single-mindedly overload children with factual knowledge in order to help them &lsquo;win&rsquo; at the starting line.</span></span></p>

<p class="font_8 wixui-rich-text__text" style="line-height:1.75em; font-size:15px;">&nbsp;</p>

<p class="font_8 wixui-rich-text__text" style="line-height:1.75em; font-size:15px;"><span style="letter-spacing:normal;" class="wixui-rich-text__text"><span class="color_15 wixui-rich-text__text">Instead, young learners should seek to improve their moral, intellectual, physical, social and aesthetic skills equally in a safe, happy and healthy environment. In an ever-changing society, we hope that by cultivating children&rsquo;s holistic development, they will be better equipped in tackling unforeseeable challenges of the future.&nbsp;</span></span></p></div></div></div></div></div></div></div></div></div></div></div></section></div></div></section><section id="comp-lhg41mbg2" tabindex="-1" class="Oqnisf comp-lhg41mbg2 wixui-section" data-block-level-container="ClassicSection"><div id="bgLayers_comp-lhg41mbg2" data-hook="bgLayers" data-motion-part="BG_LAYER comp-lhg41mbg2" class="MW5IWV"><div data-testid="colorUnderlay" class="LWbAav Kv1aVt"></div><div id="bgMedia_comp-lhg41mbg2" data-motion-part="BG_MEDIA comp-lhg41mbg2" class="VgO9Yg"></div></div><div data-mesh-id="comp-lhg41mbg2inlineContent" data-testid="inline-content" class=""><div data-mesh-id="comp-lhg41mbg2inlineContent-gridContainer" data-testid="mesh-container-content"><section id="comp-kgufd56z" class="comp-kgufd56z CohWsy wixui-column-strip"><div id="bgLayers_comp-kgufd56z" data-hook="bgLayers" data-motion-part="BG_LAYER comp-kgufd56z" class="if7Vw2"><div data-testid="colorUnderlay" class="tcElKx i1tH8h"></div><div id="bgMedia_comp-kgufd56z" data-motion-part="BG_MEDIA comp-kgufd56z" class="wG8dni"></div></div><div data-testid="columns" class="V5AUxf"><div id="comp-kgufd56z1" class="comp-kgufd56z1 YzqVVZ wixui-column-strip__column"><div id="bgLayers_comp-kgufd56z1" data-hook="bgLayers" data-motion-part="BG_LAYER comp-kgufd56z1" class="MW5IWV"><div data-testid="colorUnderlay" class="LWbAav Kv1aVt"></div><div id="bgMedia_comp-kgufd56z1" data-motion-part="BG_MEDIA comp-kgufd56z1" class="VgO9Yg"><wow-image id="img_comp-kgufd56z1" class="jhxvbR Kv1aVt dLPlxY mNGsUM bgImage" data-image-info="{&quot;containerId&quot;:&quot;comp-kgufd56z1&quot;,&quot;displayMode&quot;:&quot;fill&quot;,&quot;targetWidth&quot;:980,&quot;targetHeight&quot;:1060,&quot;isLQIP&quot;:true,&quot;encoding&quot;:&quot;AVIF&quot;,&quot;imageData&quot;:{&quot;width&quot;:5616,&quot;height&quot;:3744,&quot;uri&quot;:&quot;7f1702_2eb4ba9281414a589342cb20e423fd3d~mv2.jpg&quot;,&quot;name&quot;:&quot;&quot;,&quot;displayMode&quot;:&quot;fill&quot;,&quot;focalPoint&quot;:{&quot;x&quot;:50,&quot;y&quot;:50}}}" data-motion-part="BG_IMG comp-kgufd56z1" data-bg-effect-name="" data-has-ssr-src="true"><img src="https://static.wixstatic.com/media/7f1702_2eb4ba9281414a589342cb20e423fd3d~mv2.jpg/v1/fill/w_147,h_98,al_c,q_80,usm_0.66_1.00_0.01,blur_2,enc_avif,quality_auto/7f1702_2eb4ba9281414a589342cb20e423fd3d~mv2.jpg" alt="IMG_2316.jpg" style="width:100%;height:100%;object-fit:cover;object-position:50% 50%" width="980" height="1060"/></wow-image></div></div><div data-mesh-id="comp-kgufd56z1inlineContent" data-testid="inline-content" class=""><div data-mesh-id="comp-kgufd56z1inlineContent-gridContainer" data-testid="mesh-container-content"><div id="comp-kuhqn7mn" class="jbrj02 comp-kuhqn7mn"><div class="IvR70V wixui-box" data-testid="container-bg"></div><div data-mesh-id="comp-kuhqn7mninlineContent" data-testid="inline-content" class=""><div data-mesh-id="comp-kuhqn7mninlineContent-gridContainer" data-testid="mesh-container-content"><div id="comp-kgujmq86" class="ku3DBC zQ9jDz qvSjx3 Vq6kJx comp-kgujmq86 wixui-rich-text" data-testid="richTextElement"><h3 class="font_3 wixui-rich-text__text" style="font-size:30px; text-align:left;"><span class="color_11 wixui-rich-text__text"><span style="font-size:30px;" class="wixui-rich-text__text">Our Mission</span></span></h3></div><div id="comp-kgujmq881" class="ku3DBC zQ9jDz qvSjx3 Vq6kJx comp-kgujmq881 wixui-rich-text" data-testid="richTextElement"><p class="font_7 wixui-rich-text__text" style="font-size:20px; text-align:left;"><span class="color_11 wixui-rich-text__text"><span style="font-size:20px;" class="wixui-rich-text__text">Our goal as a school is to provide a nurturing environment for young learners of all nationalities, languages and cultural backgrounds to cultivate and develop their holistic potential in becoming responsible, respectful and resilient citizens of our world.</span></span></p></div><div class="comp-kuhqqiml FubTgk" id="comp-kuhqqiml" aria-disabled="false"><a data-testid="linkElement" href="https://www.kindergarten.edu.hk/why-tivoli" target="_self" class="uDW_Qe wixui-button PlZyDq" aria-disabled="false" aria-label="Discover More"><span class="l7_2fn wixui-button__label">Discover More</span></a></div></div></div></div></div></div></div></div></section></div></div></section><section id="comp-lhg41mbg3" tabindex="-1" class="Oqnisf comp-lhg41mbg3 wixui-section" data-block-level-container="ClassicSection"><div id="bgLayers_comp-lhg41mbg3" data-hook="bgLayers" data-motion-part="BG_LAYER comp-lhg41mbg3" class="MW5IWV"><div data-testid="colorUnderlay" class="LWbAav Kv1aVt"></div><div id="bgMedia_comp-lhg41mbg3" data-motion-part="BG_MEDIA comp-lhg41mbg3" class="VgO9Yg"></div></div><div data-mesh-id="comp-lhg41mbg3inlineContent" data-testid="inline-content" class=""><div data-mesh-id="comp-lhg41mbg3inlineContent-gridContainer" data-testid="mesh-container-content"><div id="comp-kj0156su" class="MazNVa comp-kj0156su wixui-image"><div data-testid="linkElement" class="j7pOnl"><img loading="lazy" sizes="666px" srcSet="https://static.wixstatic.com/media/7f1702_f0aa01be0cc649128a36e8b8fcc135d4~mv2.png/v1/fill/w_666,h_716,al_c,q_90,usm_0.66_1.00_0.01,enc_avif,quality_auto/Tioli%20Map%20(08-2025).png 1x, https://static.wixstatic.com/media/7f1702_f0aa01be0cc649128a36e8b8fcc135d4~mv2.png/v1/fill/w_1332,h_1432,al_c,q_90,usm_0.66_1.00_0.01,enc_avif,quality_auto/Tioli%20Map%20(08-2025).png 2x" id="img_comp-kj0156su" src="https://static.wixstatic.com/media/7f1702_f0aa01be0cc649128a36e8b8fcc135d4~mv2.png/v1/fill/w_666,h_716,al_c,q_90,usm_0.66_1.00_0.01,enc_avif,quality_auto/Tioli%20Map%20(08-2025).png" alt="Tioli Map (08-2025).png" style="object-fit:cover" class="BI8PVQ Tj01hh" width="666" height="716"/></div></div><div id="comp-kj015qa1" class="ku3DBC zQ9jDz qvSjx3 Vq6kJx comp-kj015qa1 wixui-rich-text" data-testid="richTextElement"><h3 class="font_3 wixui-rich-text__text" style="font-size:30px;"><span style="font-size:30px;" class="wixui-rich-text__text">Our campuses</span></h3></div><div id="comp-kj016fdo" class="ku3DBC zQ9jDz qvSjx3 Vq6kJx comp-kj016fdo wixui-rich-text" data-testid="richTextElement"><p class="font_8 wixui-rich-text__text" style="font-size:15px;"><span style="text-decoration:underline;" class="wixui-rich-text__text"><a href="https://www.kindergarten.edu.hk/tivoli-anglo-chinese-kindergarten" target="_self" class="wixui-rich-text__text"><span style="font-weight:bold;" class="wixui-rich-text__text"><span style="font-size:15px;" class="wixui-rich-text__text">Tivoli Anglo-Chinese Kindergarten (TK)</span></span></a></span></p>

<p class="font_8 wixui-rich-text__text" style="font-size:15px;"><span style="font-size:15px;" class="wixui-rich-text__text">G/F, Block 4, Tivoli Garden, 75 Tsing King Road, Tsing Yi</span></p>

<p class="font_8 wixui-rich-text__text" style="font-size:15px;"><span style="font-size:15px;" class="wixui-rich-text__text"><span class="wixui-rich-text__text">​</span></span></p>

<p class="font_8 wixui-rich-text__text" style="font-size:15px;"><span style="text-decoration:underline;" class="wixui-rich-text__text"><span style="font-weight:bold;" class="wixui-rich-text__text"><span style="font-size:15px;" class="wixui-rich-text__text">Tivoli Kindergarten &amp; Nursery (Ching Fu)</span></span></span></p>

<p class="font_8 wixui-rich-text__text" style="font-size:15px;"><span style="font-size:15px;" class="wixui-rich-text__text">G/F, Block A, Ching Fu Court, Tsing Yi,&nbsp;</span></p></div></div></div></section></div></div></div></div></div></div></div></main><footer id="SITE_FOOTER" class="xU8fqS SITE_FOOTER wixui-footer" tabindex="-1"><div class="_C0cVf"><div class="_4XcTfy" data-testid="screenWidthContainerBg"></div></div><div class="U4Bvut"><div class="G5K6X8"><div class="gUbusX" data-testid="screenWidthContainerBgCenter"></div></div><div class="CJF7A2"><div data-mesh-id="SITE_FOOTERinlineContent" data-testid="inline-content" class=""><div data-mesh-id="SITE_FOOTERinlineContent-gridContainer" data-testid="mesh-container-content"><div id="comp-kglnxo331" class="comp-kglnxo331 WzbAF8"><ul class="mpGTIt" aria-label="Social Bar"><li id="dataItem-kglnxo7e1-comp-kglnxo331" class="O6KwRn"><a data-testid="linkElement" href="https://www.facebook.com/tktntivoli" target="_blank" rel="noreferrer noopener" class="oRtuWN" aria-label="Facebook"><img sizes="20px" srcSet="https://static.wixstatic.com/media/0fdef751204647a3bbd7eaa2827ed4f9.png/v1/fill/w_20,h_20,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/0fdef751204647a3bbd7eaa2827ed4f9.png 1x, https://static.wixstatic.com/media/0fdef751204647a3bbd7eaa2827ed4f9.png/v1/fill/w_40,h_40,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/0fdef751204647a3bbd7eaa2827ed4f9.png 2x" id="img_0_comp-kglnxo331" src="https://static.wixstatic.com/media/0fdef751204647a3bbd7eaa2827ed4f9.png/v1/fill/w_20,h_20,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/0fdef751204647a3bbd7eaa2827ed4f9.png" alt="Facebook" style="object-fit:cover" class="YaS0jR Tj01hh" width="20" height="20"/></a></li><li id="dataItem-kxolq8qe-comp-kglnxo331" class="O6KwRn"><a data-testid="linkElement" href="https://www.instagram.com/tivoli_kindergarten/" target="_blank" rel="noreferrer noopener" class="oRtuWN" aria-label="Instagram"><img sizes="20px" srcSet="https://stat