		<style type="text/css" id="wp-custom-css">
			/*EventON Callendar*/

.eventon_events_list .eventon_list_event .evoet_cx span.evcal_desc2, .evo_pop_body .evoet_cx span.evcal_desc2{
	text-transform: none !important;
	color: black !important;
}

.eventon_events_list .eventon_list_event .evcal_cblock em, .evo_pop_body .evcal_cblock em{
	color: black !important;
	text-transform: none !important;
}

.ajde_evcal_calendar .calendar_header p, .ajde_evcal_calendar .evo_footer_nav p{
	text-transform: capitalize !important;
}

.ajde_evcal_calendar.color #evcal_list .eventon_list_event p .desc_trig, .evo_lightboxes .color.eventon_list_event .evopop_top, .evo_lightboxes .color.eventon_list_event .evcal_list_a{
	background-color: transparent !important;
}

.eventon_events_list .eventon_list_event .evoet_cx span.evcal_desc2, .evo_pop_body .evoet_cx span.evcal_desc2{
  font-size: 15px;
	color: #990000 !important;
	font-weight: 400;
	font-family: Roboto, sans-serif;
}

.evcal_cblock .evo_start{
	font-size: 15px;
}

.eventon_events_list .eventon_list_event .evcal_cblock em, .evo_pop_body .evcal_cblock em{
	color: #4f4f4f !important;
}

#evcal_list .eventon_list_event p.no_events, .evo_eventon_now .no_events{
	text-transform: none;
}

.eventon_fullcal .eventon_fc_days .evo_fc_day.on_focus{
	color: white !important;
}

.today .day_evs i{
	background-color: white !important;
}

/*EventON Full Cal Customization*/
.eventon_fullcal p{
	text-transform: capitalize;
}

.eventon_fullcal .eventon_fc_daynames .evo_fc_day{
	background: none;
}

.eventon_fullcal .evo_fc_day{
	display: block !important;
	
}

.eventon_fullcal .evo_fc_day.bb, .eventon_fullcal .evo_fc_day.nobrt, .eventon_fullcal .evo_fc_day.blsr, .eventon_fullcal .evo_fc_day.br, .eventon_fc_days, .eventon_fc_daynames, .eventon_fullcal .evo_fc_day{
	border-color: transparent;
}

.eventon_fc_days .evo_fc_day{
	color: black;
	font-weight:300;
	font-size: 15px;
}

.eventon_fc_days .evo_fc_day.has_events{
	color: #990000 !important;
	font-weight: 700;
}

.evofc_month_grid .eventon_fc_days .evo_fc_day.today:before{
	background-color: #990000;
}

.eventon_fc_daynames .evo_fc_day{
	color: #dbd1d1;
	font-weight: 300;
}

.today{
	background-color: #990000 !important;
	color: white !important;
	font-weight: 700 !important;
	border-radius: 10px;
}

.evofc_title_tip p{
	color: #990000 !important;
}

.eventon_fullcal ul.evofc_ttle_events li{
	text-transform: capitalize;
	line-height: 1.1;
	background-color: white;
	font-weight: 400;
	color: #990000;
	display: block !important;
	width: 200px;
	font-size: 10px;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}


.evofc_title_tip .evofc_ttle_cnt,
.evofc_title_tip.topper.lefter .evofc_ttle_cnt{
	background-color: #990000;
	color: white;
	display: block !important;
	top: 100%;
	
}

/*Slider Transparency*/

.unicamp-modern-slider-style-04 .tm-modern-slider .slide-layer{
	background-color: #ffffff4d;
}

/*Slider Shadow*/

.tm-modern-slider .title {
    text-shadow: 2px 2px 4px #000000;
}

.slider-shadow .description{
	text-shadow: 2px 2px 4px #000000;
}

/* Language Switcher */
/*.menu-item-title img{
	width: 20px !important;
	height: 15px !important;
	margin-top: 5px;
}

.lang-item-en{
	margin-left: -20px !important;
}*/

.elementor-widget-wp-widget-polylang ul{
	list-style-type: none !important;
}

.lang-item img{
	width: 25px !important;
	height: auto !important;
}

.lang-item-el{
	margin-left:-50px;
}

.lang-item-en{
	margin-top: -28px;
	margin-left: -15px
}

/*Anakoinwsi elke*/
body:not(.rtl) .elementor-2136 .elementor-element.elementor-element-36b90bfd{
	display: none !important;
}

/*Blog Author, Views & Comments*/
.post-meta-author{
	display: none !important;
}

.post-view{
	display: none !important;
}

.post-comments{
	display: none !important;
}

/*Secondary Menu distance*/
.menu-item-1284{
	margin-left: -20px !important
}

.menu-item-886{
	margin-left: -20px !important
}

.menu-item-1460{
	margin-left: -20px !important
}
/*
.menu-item-21932{
	margin-left: -5px !important
}

.menu-item-21933{
	margin-left: -20px !important
}

.menu-item-21938{
	margin-left: -20px !important
}

.menu-item-21934{
	margin-left: -20px !important
}

.menu-item-21939{
	margin-l
*/

/*Share Post Remove*/
.entry-post-share{
	display: none !important;
}

/*EVENTS ON CUSTOMIZE*/
.tribe-events-header{
	margin-top: -105px !important;
}

.tribe-events-c-subscribe-dropdown__container{
	display: none !important;
}

/*Posts Resize Title Fonts*/
.post-title{
	font-size: 14px !important;
}

/*IMAGE Resolution Absolut*/
.unicamp-blog .post-thumbnail img{
	width: 100%;
	object-fit: contain;
	display: block;
	margin-left: auto;
  margin-right: auto;
}

/* disable header events*/

.post-type-archive-tribe_events #header,
.single-tribe_events #header{
    display: none;
}

/*The Events Calendar Pro Customizations*/
.tribe-common--breakpoint-medium.tribe-common .tribe-common-b2--min-medium {
	display: none !important;
}

.tribe-events .tribe-events-calendar-month__mobile-events-icon--event{
	background-color: #990000 !important;
}

.tribe-events .tribe-events-calendar-month__day-cell--selected, .tribe-events .tribe-events-calendar-month__day-cell--selected:focus, .tribe-events .tribe-events-calendar-month__day-cell--selected:hover{
	background-color: #990000 !important;
}

.tribe-events .tribe-events-calendar-month__day-cell--selected .tribe-events-calendar-month__mobile-events-icon--event{
	background-color: white !important;
}

/* Events Inner Remove time */
.tribe-events-schedule{
	display: none !important;
}

.tribe-events-start-time-label{
	display: none !important;
}

.tribe-events-start-time{
	display: none !important;
}

.tribe-events-single-event-title{
	display: none !important;
}

/*Electronikes ekdosis*/

.post-count::before{
	display: none;
}

.post-title-2-rows{
	-webkit-line-clamp: 5 !important;
	-webkit-box-orient: vertical !important;
	max-width: 170px;
}

/*EKDILOSEIS PAGE CUSTOMIZATION*/
.ect-advance-list.dataTable thead th, #ect-viewmoreBtn span{
	background-color: #990000 !important;
}

/*PODCAST*/
.stoxos{
	border: 1px solid #e2e2e1 !important;
	padding-bottom: 30px;
	padding-top: 80px;
	margin-left: 62% !important;
	margin-top: -30px !important;
	margin-bottom: -20px !important;
	width: 320px !important;
	text-align: center !important;
}

/*Ribbon icons footer*/

.eksafanisi{
	display: none !important;
}

/*Contact Form Hidden Fields*/

.hidden-fields-container{
	display: none !important;
}

.wpcf7-response-output{
	display: none !important;
}
