  <meta name="theme-color" content="#ffffff">
  <meta name="msapplication-TileColor" content="#da532c">
	<title>找不到頁面 Page Not Found 404</title>
	<link rel="stylesheet" href="/assets/themes/main/css/style.css" media="all">
	<style>

    @media screen and (max-width: 1199px) {
    }
    @media screen and (max-width: 991px) {
    }
    @media screen and (max-width: 767px) {
    }
    </style>
</head>


<body>
<header class="page-head" style="padding: 18px 0; border-bottom:2px solid #0A92CC;">
	<div class="container">
		<div class="page-head__left">
			<a class="page-logo" href="/">
				<img class="page-logo__img" src="/assets/shared/img/logo_1x.png" srcset="/assets/shared/img/logo_2x.png 2x, /assets/shared/img/logo_3x.png 3x" alt="HKUGA College">
			</a>
		</div>
	</div>
</header>
	<div class="container mb-5" style="padding-top: 150px;">

	
		<h1 style="font-size:42px;text-align: center;font-weight: bold;color: #0A92CC;">非常抱歉... <span style="color: #f76911">找不到相符的頁面</span></h1>
		<hr>
		<div style="text-align: center;font-size: 28px;">
			<p>你點擊進來的連結可能不正確</p>
			<div class="mt-3">
				<a href="javascript:history.back();" class="error-btn mt-4">返回</a>
				<a href="/" class="error-btn mt-4">首頁</a>
			</div>
		</div>
	</div>
	
</body>

