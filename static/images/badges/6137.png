	明愛啟幼幼兒學校網頁
</title><link rel="stylesheet" href="../Styles/site_style.css?t=202303131822" type="text/css" /><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.7.0/css/all.min.css" /><link rel="shortcut icon" href="../images/favicon.ico" /><link href="../Scripts/jplayer/dist/skin/blue.monday/css/jplayer.blue.monday.min.css?t=202303131822" rel="stylesheet" type="text/css" />
    <script type="text/javascript" src="./Scripts/jplayer/lib/jquery.min.js"></script>
    <script type="text/javascript" src="./Scripts/jplayer/dist/jplayer/jquery.jplayer.min.js"></script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
        
    <style type="text/css"> 
        .Menu {
            z-index: 25000 !important;
        }

        .audio::-webkit-media-controls-timeline {
            display: none !important;
        }

        .t-container.t-container-fluid.background_image {
            padding-left: 0px !important;
            padding-right: 0px !important;
        }
    </style>
    <script type="text/javascript">        
        function openLyric() {
            window.open()
        }

        function playMusic() {
            $('#jquery_jplayer_1').jPlayer("play");
        }

        function pauseMusic() {
            $('#jquery_jplayer_1').jPlayer("pause");
        }

        function endMusic() {
            $('.btn_link_clicked').removeClass('btn_link_clicked');
            $('.btn_txt').addClass('btn_link');
        }

        function OnClientItemClicking(sender, args) {
            if (args.get_item().get_navigateUrl() == "#") {
                args.get_item().open();
                args.set_cancel(true);
            }
        }

        function ExpandOpenedItem(sender, args) {
            var rmGroup = args.get_item().get_childListElement();
            //var item_color = rmGroup.item_color();
            var item = args.get_item();
            //console.log(item.get_attributes().getAttribute("item_color"));
            setSlideHeight(rmGroup);
        }

        function ExpandClosedItem(sender, args) {
            var rmGroup = $(args.get_item().get_element()).parent();
            setSlideHeight(rmGroup);
        }

        function setSlideHeight(rmGroup) {
            var rmGroupHeight = $(rmGroup).height();
            $(".rmSlide").height(rmGroupHeight);
            $(".rmSlide").css("max-height", rmGroupHeight)
        }

        $(function () {
            $('.btn_txt.btn_link, .btn_txt.btn_link_clicked').click(function () {
                var wasPlay = $(this).hasClass('btn_txt btn_link');
                var clicked_class = wasPlay ? 'btn_txt btn_link' : 'btn_txt btn_link_clicked';
                var other_class = wasPlay ? 'btn_txt btn_link_clicked' : 'btn_txt btn_link';
                $(this).removeClass(clicked_class);
                $(this).addClass(other_class);                
                if (wasPlay) {
                    playMusic();
                    $('#jquery_jplayer_1').bind($.jPlayer.event.ended + ".jp-repeat", function (event) { // Using ".jp-repeat" namespace so we can easily remove this event
                        playMusic();
                    });
                } else {
                    pauseMusic();
                    $("#jquery_jplayer_1").unbind($.jPlayer.event.ended + ".jp-repeat");
                }                    
            });                      
        });
    </script>
        
    <style type="text/css">
        .auto-style1 {
            /*width: 350px;*/
        }

        .rigDotList {
            display: none;
        }

        .title_style {
            font-size: 20px;
        }

        .auto-style2 {
            height: 25px;
        }

        .rainbow_text {
            background: linear-gradient(to right, orange, gold, green, cyan, blue, violet);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .purple_text {
            color: #5a16c8;
        }

        .rigActionButton  {
            color: #000000;
        }

        .MediaPlayer {
            z-index: 20000;
        }

        .rmpToolbarWrapper {
            display: block !important;
        }

        .rmpTitleBar, #ctl00_ContentPlaceHolder1_RadMediaPlayer1_Toolbar_SubtitlesButton, #ctl00_ContentPlaceHolder1_RadMediaPlayer1_Toolbar_HDButton {
            display: none !important;
        }

        /*.rigActiveImage {
            cursor: pointer;
        }*/
    </style>
    <script type="text/javascript">        
        function play_slide_show() {
            $find("ctl00_ContentPlaceHolder1_RadImageGallery1").playSlideshow();
        }

        function imageLoaded(sender, args) {
            var image = args.get_image(),
            imageItem = args.get_item();
            var lang = $find('ctl00_ContentPlaceHolder1_RadImageGallery1').get_element().getAttribute("lang");
            var str_length = 13;
            var str_split = 17;

            if (lang == "en-US") {
                str_length = 35;
                str_split = 35;
            }

            $('#ctl00_ContentPlaceHolder1_lbl_banner_name').fadeOut(500, function () {
                var str = imageItem.get_title();
                if (str.length >= str_length) {
                    var desc = imageItem.get_title();

                    $(this).css('font-size', '15px');
                    $(this).css('color', 'black');
                    $(this).css('overflow-wrap', 'normal');
                    $(this).html(desc).fadeIn(500);
                } else {
                    $(this).css('font-size', '22px');
                    $(this).css('color', 'black');
                    $(this).css('overflow-wrap', 'normal');
                    $(this).text(imageItem.get_title()).fadeIn(500);
                }
            });
        }

        function rdpVideo_Play(sender, args) {
            var mp = $("#ctl00_ContentPlaceHolder1_RadMediaPlayer1_Toolbar_Wrapper");
            //console.log(mp);
        }

        function rdpVideo_Ended(sender, args) {
            $find('ctl00_ContentPlaceHolder1_RadMediaPlayer1').play();
        }

        function OnClientShow(sender, args) {
            $("#ctl00_ContentPlaceHolder1_popup_window_C").attr("class", "");
            sender.add_close(OnClientClose);
        }

        function OnClientClose(oWnd) {
            //player.pauseVideo();
            console.log("Close")
            $("#ctl00_ContentPlaceHolder1_popup_window_C").html("");
        }
    </script>
