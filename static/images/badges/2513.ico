    <script type="text/javascript">
        $(document).ready(function() {
            const ori_total = parseInt($('#section4').data('total'));
            let slider_loop = ori_total >= 3 ? true : false;
            $('#section4').Slider({
                slides: '.record-item',
                maxSlide: 1,
                swipeControl: true,
                skipBoundary: true,
                infiniteLoop: slider_loop,
                dummySlide: slider_loop,
				afterSlide: function(slider, slides, current_page, total_page) {
					if(slider_loop) {
						if(current_page == ori_total) {
							slider.Slider('jump', ori_total * 2).Slider('start');
						}
						if(current_page == ori_total * 2 + 1) {
							slider.Slider('jump', ori_total + 1).Slider('start');
						}
					}
				},
                afterInit: function(slider, slides, current_page, total_page) {
                    if(slider_loop) {
                        slider.Slider('jump', ori_total * 2);
                    }
                    else {
                        slider.Slider('jump', total_page);
                    }
                }
            });
        });
    </script>
</section>
<section id="section6">
    <div class="container">
        <div class="section-title">
            <h2 class="colour2">Testimonials</h2>
            <span class="bg-colour1"></span>
        </div>
        <div class="wrapper">
            <div class="tabs">
                                    <button class="tab current" data-id="1">Students</button>
                                    <button class="tab" data-id="2">Parents</button>
                                    <button class="tab" data-id="3">Alumni</button>
                            </div>
            <select class="tab-select" name="tab"><option value="1">Students</option><option value="2">Parents</option><option value="3">Alumni</option></select>                            <div class="tab-content current" data-id="1">
                                            <div class="record-slider">
                            <div class="slider-container">
                                                                    <div class="record-item">
                                        <div class="left">
                                            <div class="thumbnail bg-colour1">
                                                <span></span>
                                                <img src="/cache/img/6fdd5da06b481e18ac269004adcd1cdd.png" alt="Testimonial-Boy" loading="lazy" width="548" height="548" />                                            </div>
                                                                                            <div class="slider-pager">
                                                    <button class="prev"></button>
                                                    <span>1 / 2</span>
                                                    <button class="next"></button>
                                                </div>
                                                                                    </div>
                                        <div class="right">
                                            <article>
                                                                                                    <div class="content">
                                                        <p class="description">I think Quarry Bay School is a great place to be because the teachers are very kind and help us a lot. Lessons are fun and we get to work together with our friends.</p>
                                                        <button class="view-more">
                                                            <span>View More</span>
                                                        </button>
                                                        <p class="content">I think Quarry Bay School is a great place to be because the teachers are very kind and help us a lot. Lessons are fun and we get to work together with our friends.</p>
                                                        <button class="view-less">
                                                            <span>View Less</span>
                                                        </button>
                                                    </div>
                                                                                            </article>
                                                                                            <div class="title">
                                                    <span></span>
                                                    <h3>Joshua M - Y6 Student, Class of 2021</h3>
                                                </div>
                                                                                    </div>
                                    </div>
                                                                    <div class="record-item">
                                        <div class="left">
                                            <div class="thumbnail bg-colour1">
                                                <span></span>
                                                <img src="/cache/img/203fa44e5899422e95306753a6f5fa92.png" alt="Testimonial-Girl" loading="lazy" width="548" height="548" />                                            </div>
                                                                                            <div class="slider-pager">
                                                    <button class="prev"></button>
                                                    <span>2 / 2</span>
                                                    <button class="next"></button>
                                                </div>
                                                                                    </div>
                                        <div class="right">
                                            <article>
                                                                                                    <div class="content">
                                                        <p class="description">I absolutely loved being a part of Quarry Bay School. The vast array of learning opportunities available here was truly remarkable, and I always felt supported when I needed extra help. My fondest memory is the joy of talking and playing with my friends during recess in the vibrant school playground.</p>
                                                        <button class="view-more">
                                                            <span>View More</span>
                                                        </button>
                                                        <p class="content">I absolutely loved being a part of Quarry Bay School. The vast array of learning opportunities available here was truly remarkable, and I always felt supported when I needed extra help. My fondest memory is the joy of talking and playing with my friends during recess in the vibrant school playground.</p>
                                                        <button class="view-less">
                                                            <span>View Less</span>
                                                        </button>
                                                    </div>
                                                                                            </article>
                                                                                            <div class="title">
                                                    <span></span>
                                                    <h3>Grace M - Y6 Student, Class of 2024</h3>
                                                </div>
                                                                                    </div>
                                    </div>
                                                            </div>
                        </div>
                                    </div>
                            <div class="tab-content" data-id="2">
                                            <div class="record-slider">
                            <div class="slider-container">
                                                                    <div class="record-item">
                                        <div class="left">
                                            <div class="thumbnail bg-colour1">
                                                <span></span>
                                                <img src="/cache/img/45b3d5d1de58b2d7776ab6c2154698cf.png" alt="Testimonial-Woman" loading="lazy" width="548" height="548" />                                            </div>
                                                                                            <div class="slider-pager">
                                                    <button class="prev"></button>
                                                    <span>1 / 2</span>
                                                    <button class="next"></button>
                                                </div>
                                                                                    </div>
                                        <div class="right">
                                            <article>
                                                                                                    <div class="content">
                                                        <p class="description">As a parent of 3 children in Quarry Bay School, I believe QBS offers the best of both worlds, an international yet local community. With a down-to-earth feel, QBS is a school where academics go hand in hand with happiness, lots of love and enthusiasm and a passion for learning in a variety of ways. QBS is a school that brings out the best in my children no matter their differences and personalities.</p>
                                                        <button class="view-more">
                                                            <span>View More</span>
                                                        </button>
                                                        <p class="content">As a parent of 3 children in Quarry Bay School, I believe QBS offers the best of both worlds, an international yet local community. With a down-to-earth feel, QBS is a school where academics go hand in hand with happiness, lots of love and enthusiasm and a passion for learning in a variety of ways. QBS is a school that brings out the best in my children no matter their differences and personalities.</p>
                                                        <button class="view-less">
                                                            <span>View Less</span>
                                                        </button>
                                                    </div>
                                                                                            </article>
                                                                                            <div class="title">
                                                    <span></span>
                                                    <h3>Franka K. - QBS parent</h3>
                                                </div>
                                                                                    </div>
                                    </div>
                                                                    <div class="record-item">
                                        <div class="left">
                                            <div class="thumbnail bg-colour1">
                                                <span></span>
                                                <img src="/cache/img/3d7fc8aea63a8142370a0fa05840ad79.png" alt="Testimonial-Man" loading="lazy" width="548" height="548" />                                            </div>
                                                                                            <div class="slider-pager">
                                                    <button class="prev"></button>
                                                    <span>2 / 2</span>
                                                    <button class="next"></button>
                                                </div>
                                                                                    </div>
                                        <div class="right">
                                            <article>
                                                                                                    <div class="content">
                                                        <p class="description">I've had the privilege of being part of the Quarry Bay School (QBS) community twice - first as a student and now as a parent for over 7 years. The excellent leadership team, the teachers and staff are friendly, enthusiastic, and caring towards every student. Both of my children have been very happy at QBS, learning in a positive environment and developing meaningful friendships. I highly recommend QBS to other parents.</p>
                                                        <button class="view-more">
                                                            <span>View More</span>
                                                        </button>
                                                        <p class="content">I've had the privilege of being part of the Quarry Bay School (QBS) community twice - first as a student and now as a parent for over 7 years. The excellent leadership team, the teachers and staff are friendly, enthusiastic, and caring towards every student. Both of my children have been very happy at QBS, learning in a positive environment and developing meaningful friendships. I highly recommend QBS to other parents.</p>
                                                        <button class="view-less">
                                                            <span>View Less</span>
                                                        </button>
                                                    </div>
                                                                                            </article>
                                                                                            <div class="title">
                                                    <span></span>
                                                    <h3>Andrew Y. - QBS parent</h3>
                                                </div>
                                                                                    </div>
                                    </div>
                                                            </div>
                        </div>
                                    </div>
                            <div class="tab-content" data-id="3">
                                            <div class="record-slider">
                            <div class="slider-container">
                                                                    <div class="record-item">
                                        <div class="left">
                                            <div class="thumbnail bg-colour1">
                                                <span></span>
                                                <img src="/cache/img/f658b10579dd16bb5c0779aaba41390c.png" alt="Testimonial-Woman" loading="lazy" width="548" height="548" />                                            </div>
                                                                                            <div class="slider-pager">
                                                    <button class="prev"></button>
                                                    <span>1 / 2</span>
                                                    <button class="next"></button>
                                                </div>
                                                                                    </div>
                                        <div class="right">
                                            <article>
                                                                                                    <div class="content">
                                                        <p class="description">As a former Quarry Bay School student from 2012-2015, I was thrilled to work at the school for a year. I'm deeply passionate about QBS's core values and the caring, supportive community that empowers the student body. QBS is a highly creative school that encourages self-expression across all subjects. I love being a part of this positive environment surrounded by a friendly, social community. QBS provides students with diverse opportunities that enhance their overall school experience. During my time as a student, I was heavily involved in sports, representing the school in various internal and external events. I believe student participation in school activities is crucial for building confidence, developing social skills, and forming strong relationships.</p>
                                                        <button class="view-more">
                                                            <span>View More</span>
                                                        </button>
                                                        <p class="content">As a former Quarry Bay School student from 2012-2015, I was thrilled to work at the school for a year. I'm deeply passionate about QBS's core values and the caring, supportive community that empowers the student body. QBS is a highly creative school that encourages self-expression across all subjects. I love being a part of this positive environment surrounded by a friendly, social community. QBS provides students with diverse opportunities that enhance their overall school experience. During my time as a student, I was heavily involved in sports, representing the school in various internal and external events. I believe student participation in school activities is crucial for building confidence, developing social skills, and forming strong relationships.</p>
                                                        <button class="view-less">
                                                            <span>View Less</span>
                                                        </button>
                                                    </div>
                                                                                            </article>
                                                                                            <div class="title">
                                                    <span></span>
                                                    <h3>Hannah M. - Class of 2015</h3>
                                                </div>
                                                                                    </div>
                                    </div>
                                                                    <div class="record-item">
                                        <div class="left">
                                            <div class="thumbnail bg-colour1">
                                                <span></span>
                                                <img src="/cache/img/a665f93b2a562ef4cbf6352168f774d7.png" alt="Testimonial-Woman" loading="lazy" width="548" height="548" />                                            </div>
                                                                                            <div class="slider-pager">
                                                    <button class="prev"></button>
                                                    <span>2 / 2</span>
                                                    <button class="next"></button>
                                                </div>
                                                                                    </div>
                                        <div class="right">
                                            <article>
                                                                                                    <div class="content">
                                                        <p class="description">Quarry Bay School manages to combine high expectations and academic rigour with some of the softer skills that will be so necessary for our children's future. Children here are happy, curious and kind. Most important of all, they love learning and enjoy coming to school. Parents, children and teachers all play a part in the supportive school community which creates a great sense of belonging.</p>
                                                        <button class="view-more">
                                                            <span>View More</span>
                                                        </button>
                                                        <p class="content">Quarry Bay School manages to combine high expectations and academic rigour with some of the softer skills that will be so necessary for our children's future. Children here are happy, curious and kind. Most important of all, they love learning and enjoy coming to school. Parents, children and teachers all play a part in the supportive school community which creates a great sense of belonging.</p>
                                                        <button class="view-less">
                                                            <span>View Less</span>
