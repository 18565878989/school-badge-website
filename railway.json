{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "PYTHON",
    "pythonVersion": "3.11"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "runtime": "V2",
    "command": "gunicorn --bind 0.0.0.0:$PORT app:app"
  }
}
